{
  "weights": {
    "required_findings": 0.25,
    "file_references": 0.30,
    "causal_chain": 0.30,
    "negative_checks": 0.15
  },
  "required_findings": [
    {
      "id": "purpose_ebpf_datapath",
      "patterns": ["eBPF.*datapath", "kernel.*networking", "packet processing", "XDP|TC|cgroup"],
      "weight": 1.0,
      "description": "Identifies that eBPF datapath handles kernel-level packet processing and policy enforcement",
      "section": "purpose"
    },
    {
      "id": "purpose_performance",
      "patterns": ["performance", "iptables.*slow", "kernel.*space", "avoid.*context.*switch"],
      "weight": 1.0,
      "description": "Explains why eBPF is used instead of iptables (performance, kernel-space processing)",
      "section": "purpose"
    },
    {
      "id": "purpose_policy_enforcement",
      "patterns": ["network.*polic(y|ies)", "security.*polic(y|ies)", "L3.*L4.*L7", "enforce"],
      "weight": 1.0,
      "description": "Identifies policy enforcement as a key responsibility",
      "section": "purpose"
    },
    {
      "id": "deps_loader",
      "patterns": ["loader", "pkg/datapath/loader", "load.*eBPF.*program"],
      "weight": 1.0,
      "description": "Identifies the eBPF loader as a key component",
      "section": "dependencies"
    },
    {
      "id": "deps_policy",
      "patterns": ["pkg/policy", "policy.*repository", "PolicyImporter"],
      "weight": 1.0,
      "description": "Identifies policy subsystem as upstream dependency",
      "section": "dependencies"
    },
    {
      "id": "deps_maps",
      "patterns": ["eBPF.*map", "pkg/maps", "BPF.*map"],
      "weight": 1.0,
      "description": "Identifies eBPF maps as critical data structures",
      "section": "dependencies"
    },
    {
      "id": "failure_mode_verifier",
      "patterns": ["verifier.*fail", "eBPF.*verifier", "kernel.*verifier", "instruction limit"],
      "weight": 1.0,
      "description": "Mentions eBPF verifier failures as a failure mode",
      "section": "failure_modes"
    },
    {
      "id": "failure_mode_map_full",
      "patterns": ["map.*full", "map.*capacity", "ENOSPC"],
      "weight": 1.0,
      "description": "Mentions eBPF map capacity issues as failure mode",
      "section": "failure_modes"
    },
    {
      "id": "testing_datapath",
      "patterns": ["test.*datapath", "bpf.*test", "test/bpf"],
      "weight": 1.0,
      "description": "Identifies datapath tests",
      "section": "testing"
    },
    {
      "id": "debugging_bpftool",
      "patterns": ["bpftool", "cilium monitor", "cilium bpf", "tc filter show"],
      "weight": 1.0,
      "description": "Mentions debugging tools like bpftool or cilium monitor",
      "section": "debugging"
    }
  ],
  "file_references": [
    {
      "id": "file_loader",
      "patterns": ["pkg/datapath/loader"],
      "weight": 2.0,
      "description": "eBPF loader directory",
      "section": "key_files"
    },
    {
      "id": "file_bpf_programs",
      "patterns": ["bpf/.*\\.c", "bpf/", "bpf_host\\.c", "bpf_lxc\\.c", "bpf_overlay\\.c"],
      "weight": 2.0,
      "description": "eBPF C program files",
      "section": "key_files"
    },
    {
      "id": "file_maps",
      "patterns": ["pkg/maps"],
      "weight": 1.5,
      "description": "eBPF maps management",
      "section": "key_files"
    },
    {
      "id": "file_policy_map",
      "patterns": ["pkg/maps/policymap", "policymap"],
      "weight": 1.0,
      "description": "Policy map implementation",
      "section": "key_files"
    },
    {
      "id": "file_datapath_linux",
      "patterns": ["pkg/datapath/linux"],
      "weight": 1.5,
      "description": "Linux-specific datapath implementation",
      "section": "key_files"
    },
    {
      "id": "file_endpoint_regeneration",
      "patterns": ["pkg/endpoint.*regenerat", "endpoint.*bpf", "regenerateBPF"],
      "weight": 1.0,
      "description": "Endpoint regeneration (triggers eBPF program recompilation/reload)",
      "section": "key_files"
    },
    {
      "id": "file_compile",
      "patterns": ["pkg/datapath/linux/compile", "compile.*bpf"],
      "weight": 1.0,
      "description": "eBPF compilation logic",
      "section": "key_files"
    },
    {
      "id": "test_datapath",
      "patterns": ["test.*datapath", "pkg/datapath.*test", "bpf.*test"],
      "weight": 1.0,
      "description": "Datapath test files",
      "section": "testing"
    }
  ],
  "causal_chain": [
    {
      "id": "chain_policy_to_bpf",
      "patterns": ["policy.*update|policy.*change", "regenerat.*endpoint|endpoint.*regenerat", "load.*eBPF|eBPF.*load|compile.*eBPF"],
      "weight": 2.0,
      "description": "Describes policy update flow: policy change -> endpoint regeneration -> eBPF recompilation/reload",
      "section": "purpose"
    },
    {
      "id": "chain_loader_flow",
      "patterns": ["compile|clang|llvm", "load.*kernel|attach.*program", "netlink|TC|XDP"],
      "weight": 1.5,
      "description": "Describes eBPF loader flow: compile C -> load into kernel -> attach to hook",
      "section": "key_files"
    },
    {
      "id": "chain_map_update",
      "patterns": ["policy.*map|policymap", "key.*value", "BPF_MAP_UPDATE"],
      "weight": 1.5,
      "description": "Describes how policies are enforced via map updates (policymap key-value updates)",
      "section": "purpose"
    },
    {
      "id": "chain_failure_recovery",
      "patterns": ["verifier.*fail|fail.*load", "rollback|previous.*version|endpoint.*fail"],
      "weight": 1.0,
      "description": "Describes failure recovery: verifier failure -> rollback or endpoint failure state",
      "section": "failure_modes"
    }
  ],
  "negative_checks": [
    {
      "id": "neg_userspace_only",
      "patterns": ["eBPF.*userspace only|datapath.*runs.*userspace"],
      "weight": 1.0,
      "description": "Incorrectly claims eBPF datapath runs in userspace (it runs in kernel)",
      "section": "purpose",
      "should_not_match": true
    },
    {
      "id": "neg_single_program",
      "patterns": ["single.*eBPF.*program|one.*eBPF.*program"],
      "weight": 1.0,
      "description": "Incorrectly claims there's a single eBPF program (Cilium uses multiple: bpf_host, bpf_lxc, bpf_overlay, etc.)",
      "section": "key_files",
      "should_not_match": true
    }
  ]
}
