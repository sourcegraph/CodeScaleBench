{
  "task_id": "onboard-orient-002",
  "description": "Argo CD codebase orientation — onboarding exploration",
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.30,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies cmd/argocd-server/main.go as API server entry point",
      "patterns": ["cmd/argocd.server/main\\.go", "argocd.server.*main", "API.*server.*cmd/"],
      "weight": 0.10
    },
    {
      "id": "f2",
      "description": "Identifies cmd/argocd-application-controller/main.go as application controller entry point",
      "patterns": ["cmd/argocd.application.controller/main\\.go", "application.controller.*main"],
      "weight": 0.10
    },
    {
      "id": "f3",
      "description": "Identifies cmd/argocd-repo-server/main.go as repo server entry point",
      "patterns": ["cmd/argocd.repo.server/main\\.go", "repo.server.*main"],
      "weight": 0.10
    },
    {
      "id": "f4",
      "description": "Identifies controller/ or controller/state.go for application reconciliation logic",
      "patterns": ["controller/state\\.go", "controller/sync\\.go", "application.*controller.*reconcil"],
      "weight": 0.12
    },
    {
      "id": "f5",
      "description": "Identifies reposerver/ package for repository interaction",
      "patterns": ["reposerver/", "repo.*server.*manifest|manifest.*generat"],
      "weight": 0.10
    },
    {
      "id": "f6",
      "description": "Identifies pkg/apis/application/ for CRD types",
      "patterns": ["pkg/apis/application", "v1alpha1/types\\.go", "ApplicationSpec|ApplicationStatus"],
      "weight": 0.12
    },
    {
      "id": "f7",
      "description": "Identifies util/ packages for common utilities",
      "patterns": ["util/git", "util/helm", "util/kube", "util/argo"],
      "weight": 0.08
    },
    {
      "id": "f8",
      "description": "Mentions Cobra for CLI framework",
      "patterns": ["[Cc]obra", "spf13/cobra"],
      "weight": 0.08
    },
    {
      "id": "f9",
      "description": "Identifies test/e2e/ for end-to-end tests",
      "patterns": ["test/e2e", "e2e.*test"],
      "weight": 0.10
    },
    {
      "id": "f10",
      "description": "Mentions testify or mock frameworks for unit testing",
      "patterns": ["testify", "stretchr/testify", "mock", "_test\\.go"],
      "weight": 0.10
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References cmd/argocd-server/main.go",
      "patterns": ["cmd/argocd.server/main\\.go"],
      "weight": 0.12
    },
    {
      "id": "r2",
      "description": "References cmd/argocd-application-controller/main.go",
      "patterns": ["cmd/argocd.application.controller/main\\.go"],
      "weight": 0.12
    },
    {
      "id": "r3",
      "description": "References cmd/argocd-repo-server/main.go",
      "patterns": ["cmd/argocd.repo.server/main\\.go"],
      "weight": 0.12
    },
    {
      "id": "r4",
      "description": "References pkg/apis/application/v1alpha1/types.go for CRD definitions",
      "patterns": ["pkg/apis/application/v1alpha1/types\\.go", "v1alpha1.*types"],
      "weight": 0.15
    },
    {
      "id": "r5",
      "description": "References controller/state.go or controller/sync.go for sync logic",
      "patterns": ["controller/state\\.go", "controller/sync\\.go"],
      "weight": 0.12
    },
    {
      "id": "r6",
      "description": "References reposerver/repository/ for manifest generation",
      "patterns": ["reposerver/repository", "repository/repository\\.go"],
      "weight": 0.12
    },
    {
      "id": "r7",
      "description": "References util/ packages (git, kube, helm, argo)",
      "patterns": ["util/git", "util/kube", "util/helm", "util/argo"],
      "weight": 0.10
    },
    {
      "id": "r8",
      "description": "References test/e2e/ directory or test structure",
      "patterns": ["test/e2e", "test/fixture"],
      "weight": 0.08
    },
    {
      "id": "r9",
      "description": "References ApplicationSet controller (cmd/argocd-applicationset-controller or applicationset/)",
      "patterns": ["cmd/argocd.applicationset.controller", "applicationset/controller"],
      "weight": 0.07
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Application sync pipeline: CRD types → controller reconciliation → repo server manifest generation → kubectl apply/sync",
      "patterns": [
        "Application.*CRD|pkg/apis/application|v1alpha1|ApplicationSpec",
        "controller.*reconcil|application.controller|state\\.go|sync\\.go|CompareAppState",
        "repo.*server|manifest.*generat|reposerver/repository|GenerateManifest",
        "kubectl.*apply|sync.*resource|apply.*sync|LiveStateCache"
      ],
      "ordered": true,
      "weight": 0.60
    },
    {
      "id": "c2",
      "description": "Config pipeline: Cobra CLI → flags/env vars → component-specific config structs",
      "patterns": [
        "[Cc]obra|CLI|command|rootCmd",
        "flags|env.*var|viper|pflag",
        "config|settings|ArgoCDSettings|ServerOptions|ControllerOptions"
      ],
      "ordered": true,
      "weight": 0.40
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT claim there is a single monolithic entry point (Argo CD has multiple binaries)",
      "patterns": ["single.*entry.*point|monolithic.*main|one.*main.*function"],
      "must_be_absent": true,
      "weight": 0.60
    },
    {
      "id": "n2",
      "description": "Does NOT confuse ApplicationSet controller with Application controller (they are separate)",
      "patterns": ["ApplicationSet.*controller.*same|Application.*controller.*handles.*ApplicationSet"],
      "must_be_absent": true,
      "weight": 0.40
    }
  ]
}
