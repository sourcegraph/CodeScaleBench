{
  "weights": {
    "required_findings": 0.35,
    "file_references": 0.35,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "weight": 0.25,
      "description": "Identifies Gradle as the build system",
      "patterns": [
        "(?i)gradle",
        "gradlew",
        "build\\.gradle"
      ]
    },
    {
      "weight": 0.30,
      "description": "Identifies core modules: core, clients, server/streams",
      "patterns": [
        "(?i)core/",
        "(?i)clients/",
        "(?i)streams/|server"
      ]
    },
    {
      "weight": 0.25,
      "description": "Identifies KafkaConfig as the configuration registry",
      "patterns": [
        "KafkaConfig",
        "kafka\\.server\\.KafkaConfig"
      ]
    },
    {
      "weight": 0.20,
      "description": "Mentions testing frameworks (EmbeddedKafka or TopologyTestDriver)",
      "patterns": [
        "(?i)embeddedkafka",
        "(?i)topologytestdriver",
        "(?i)kafka.*junit"
      ]
    }
  ],
  "file_references": [
    {
      "weight": 0.20,
      "description": "References kafka-server-start.sh as entry script",
      "patterns": [
        "kafka-server-start\\.sh",
        "bin/kafka-server-start"
      ]
    },
    {
      "weight": 0.25,
      "description": "References KafkaServer or BrokerServer/KafkaRaftServer classes",
      "patterns": [
        "(?i)kafkaserver",
        "(?i)brokerserver",
        "(?i)kafkaraftserver"
      ]
    },
    {
      "weight": 0.20,
      "description": "References KafkaApis.scala or handleCreateTopicsRequest",
      "patterns": [
        "KafkaApis",
        "handleCreateTopics",
        "kafka/server/KafkaApis"
      ]
    },
    {
      "weight": 0.20,
      "description": "References KafkaConfig.scala file location",
      "patterns": [
        "KafkaConfig\\.scala",
        "core/src/main/scala/kafka/server/KafkaConfig"
      ]
    },
    {
      "weight": 0.15,
      "description": "References DynamicBrokerConfig for runtime updates",
      "patterns": [
        "DynamicBrokerConfig",
        "(?i)dynamic.*config"
      ]
    }
  ],
  "causal_chain": [
    {
      "weight": 0.20,
      "description": "Explains that core/ contains broker implementation in Scala",
      "patterns": [
        "(?i)core",
        "(?i)broker",
        "(?i)scala"
      ]
    },
    {
      "weight": 0.35,
      "description": "Describes topic creation flow: AdminClient -> KafkaApis -> AdminManager",
      "patterns": [
        "(?i)adminclient|createtopics",
        "(?i)kafkaapis",
        "(?i)adminmanager|handlecreatetopics"
      ]
    },
    {
      "weight": 0.15,
      "description": "Explains configDef.define() pattern for config definition",
      "patterns": [
        "configDef\\.define",
        "(?i)define"
      ]
    },
    {
      "weight": 0.30,
      "description": "Describes steps to add broker config: modify KafkaConfig.scala, add field, extract value",
      "patterns": [
        "KafkaConfig",
        "(?i)field|add.*field",
        "(?i)value|extract|getString"
      ]
    }
  ],
  "negative_checks": [
    {
      "weight": 0.10,
      "description": "Penalize if agent claims there's a simple main() in a single file (Kafka has complex startup)",
      "patterns": [
        "(?i)single.*main.*method",
        "(?i)just.*run.*main"
      ]
    },
    {
      "weight": 0.10,
      "description": "Penalize if agent claims Kafka is monolithic (it's highly modular)",
      "patterns": [
        "(?i)monolithic",
        "(?i)single.*module"
      ]
    }
  ]
}
