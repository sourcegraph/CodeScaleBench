{
  "task_id": "nlqa-flow-001",
  "description": "Kafka message lifecycle: producer to broker to consumer",
  "weights": {
    "required_findings": 0.35,
    "file_references": 0.25,
    "causal_chain": 0.30,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies RecordAccumulator's role in batching messages",
      "patterns": ["RecordAccumulator", "accumulator.*batch|batch.*accumulator", "append.*batch"],
      "weight": 0.12
    },
    {
      "id": "f2",
      "description": "Explains Sender thread transmits batches when ready",
      "patterns": ["Sender|sender.*thread", "sendProduceRequest|send.*produce", "ready.*batch|batch.*ready"],
      "weight": 0.12
    },
    {
      "id": "f3",
      "description": "Identifies KafkaApis handles produce requests on broker",
      "patterns": ["KafkaApis|kafka.*apis", "handleProduceRequest|handle.*produce"],
      "weight": 0.10
    },
    {
      "id": "f4",
      "description": "Explains ReplicaManager coordinates append and replication",
      "patterns": ["ReplicaManager", "appendRecords|append.*replica", "maybeAddDelayedProduce"],
      "weight": 0.15
    },
    {
      "id": "f5",
      "description": "Mentions UnifiedLog or Log handles disk writes",
      "patterns": ["UnifiedLog|LocalLog|LogSegment", "append.*log|log.*append", "FileRecords"],
      "weight": 0.12
    },
    {
      "id": "f6",
      "description": "Identifies Fetcher component in consumer for fetch requests",
      "patterns": ["Fetcher|fetcher.*consumer", "sendFetches|fetch.*request"],
      "weight": 0.12
    },
    {
      "id": "f7",
      "description": "Explains poll() delegates to Fetcher to retrieve messages",
      "patterns": ["poll|KafkaConsumer.*poll", "fetchedRecords|completed.*fetch"],
      "weight": 0.10
    },
    {
      "id": "f8",
      "description": "Mentions serialization on producer side and deserialization on consumer side",
      "patterns": ["serializ|Serializer|Deserializer"],
      "weight": 0.10
    },
    {
      "id": "f9",
      "description": "Describes RecordBatch or MemoryRecords as protocol framing",
      "patterns": ["RecordBatch|MemoryRecords|DefaultRecordBatch"],
      "weight": 0.07
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References KafkaProducer.java",
      "patterns": ["clients/src/main/java/org/apache/kafka/clients/producer/KafkaProducer\\.java", "KafkaProducer\\.java"],
      "weight": 0.15
    },
    {
      "id": "r2",
      "description": "References RecordAccumulator.java",
      "patterns": ["clients/src/main/java/org/apache/kafka/clients/producer/internals/RecordAccumulator\\.java", "RecordAccumulator\\.java"],
      "weight": 0.20
    },
    {
      "id": "r3",
      "description": "References Sender.java",
      "patterns": ["clients/src/main/java/org/apache/kafka/clients/producer/internals/Sender\\.java", "Sender\\.java"],
      "weight": 0.15
    },
    {
      "id": "r4",
      "description": "References KafkaApis.scala or ReplicaManager.scala",
      "patterns": ["core/src/main/scala/kafka/server/KafkaApis\\.scala|core/src/main/scala/kafka/server/ReplicaManager\\.scala", "KafkaApis\\.scala|ReplicaManager\\.scala"],
      "weight": 0.20
    },
    {
      "id": "r5",
      "description": "References Fetcher.java or KafkaConsumer.java",
      "patterns": ["clients/src/main/java/org/apache/kafka/clients/consumer/internals/Fetcher\\.java|clients/src/main/java/org/apache/kafka/clients/consumer/KafkaConsumer\\.java", "Fetcher\\.java|KafkaConsumer\\.java"],
      "weight": 0.15
    },
    {
      "id": "r6",
      "description": "References UnifiedLog, LocalLog, or LogSegment (storage layer)",
      "patterns": ["storage.*Log|UnifiedLog|LocalLog|LogSegment", "core.*kafka/log/"],
      "weight": 0.15
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Producer flow: KafkaProducer.send → serialize → RecordAccumulator.append → Sender wakeup → sendProduceRequest → network transmission",
      "patterns": [
        "KafkaProducer.*send|doSend",
        "serializ",
        "RecordAccumulator.*append",
        "Sender|sender.*wakeup",
        "sendProduceRequest|ProduceRequest"
      ],
      "ordered": true,
      "weight": 0.35
    },
    {
      "id": "c2",
      "description": "Broker flow: KafkaApis.handleProduceRequest → ReplicaManager.appendRecords → UnifiedLog/LocalLog append → ReplicaFetcherThread replication → ack producer",
      "patterns": [
        "KafkaApis|handleProduceRequest",
        "ReplicaManager.*append",
        "UnifiedLog|LocalLog|log.*append",
        "replicat|ReplicaFetcher|follower",
        "ack|acknowledge|response.*producer"
      ],
      "ordered": true,
      "weight": 0.35
    },
    {
      "id": "c3",
      "description": "Consumer flow: KafkaConsumer.poll → Fetcher.sendFetches → broker response → parseCompletedFetch → deserialize → return ConsumerRecords",
      "patterns": [
        "KafkaConsumer.*poll",
        "Fetcher.*fetch|sendFetches",
        "completedFetch|fetch.*response",
        "deserializ",
        "ConsumerRecords"
      ],
      "ordered": true,
      "weight": 0.30
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT claim messages are sent synchronously per-record from producer (they are batched)",
      "patterns": ["send.*synchronous.*each.*record|per.*record.*network.*request|immediate.*send.*record"],
      "must_be_absent": true,
      "weight": 0.50
    },
    {
      "id": "n2",
      "description": "Does NOT confuse ZooKeeper with Kafka's message storage (ZK is metadata only, not message data)",
      "patterns": ["ZooKeeper.*store.*message|message.*persist.*ZooKeeper|ZK.*log.*append"],
      "must_be_absent": true,
      "weight": 0.50
    }
  ]
}
