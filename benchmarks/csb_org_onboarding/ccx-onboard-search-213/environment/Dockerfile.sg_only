# ccx-onboard-search-213 — sg_only_env variant
# Empty /app workspace — agent uses Sourcegraph MCP for code access.
# RepoQA verifier reads /app/solution.json only, so no repo restore is needed.

FROM ubuntu:22.04
ENV TASK_WORKDIR=/app
ENV TASK_REPO_ROOT=/app
ENV TASK_OUTPUT=/app/solution.json

ENV DEBIAN_FRONTEND=noninteractive
ENV SOURCEGRAPH_REPOS="sg-evals/vscode--17baf841"

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ca-certificates \
    python3 \
    curl \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /app

WORKDIR /app

# Empty git repo so agent can commit work
RUN git init && \
    git config user.email "agent@example.com" && \
    git config user.name "Agent"

RUN mkdir -p /logs/agent /logs/verifier
RUN chown -R claude:claude /logs

# Mark sg_only mode
RUN touch /tmp/.sg_only_mode

# Pre-create claude user and set ownership at build time.
RUN (adduser --disabled-password --gecos '' claude 2>/dev/null || true) && \
    for d in /app /testbed /logs; do [ -d "$d" ] && chown -R claude:claude "$d"; done || true

ENTRYPOINT []
