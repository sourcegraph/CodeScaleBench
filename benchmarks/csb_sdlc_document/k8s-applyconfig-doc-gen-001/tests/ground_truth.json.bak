      "description": "Pointer-field and With-method builder pattern",
      "patterns": [
        "With[A-Z]|builder",
        "pointer"
      ],
      "weight": 0.2
    },
    {
      "id": "t3",
      "description": "Extract-modify-apply workflow",
      "patterns": [
        "Extract|modify|apply"
      ],
      "weight": 0.2
    },
    {
      "id": "t4",
      "description": "Field manager and conflict behavior",
      "patterns": [
        "field manager|managedFields|conflict"
      ],
      "weight": 0.2
    },
    {
      "id": "t5",
      "description": "Typed client and apply options integration",
      "patterns": [
        "ApplyOptions|metav1",
        "typed client|client-go"
      ],
      "weight": 0.2
    }
  ],
  "file_references": [
    {
      "id": "r1",
