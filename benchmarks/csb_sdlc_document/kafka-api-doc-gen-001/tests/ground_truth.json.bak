    "behavioral_notes": {
      "weight": 0.3,
      "items": [
        {
          "weight": 0.1,
          "patterns": [
            "poll.*block.*timeout.*rebalance.*callback"
          ],
          "name": "poll() blocking behavior: may block beyond timeout during rebalance callbacks"
        },
        {
          "weight": 0.08,
          "patterns": [
            "commitSync.*block.*complete.*guarantee|commitAsync.*non-blocking"
          ],
          "name": "Sync vs async commit semantics: blocking guarantees vs non-blocking fire-and-forget"
        },
        {
          "weight": 0.08,
          "patterns": [
            "rebalance.*only.*during.*poll|poll.*drive.*rebalance"
          ],
          "name": "Rebalances only occur during active poll() calls"
        },
        {
          "weight": 0.1,
          "patterns": [
            "NOT.*thread.*safe|wakeup.*only.*thread.*safe"
          ],
          "name": "Thread safety: consumer NOT thread-safe except wakeup()"
        },
        {
          "weight": 0.08,
          "patterns": [
            "max\\.poll\\.interval\\.ms.*leave.*group|proactive.*leave"
          ],
          "name": "max.poll.interval.ms enforcement: consumer proactively leaves group if poll interval exceeded"
        },
        {
          "weight": 0.06,
          "patterns": [
            "subscribe.*assign.*mutually.*exclusive|cannot.*mix"
          ],
          "name": "Manual assignment vs dynamic subscription are mutually exclusive"
        },
        {
          "weight": 0.08,
          "patterns": [
            "committed.*offset.*next.*message.*read|add.*one|off-by-one"
          ],
          "name": "Position vs committed offset: committed should be next offset to read (off-by-one relationship)"
        },
        {
          "weight": 0.06,
          "patterns": [
            "read_committed.*LSO|transactional.*filter.*abort"
          ],
          "name": "Transactional semantics: read_committed isolation level, LSO boundary, filtered aborted messages"
        },
        {
          "weight": 0.08,
          "patterns": [
            "onPartitionsRevoked.*commit.*offset|onPartitionsAssigned.*seek|callback.*order"
          ],
          "name": "Rebalance listener callback ordering: revoked called before rebalance, assigned after"
        },
        {
          "weight": 0.06,
          "patterns": [
            "CommitFailedException.*group.*member.*not.*active|fenced.*consumer"
          ],
          "name": "CommitFailedException: thrown when consumer is no longer active group member (fenced)"
        },
        {
          "weight": 0.06,
          "patterns": [
            "WakeupException.*interrupt.*poll|wakeup.*from.*another.*thread"
          ],
          "name": "WakeupException: safe interruption mechanism via wakeup() from external thread"
        },
        {
          "weight": 0.05,
          "patterns": [
            "auto\\.commit\\.interval\\.ms|enable\\.auto\\.commit"
          ],
          "name": "Auto-commit configuration: enable.auto.commit and auto.commit.interval.ms"
        },
        {
          "weight": 0.05,
          "patterns": [
            "close.*must.*always.*close|resource.*leak"
          ],
          "name": "Resource management: must always close() consumer to avoid leaks"
        },
        {
          "weight": 0.06,
          "patterns": [
            "pause.*resume.*flow.*control|backpressure"
          ],
          "name": "Flow control: pause()/resume() for backpressure management"
        }
      ]
