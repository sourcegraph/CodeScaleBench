{
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.20,
    "causal_chain": 0.25,
    "negative_checks": 0.15
  },
  "required_findings": [
    {
      "id": "finding_001",
      "description": "Identify wish is affected by CVE-2024-45337",
      "patterns": ["affected.*yes", "wish.*affected", "vulnerable.*transitive", "assessment.*affected"],
      "weight": 0.20
    },
    {
      "id": "finding_002",
      "description": "Identify wish v0.5.0 depends on gliderlabs/ssh v0.3.4",
      "patterns": ["gliderlabs/ssh.*v0\\.3\\.[34]", "wish.*depends.*gliderlabs", "go\\.mod.*gliderlabs"],
      "weight": 0.15
    },
    {
      "id": "finding_003",
      "description": "Identify gliderlabs/ssh v0.3.4 depends on vulnerable golang.org/x/crypto (pre-v0.31.0)",
      "patterns": ["golang\\.org/x/crypto.*v0\\.0\\.0-20210616", "gliderlabs.*crypto.*vulnerable", "transitive.*golang\\.org/x/crypto"],
      "weight": 0.15
    },
    {
      "id": "finding_004",
      "description": "Identify wish uses PublicKeyAuth functionality",
      "patterns": ["WithPublicKeyAuth", "WithAuthorizedKeys", "WithTrustedUserCAKeys", "PublicKeyHandler"],
      "weight": 0.15
    },
    {
      "id": "finding_005",
      "description": "Identify gliderlabs/ssh uses ServerConfig.PublicKeyCallback",
      "patterns": ["ServerConfig\\.PublicKeyCallback", "config\\.PublicKeyCallback", "PublicKeyCallback.*gossh"],
      "weight": 0.15
    },
    {
      "id": "finding_006",
      "description": "Explain the vulnerability mechanism (callback called multiple times, key order unreliable)",
      "patterns": ["callback.*multiple.*keys", "order.*unreliable", "multiple.*keys.*callback", "authorization.*bypass"],
      "weight": 0.10
    },
    {
      "id": "finding_007",
      "description": "Recommend upgrading to golang.org/x/crypto v0.31.0+",
      "patterns": ["upgrade.*v0\\.31", "golang\\.org/x/crypto.*v0\\.31", "remediation.*upgrade", "fix.*v0\\.31"],
      "weight": 0.10
    }
  ],
  "file_references": [
    {
      "id": "file_001",
      "description": "wish/options.go - contains PublicKeyAuth wrappers",
      "patterns": ["wish/options\\.go", "options\\.go.*PublicKeyAuth"],
      "weight": 0.30
    },
    {
      "id": "file_002",
      "description": "wish/go.mod - shows gliderlabs/ssh dependency",
      "patterns": ["wish/go\\.mod", "go\\.mod.*gliderlabs"],
      "weight": 0.20
    },
    {
      "id": "file_003",
      "description": "ssh/server.go - gliderlabs/ssh PublicKeyCallback setup",
      "patterns": ["ssh/server\\.go", "gliderlabs.*server\\.go"],
      "weight": 0.30
    },
    {
      "id": "file_004",
      "description": "ssh/go.mod - shows golang.org/x/crypto dependency",
      "patterns": ["ssh/go\\.mod", "gliderlabs.*go\\.mod.*crypto"],
      "weight": 0.20
    }
  ],
  "causal_chain": [
    {
      "id": "chain_001",
      "description": "Application calls wish.WithPublicKeyAuth() or wish.WithAuthorizedKeys()",
      "patterns": ["WithPublicKeyAuth", "WithAuthorizedKeys", "WithTrustedUserCAKeys", "wish.*authentication"],
      "weight": 0.20
    },
    {
      "id": "chain_002",
      "description": "wish delegates to ssh.PublicKeyAuth(handler)",
      "patterns": ["ssh\\.PublicKeyAuth", "gliderlabs.*PublicKeyAuth", "return.*ssh\\.PublicKeyAuth"],
      "weight": 0.20
    },
    {
      "id": "chain_003",
      "description": "gliderlabs/ssh sets config.PublicKeyCallback in server.go",
      "patterns": ["config\\.PublicKeyCallback.*=", "PublicKeyCallback.*func.*ConnMetadata", "server\\.go.*PublicKeyCallback"],
      "weight": 0.20
    },
    {
      "id": "chain_004",
      "description": "gliderlabs/ssh imports gossh from golang.org/x/crypto/ssh",
      "patterns": ["gossh.*golang\\.org/x/crypto/ssh", "import.*golang\\.org/x/crypto/ssh", "x/crypto/ssh.*gossh"],
      "weight": 0.20
    },
    {
      "id": "chain_005",
      "description": "golang.org/x/crypto/ssh invokes PublicKeyCallback during SSH authentication",
      "patterns": ["PublicKeyCallback.*invoked", "SSH.*authentication.*callback", "crypto/ssh.*PublicKeyCallback"],
      "weight": 0.20
    }
  ],
  "negative_checks": [
    {
      "id": "negative_001",
      "description": "Must NOT claim the project is NOT affected",
      "patterns": ["not.*affected", "unaffected", "no.*vulnerability", "safe.*from.*cve"],
      "must_be_absent": true,
      "weight": 0.30
    },
    {
      "id": "negative_002",
      "description": "Must NOT claim this is only a password authentication issue",
      "patterns": ["only.*password", "password.*authentication.*only", "not.*public.*key"],
      "must_be_absent": true,
      "weight": 0.25
    },
    {
      "id": "negative_003",
      "description": "Must NOT claim the vulnerability is in gliderlabs/ssh itself (it's in golang.org/x/crypto)",
      "patterns": ["gliderlabs.*vulnerable.*code", "gliderlabs.*contains.*vulnerability", "bug.*in.*gliderlabs"],
      "must_be_absent": true,
      "weight": 0.25
    },
    {
      "id": "negative_004",
      "description": "Must NOT suggest fixing wish code (the fix is to upgrade the dependency)",
      "patterns": ["modify.*wish.*code", "patch.*wish", "fix.*in.*wish"],
      "must_be_absent": true,
      "weight": 0.20
    }
  ]
}
