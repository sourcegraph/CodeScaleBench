{
  "task_id": "sec-reach-002",
  "description": "Envoy admin interface reachability analysis - UNREACHABLE endpoint",
  "weights": {
    "required_findings": 0.25,
    "file_references": 0.15,
    "causal_chain": 0.30,
    "negative_checks": 0.30
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identified the dangerous admin function (handlerDrainListeners)",
      "patterns": ["handlerDrainListeners", "drain_listeners"],
      "weight": 0.18
    },
    {
      "id": "f2",
      "description": "Admin interface binds to localhost only",
      "patterns": ["127\\.0\\.0\\.1", "localhost", "admin.*address"],
      "weight": 0.20
    },
    {
      "id": "f3",
      "description": "Admin endpoint path identified",
      "patterns": ["/drain_listeners", "admin.*endpoint"],
      "weight": 0.10
    },
    {
      "id": "f4",
      "description": "Admin interface is separate from data plane listeners",
      "patterns": ["admin.*interface", "separate.*listener", "AdminImpl", "admin_address"],
      "weight": 0.18
    },
    {
      "id": "f5",
      "description": "Correctly assessed as UNREACHABLE/NOT EXPLOITABLE from external traffic",
      "patterns": ["unreachable", "not.*reachable", "admin.*only", "localhost.*only", "not.*exploitable", "mitigated"],
      "weight": 0.24
    },
    {
      "id": "f6",
      "description": "Explained network isolation between admin and data plane",
      "patterns": ["data.*plane.*separate", "different.*port", "different.*listener", "network.*isolation"],
      "weight": 0.10
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "patterns": ["source/server/admin/admin\\.(cc|h)", "admin\\.cc"],
      "description": "Admin endpoint handler implementation",
      "weight": 0.40
    },
    {
      "id": "r2",
      "patterns": ["source/server/server\\.(cc|h)", "server\\.cc"],
      "description": "Server initialization and admin interface binding",
      "weight": 0.35
    },
    {
      "id": "r3",
      "patterns": ["envoy/server/admin\\.h"],
      "description": "Admin interface API definition",
      "weight": 0.25
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "step": 1,
      "patterns": ["HTTP.*request", "external.*traffic", "internet.*facing", "data.*plane"],
      "description": "External HTTP request arrives at data plane listener",
      "weight": 0.15
    },
    {
      "id": "c2",
      "step": 2,
      "patterns": ["listener.*port.*[0-9]+", "data.*plane.*listener", "ConnectionManagerImpl"],
      "description": "Data plane listener processes request on public port (e.g., 8080)",
      "weight": 0.20
    },
    {
      "id": "c3",
      "step": 3,
      "patterns": ["NOT.*routed.*admin", "separate.*interface", "different.*listener", "admin.*port.*[0-9]+"],
      "description": "Request is NOT routed to admin interface (different listener/port)",
      "weight": 0.25
    },
    {
      "id": "c4",
      "step": 4,
      "patterns": ["127\\.0\\.0\\.1.*only", "localhost.*only", "admin.*binding", "cannot.*reach"],
      "description": "Admin interface listens on localhost only, unreachable from external network",
      "weight": 0.20
    },
    {
      "id": "c5",
      "step": 5,
      "patterns": ["unreachable", "blocked", "isolated", "not.*accessible"],
      "description": "CONCLUSION: handlerDrainListeners() is unreachable from external traffic",
      "weight": 0.20
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Must NOT claim the admin endpoint is exploitable from external traffic",
      "patterns": ["exploitable.*external", "attacker.*can.*reach", "vulnerable.*public", "reachable.*internet"],
      "must_be_absent": true,
      "weight": 0.30
    },
    {
      "id": "n2",
      "description": "Must NOT claim admin interface binds to public IP by default",
      "patterns": ["admin.*0\\.0\\.0\\.0", "admin.*public", "admin.*exposed"],
      "must_be_absent": true,
      "weight": 0.25
    },
    {
      "id": "n3",
      "description": "Must NOT conflate admin interface with data plane listeners",
      "patterns": ["same.*listener", "same.*port", "merged.*interface"],
      "must_be_absent": true,
      "weight": 0.25
    },
    {
      "id": "n4",
      "description": "Must NOT suggest network isolation can be bypassed without insider access",
      "patterns": ["bypass.*network", "circumvent.*localhost", "tunnel.*admin"],
      "must_be_absent": true,
      "weight": 0.20
    }
  ]
}
