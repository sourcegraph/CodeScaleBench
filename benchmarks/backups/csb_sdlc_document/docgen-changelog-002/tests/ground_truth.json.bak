{
  "task_id": "docgen-changelog-002",
  "description": "Flipt Release Notes Generation",
  "weights": {
    "breaking_changes": 0.4,
    "deprecations": 0.3,
    "new_features": 0.3
  },
  "breaking_changes": [
    {
      "id": "b1",
      "description": "Breaking changes section present",
      "patterns": [
        "[Bb]reaking [Cc]hange|BREAKING"
      ],
      "weight": 0.5
    },
    {
      "id": "b2",
      "description": "Migration path provided",
      "patterns": [
        "migrat|upgrade|workaround|instead|replace"
      ],
      "weight": 0.5
    }
  ],
  "deprecations": [
    {
      "id": "d1",
      "description": "Deprecations section present",
      "patterns": [
        "[Dd]eprecate|DEPRECATED"
      ],
      "weight": 0.5
    },
    {
      "id": "d2",
      "description": "Replacement specified",
      "patterns": [
        "use.*instead|replaced by|alternative"
      ],
      "weight": 0.5
    }
  ],
  "new_features": [
    {
      "id": "f1",
      "description": "New features section present",
      "patterns": [
        "[Nn]ew [Ff]eature|## Feature|### Feature|## Enhancement"
      ],
      "weight": 0.4
    },
    {
      "id": "f2",
      "description": "Flipt-specific API references",
      "patterns": [
        "flag|segment|rule|variant|evaluation|namespace|flipt"
      ],
      "weight": 0.3
    },
    {
      "id": "f3",
      "description": "Upgrade guide present",
      "patterns": [
        "[Uu]pgrade [Gg]uide|[Mm]igration [Gg]uide"
      ],
      "weight": 0.3
    }
  ]
}