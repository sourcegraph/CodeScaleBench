{
  "task_id": "docgen-runbook-001",
  "description": "Prometheus TSDB Compaction Runbook",
  "weights": {
    "monitoring": 0.3,
    "failure_modes": 0.3,
    "recovery": 0.2,
    "code_references": 0.2
  },
  "monitoring": [
    {
      "id": "m1",
      "description": "Prometheus metrics referenced",
      "patterns": [
        "prometheus_tsdb|tsdb_compact|compaction_total|compaction_duration"
      ],
      "weight": 0.6
    },
    {
      "id": "m2",
      "description": "Alert or threshold described",
      "patterns": [
        "alert|threshold|SLO|SLA|healthy|stuck"
      ],
      "weight": 0.4
    }
  ],
  "failure_modes": [
    {
      "id": "f1",
      "description": "Disk space failure mode",
      "patterns": [
        "disk|space|storage|ENOSPC|no space"
      ],
      "weight": 0.25
    },
    {
      "id": "f2",
      "description": "Compaction stuck/not progressing",
      "patterns": [
        "stuck|not progress|hung|stall|slow"
      ],
      "weight": 0.25
    },
    {
      "id": "f3",
      "description": "Block corruption",
      "patterns": [
        "corrupt|invalid|checksum|damage"
      ],
      "weight": 0.25
    },
    {
      "id": "f4",
      "description": "OOM or memory failure",
      "patterns": [
        "OOM|out.of.memory|memory|RSS"
      ],
      "weight": 0.25
    }
  ],
  "recovery": [
    {
      "id": "r1",
      "description": "Numbered recovery steps",
      "patterns": [
        "^\\d+\\.|^1\\.|Step \\d"
      ],
      "weight": 0.5
    },
    {
      "id": "r2",
      "description": "promtool or CLI commands mentioned",
      "patterns": [
        "promtool|prometheus.*--storage|systemctl|restart"
      ],
      "weight": 0.5
    }
  ],
  "code_references": [
    {
      "id": "cr1",
      "description": "tsdb/compact.go or tsdb/ referenced",
      "patterns": [
        "tsdb/compact|tsdb/db\\.go|tsdb/head"
      ],
      "weight": 0.6
    },
    {
      "id": "cr2",
      "description": "Specific function names mentioned",
      "patterns": [
        "func.*Compact|planCompaction|leveledCompactor"
      ],
      "weight": 0.4
    }
  ]
}