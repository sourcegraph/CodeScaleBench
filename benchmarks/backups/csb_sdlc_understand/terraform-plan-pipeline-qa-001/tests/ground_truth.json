{
  "task_id": "nlqa-arch-003",
  "description": "Terraform plan/apply pipeline: graph building, provider resolution, and diff computation",
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.30,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies PlanGraphBuilder as the graph construction entry point for plan operations",
      "patterns": ["PlanGraphBuilder", "graph_builder_plan"],
      "weight": 0.15
    },
    {
      "id": "f2",
      "description": "Explains ReferenceTransformer adds dependency edges by analyzing GraphNodeReferencer/GraphNodeReferenceable interfaces",
      "patterns": ["ReferenceTransformer|reference_transform", "GraphNodeReferencer|GraphNodeReferenceable|ReferenceMap"],
      "weight": 0.15
    },
    {
      "id": "f3",
      "description": "Identifies terraform.Context.Plan() or planWalk() as the core plan execution entry point",
      "patterns": ["Context\\.Plan|context_plan|planWalk|plan_walk"],
      "weight": 0.10
    },
    {
      "id": "f4",
      "description": "Explains NodePlannableResourceInstance.Execute() delegates to managedResourceExecute for managed resources",
      "patterns": ["NodePlannableResourceInstance|node_resource_plan_instance", "managedResourceExecute|managed.*resource.*execute"],
      "weight": 0.15
    },
    {
      "id": "f5",
      "description": "Identifies the provider Interface and PlanResourceChange as the RPC that computes the diff",
      "patterns": ["PlanResourceChange|Plan.*Resource.*Change", "providers?\\.Interface|provider.*interface"],
      "weight": 0.15
    },
    {
      "id": "f6",
      "description": "Explains ConfigTransformer adds resource and provider nodes from configuration to the graph",
      "patterns": ["ConfigTransformer|config_transform"],
      "weight": 0.10
    },
    {
      "id": "f7",
      "description": "Describes the refresh phase reading current remote state before planning via ReadResource",
      "patterns": ["[Rr]efresh|ReadResource|readResource|read.*resource"],
      "weight": 0.10
    },
    {
      "id": "f8",
      "description": "Explains EvalContext.InitProvider/ConfigureProvider for provider lifecycle during graph walk",
      "patterns": ["InitProvider|init.*provider|ConfigureProvider|configure.*provider|EvalContext"],
      "weight": 0.10
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References graph_builder_plan.go",
      "patterns": ["internal/terraform/graph_builder_plan\\.go", "graph_builder_plan\\.go"],
      "weight": 0.20
    },
    {
      "id": "r2",
      "description": "References context_plan.go or context.go",
      "patterns": ["internal/terraform/context_plan\\.go|internal/terraform/context\\.go", "context_plan\\.go|context\\.go"],
      "weight": 0.20
    },
    {
      "id": "r3",
      "description": "References node_resource_plan_instance.go or node_resource_plan.go",
      "patterns": ["internal/terraform/node_resource_plan.*\\.go", "node_resource_plan_instance\\.go|node_resource_plan\\.go"],
      "weight": 0.20
    },
    {
      "id": "r4",
      "description": "References providers/provider.go or the provider Interface",
      "patterns": ["internal/providers/provider\\.go|providers/provider\\.go"],
      "weight": 0.15
    },
    {
      "id": "r5",
      "description": "References transform_reference.go or command/plan.go",
      "patterns": ["transform_reference\\.go|internal/command/plan\\.go|command/plan\\.go"],
      "weight": 0.15
    },
    {
      "id": "r6",
      "description": "References eval_context.go or graph.go",
      "patterns": ["eval_context\\.go|internal/terraform/graph\\.go|graph_walk"],
      "weight": 0.10
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Plan pipeline: PlanCommand.Run → backend operation → Context.Plan() → planWalk() → PlanGraphBuilder.Build() → graph transformers → Graph.Walk() executes nodes",
      "patterns": [
        "PlanCommand|command.*plan|plan.*command",
        "backend|operation|RunOperation",
        "Context\\.Plan|context.*plan|Plan\\(",
        "planWalk|plan.*walk|planGraph",
        "PlanGraphBuilder|graph_builder_plan",
        "Graph.*Walk|walk.*graph|Execute"
      ],
      "ordered": true,
      "weight": 0.60
    },
    {
      "id": "c2",
      "description": "Per-resource planning: NodePlannableResourceInstance.Execute → getProvider → refresh (ReadResource) → plan (PlanResourceChange) → writeChange",
      "patterns": [
        "NodePlannableResourceInstance|node.*plan.*instance",
        "getProvider|get.*provider|InitProvider",
        "refresh|ReadResource|read.*resource",
        "plan|PlanResourceChange|plan.*resource.*change",
        "writeChange|write.*change|record.*change"
      ],
      "ordered": true,
      "weight": 0.40
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT claim Terraform builds the graph at apply time (the graph is built during plan; apply reuses the plan)",
      "patterns": ["apply.*build.*graph.*from.*scratch|apply.*construct.*new.*graph|graph.*built.*during.*apply.*not.*plan"],
      "must_be_absent": true,
      "weight": 0.50
    },
    {
      "id": "n2",
      "description": "Does NOT confuse the provider plugin process with the Terraform CLI process (providers are separate gRPC plugin processes)",
      "patterns": ["provider.*runs.*inside.*terraform.*process|provider.*same.*process.*as.*terraform|provider.*not.*separate|provider.*embedded.*in.*cli"],
      "must_be_absent": true,
      "weight": 0.50
    }
  ]
}
