{
  "task_id": "nlqa-arch-002",
  "description": "Istio Pilot xDS serving architecture: Kubernetes resources to Envoy configuration",
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.30,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies DiscoveryServer as the central xDS control plane server implementing SotW and Delta protocols",
      "patterns": ["DiscoveryServer", "discovery\\.go"],
      "weight": 0.15
    },
    {
      "id": "f2",
      "description": "Explains PushContext as the per-push configuration snapshot rebuilt from all config sources",
      "patterns": ["PushContext|push_context", "InitContext|initServiceRegistry|initVirtualServices|initDestinationRules"],
      "weight": 0.15
    },
    {
      "id": "f3",
      "description": "Identifies ConfigStoreController interface and CRD client watching Kubernetes resources via informers",
      "patterns": ["ConfigStoreController|ConfigStore", "crdclient|CRD.*client|RegisterEventHandler"],
      "weight": 0.12
    },
    {
      "id": "f4",
      "description": "Explains the debounce mechanism for coalescing rapid config changes before pushing",
      "patterns": ["debounce|pushChannel|DebounceAfter|debounceMax|ConfigUpdate"],
      "weight": 0.10
    },
    {
      "id": "f5",
      "description": "Identifies pluggable xDS generators (CDS, EDS, LDS, RDS) registered in Generators map",
      "patterns": ["CdsGenerator|EdsGenerator|LdsGenerator|RdsGenerator", "Generators.*map|XdsResourceGenerator|XdsDeltaResourceGenerator"],
      "weight": 0.12
    },
    {
      "id": "f6",
      "description": "Explains ConfigGenerator interface with BuildClusters, BuildListeners, BuildHTTPRoutes methods",
      "patterns": ["ConfigGenerator|ConfigGeneratorImpl", "BuildClusters|BuildListeners|BuildHTTPRoutes"],
      "weight": 0.12
    },
    {
      "id": "f7",
      "description": "Describes internal model types: model.Service (Hostname, Ports, Resolution) and model.IstioEndpoint",
      "patterns": ["model\\.Service|model\\.IstioEndpoint|IstioEndpoint", "Hostname|Resolution|ClusterVIPs"],
      "weight": 0.12
    },
    {
      "id": "f8",
      "description": "Explains aggregate service registry merging Kubernetes and ServiceEntry registries",
      "patterns": ["aggregate.*controller|aggregate.*registry|ServiceDiscovery", "convertServices|serviceentry.*controller"],
      "weight": 0.12
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References pilot/pkg/xds/discovery.go (DiscoveryServer)",
      "patterns": ["pilot/pkg/xds/discovery\\.go", "xds/discovery\\.go"],
      "weight": 0.20
    },
    {
      "id": "r2",
      "description": "References pilot/pkg/model/push_context.go (PushContext)",
      "patterns": ["pilot/pkg/model/push_context\\.go", "model/push_context\\.go"],
      "weight": 0.20
    },
    {
      "id": "r3",
      "description": "References xDS generator files (cds.go, eds.go, lds.go, rds.go)",
      "patterns": ["pilot/pkg/xds/cds\\.go|pilot/pkg/xds/eds\\.go|pilot/pkg/xds/lds\\.go|pilot/pkg/xds/rds\\.go", "xds/cds\\.go|xds/eds\\.go|xds/lds\\.go|xds/rds\\.go"],
      "weight": 0.20
    },
    {
      "id": "r4",
      "description": "References pilot/pkg/networking/core/ (ConfigGenerator, cluster_builder, route)",
      "patterns": ["pilot/pkg/networking/core|networking/core/configgen|cluster_builder\\.go|networking/core/route"],
      "weight": 0.15
    },
    {
      "id": "r5",
      "description": "References pilot/pkg/model/service.go or pilot/pkg/model/config.go",
      "patterns": ["pilot/pkg/model/service\\.go|pilot/pkg/model/config\\.go|model/service\\.go|model/config\\.go"],
      "weight": 0.15
    },
    {
      "id": "r6",
      "description": "References pilot/pkg/config/kube/crdclient/ or pilot/pkg/serviceregistry/",
      "patterns": ["pilot/pkg/config/kube/crdclient|crdclient/client\\.go|pilot/pkg/serviceregistry|serviceregistry/aggregate|serviceregistry/kube"],
      "weight": 0.10
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Config ingestion to xDS delivery: K8s resource change → informer/CRD client events → ConfigUpdate/pushChannel → debounce → PushContext rebuild (InitContext) → generator dispatch (pushXds/findGenerator) → xDS response to Envoy via ADS",
      "patterns": [
        "informer|CRD.*client|watch|ConfigStoreController",
        "ConfigUpdate|pushChannel|push.*request",
        "debounce|coalesce|quiet.*period",
        "PushContext|InitContext|init.*Service|init.*Virtual|init.*Destination",
        "pushXds|findGenerator|Generate|CdsGenerator|EdsGenerator|LdsGenerator|RdsGenerator",
        "ADS|gRPC|StreamAggregatedResources|DiscoveryResponse"
      ],
      "ordered": true,
      "weight": 0.60
    },
    {
      "id": "c2",
      "description": "Resource translation: VirtualService/DestinationRule → PushContext indexes → ConfigGenerator.Build* methods → Envoy protobuf resources (Cluster, RouteConfiguration, Listener)",
      "patterns": [
        "VirtualService|DestinationRule|ServiceEntry",
        "PushContext|virtualServiceIndex|destinationRuleIndex|ServiceIndex",
        "BuildClusters|BuildHTTPRoutes|BuildListeners|ConfigGenerator",
        "Cluster|RouteConfiguration|Listener|ClusterLoadAssignment|protobuf|proto"
      ],
      "ordered": true,
      "weight": 0.40
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT claim Mixer is involved in the xDS translation pipeline (Mixer was removed in Istio 1.8)",
      "patterns": ["[Mm]ixer.*xDS|[Mm]ixer.*translat|[Mm]ixer.*config.*distribut|istio-policy.*xDS|istio-telemetry.*xDS"],
      "must_be_absent": true,
      "weight": 0.50
    },
    {
      "id": "n2",
      "description": "Does NOT claim Galley is part of the current config pipeline (Galley was removed in Istio 1.9)",
      "patterns": ["[Gg]alley.*config|[Gg]alley.*validat.*distribut|[Gg]alley.*pipeline|[Gg]alley.*CRD.*watch"],
      "must_be_absent": true,
      "weight": 0.50
    }
  ]
}
