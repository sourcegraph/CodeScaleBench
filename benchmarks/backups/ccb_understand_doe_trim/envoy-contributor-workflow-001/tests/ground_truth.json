{
  "task_id": "onboard-workflow-001",
  "description": "Envoy contributor workflow discovery — learning build system, test framework, CI pipeline, and code review process",
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.30,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies Bazel as the build system",
      "patterns": ["[Bb]azel", "bazelisk"],
      "weight": 0.12
    },
    {
      "id": "f2",
      "description": "Provides bazel build command for building Envoy",
      "patterns": ["bazel build.*envoy|bazel build.*//source"],
      "weight": 0.10
    },
    {
      "id": "f3",
      "description": "Provides bazel test command for running tests",
      "patterns": ["bazel test", "bazel.*test.*//test"],
      "weight": 0.10
    },
    {
      "id": "f4",
      "description": "Mentions CI uses GitHub Actions or Azure Pipelines",
      "patterns": ["GitHub Actions|Azure Pipelines|AZP|\\.github/workflows|\\.azure-pipelines"],
      "weight": 0.10
    },
    {
      "id": "f5",
      "description": "Mentions CONTRIBUTING.md or contribution guide location",
      "patterns": ["CONTRIBUTING\\.md", "contribution.*guide"],
      "weight": 0.08
    },
    {
      "id": "f6",
      "description": "Mentions DCO sign-off requirement",
      "patterns": ["DCO|Developer Certificate of Origin|Signed-off-by"],
      "weight": 0.08
    },
    {
      "id": "f7",
      "description": "Identifies test frameworks (googletest, gtest)",
      "patterns": ["googletest|gtest|TEST\\(|TEST_F\\(|test_common"],
      "weight": 0.08
    },
    {
      "id": "f8",
      "description": "Mentions build prerequisites (Bazel, clang, Docker, or compilers)",
      "patterns": ["clang|gcc|compiler|Docker.*build|bazelisk|build.*prerequisites|dependencies.*install"],
      "weight": 0.08
    },
    {
      "id": "f9",
      "description": "Mentions code formatting or style checks (clang-format, buildifier)",
      "patterns": ["clang-format|buildifier|format.*check|style.*check|ci/run_clang_format"],
      "weight": 0.08
    },
    {
      "id": "f10",
      "description": "Mentions integration tests or end-to-end tests",
      "patterns": ["integration.*test|e2e.*test|integration_admin_test|envoy_binary_test"],
      "weight": 0.08
    },
    {
      "id": "f11",
      "description": "Identifies test_common/ or test helpers location",
      "patterns": ["test/common|test_common|test/integration|test/extensions"],
      "weight": 0.05
    },
    {
      "id": "f12",
      "description": "Mentions PR review process or reviewers assignment",
      "patterns": ["code.*review|CODEOWNERS|PR.*review|pull.*request.*review|maintainer.*review"],
      "weight": 0.05
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References CONTRIBUTING.md",
      "patterns": ["CONTRIBUTING\\.md"],
      "weight": 0.15
    },
    {
      "id": "r2",
      "description": "References .bazelrc or bazel configuration",
      "patterns": ["\\.bazelrc", "bazel/.*\\.bzl"],
      "weight": 0.10
    },
    {
      "id": "r3",
      "description": "References .github/workflows/ for GitHub Actions",
      "patterns": ["\\.github/workflows", "workflows/.*\\.ya?ml"],
      "weight": 0.12
    },
    {
      "id": "r4",
      "description": "References .azure-pipelines/ or ci/ directory",
      "patterns": ["\\.azure-pipelines", "ci/.*\\.sh|ci/.*\\.yml"],
      "weight": 0.10
    },
    {
      "id": "r5",
      "description": "References test directory structure (test/common, test/integration, test/extensions)",
      "patterns": ["test/common", "test/integration", "test/extensions"],
      "weight": 0.12
    },
    {
      "id": "r6",
      "description": "References CODEOWNERS file",
      "patterns": ["CODEOWNERS"],
      "weight": 0.08
    },
    {
      "id": "r7",
      "description": "References BUILD or BUILD.bazel files",
      "patterns": ["BUILD\\.bazel|BUILD file"],
      "weight": 0.10
    },
    {
      "id": "r8",
      "description": "References ci/run_clang_format.sh or format checking scripts",
      "patterns": ["ci/run_clang_format|ci/format|tools/code_format"],
      "weight": 0.08
    },
    {
      "id": "r9",
      "description": "References source/common, source/server, or source/extensions",
      "patterns": ["source/common", "source/server", "source/extensions"],
      "weight": 0.08
    },
    {
      "id": "r10",
      "description": "References DEVELOPER.md, STYLE.md, or developer docs",
      "patterns": ["DEVELOPER\\.md", "STYLE\\.md", "docs/root/intro/arch_overview"],
      "weight": 0.07
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Build workflow: install Bazel → bazel build → bazel test → format check",
      "patterns": [
        "bazel|bazelisk|install",
        "bazel build",
        "bazel test",
        "format|clang-format|buildifier"
      ],
      "ordered": true,
      "weight": 0.50
    },
    {
      "id": "c2",
      "description": "PR workflow: clone → branch → code → test → format → DCO → push → PR",
      "patterns": [
        "clone|git clone",
        "branch|checkout.*-b|feature.*branch",
        "code|implement|fix|change",
        "test|bazel test",
        "DCO|Signed-off-by|sign.*off",
        "push|git push",
        "pull.*request|PR|create.*pr"
      ],
      "ordered": false,
      "weight": 0.50
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT claim Envoy uses Make as primary build system (it uses Bazel)",
      "patterns": ["[Mm]ake.*primary.*build|primary.*build.*[Mm]akefile|make.*instead.*bazel"],
      "must_be_absent": true,
      "weight": 0.50
    },
    {
      "id": "n2",
      "description": "Does NOT claim Envoy uses CMake as primary build system (it uses Bazel)",
      "patterns": ["[Cc][Mm]ake.*primary.*build|primary.*build.*[Cc][Mm]ake|cmake.*instead.*bazel"],
      "must_be_absent": true,
      "weight": 0.50
    }
  ]
}
