{
  "task_id": "docgen-runbook-002",
  "description": "Envoy Connection Pool Troubleshooting Runbook",
  "weights": {
    "failure_scenarios": 0.3,
    "diagnostic_commands": 0.3,
    "config_fixes": 0.2,
    "code_references": 0.2
  },
  "failure_scenarios": [
    {
      "id": "fs1",
      "description": "Connection pool exhaustion scenario",
      "patterns": [
        "pool exhaust|pending.*overflow|max_pending|circuit.break"
      ],
      "weight": 0.25
    },
    {
      "id": "fs2",
      "description": "Connection reset/upstream close scenario",
      "patterns": [
        "reset|premature|close|RST|GOAWAY|upstream.*close"
      ],
      "weight": 0.25
    },
    {
      "id": "fs3",
      "description": "Circuit breaker scenario",
      "patterns": [
        "circuit.break|CircuitBreak|threshold|trip"
      ],
      "weight": 0.25
    },
    {
      "id": "fs4",
      "description": "HTTP/2 specific failure",
      "patterns": [
        "HTTP/2|http2|h2|GOAWAY|stream"
      ],
      "weight": 0.25
    }
  ],
  "diagnostic_commands": [
    {
      "id": "dc1",
      "description": "Admin API endpoints mentioned",
      "patterns": [
        "/clusters|/stats|admin.*api|:9901"
      ],
      "weight": 0.4
    },
    {
      "id": "dc2",
      "description": "Specific metrics referenced",
      "patterns": [
        "upstream_cx_|upstream_rq_|circuit_breaker"
      ],
      "weight": 0.4
    },
    {
      "id": "dc3",
      "description": "curl or diagnostic commands shown",
      "patterns": [
        "curl|wget|admin"
      ],
      "weight": 0.2
    }
  ],
  "config_fixes": [
    {
      "id": "cf1",
      "description": "max_connections or max_pending_requests mentioned",
      "patterns": [
        "max_connections|max_pending_requests|max_requests"
      ],
      "weight": 0.5
    },
    {
      "id": "cf2",
      "description": "Timeout or buffer configuration mentioned",
      "patterns": [
        "connect_timeout|per_connection_buffer|timeout"
      ],
      "weight": 0.5
    }
  ],
  "code_references": [
    {
      "id": "cr1",
      "description": "Source file paths referenced",
      "patterns": [
        "conn_pool_base|conn_pool\\.cc|cluster_manager"
      ],
      "weight": 0.6
    },
    {
      "id": "cr2",
      "description": "Specific function or class mentioned",
      "patterns": [
        "ConnPoolBase|TcpConnPool|HttpConnPool|pendingRequests"
      ],
      "weight": 0.4
    }
  ]
}