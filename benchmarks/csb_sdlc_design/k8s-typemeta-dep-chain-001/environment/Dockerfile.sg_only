# k8s-typemeta-dep-chain-001 — sg_only_env variant (v2: clone-at-verify)
# Empty workspace — agent uses Sourcegraph MCP for code access.
# Verifier clones mirror(s) at verification time via clone manifest.

FROM golang:1.23-alpine

ENV DEBIAN_FRONTEND=noninteractive
ENV SOURCEGRAPH_REPOS="sg-evals/api--f32ed1d6,sg-evals/apimachinery--b2e9f88f,sg-evals/kubernetes--31bf3ed4"

RUN apk add --no-cache \
    git \
    python3 \
    curl \
    bash

WORKDIR /workspace

# Empty git repo so agent can commit work
RUN git init && \
    git config user.email "agent@example.com" && \
    git config user.name "Agent"

RUN mkdir -p /logs/agent /logs/verifier

# Clone manifest for verifier (clone-at-verify strategy)
RUN echo '{"workdir":"/workspace","repos":[{"mirror":"sg-evals/kubernetes--31bf3ed4","target_dir":"kubernetes"},{"mirror":"sg-evals/api--f32ed1d6","target_dir":"api"},{"mirror":"sg-evals/apimachinery--b2e9f88f","target_dir":"apimachinery"}]}' > /tmp/.sg_only_clone_manifest.json

# Mark sg_only mode
RUN touch /tmp/.sg_only_mode

# Pre-create claude user and set ownership at build time.
RUN (adduser --disabled-password --gecos '' claude 2>/dev/null || true) && \
    for d in /workspace /app /testbed /logs; do [ -d "$d" ] && chown -R claude:claude "$d"; done || true

ENTRYPOINT []
