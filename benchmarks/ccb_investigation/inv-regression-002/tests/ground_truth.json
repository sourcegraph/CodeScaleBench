{
  "task_id": "inv-regression-002",
  "description": "Regression hunt: Prometheus alert rule state loss on config reload due to inconsistent map keys",
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.30,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies the regressing commit SHA (a48a01836 or full SHA)",
      "patterns": ["a48a01836", "a48a01836810055029145881b7777fddd00c233a"],
      "weight": 0.12
    },
    {
      "id": "f2",
      "description": "Identifies rules/manager.go as the changed file",
      "patterns": ["rules/manager\\.go", "manager\\.go"],
      "weight": 0.10
    },
    {
      "id": "f3",
      "description": "Mentions the ApplyConfig method or config reload mechanism",
      "patterns": ["ApplyConfig|apply.*config|config.*reload|reload.*config"],
      "weight": 0.08
    },
    {
      "id": "f4",
      "description": "Identifies map key inconsistency as the root cause",
      "patterns": ["map.*key|key.*format|key.*inconsist|key.*mismatch|wrong.*key|incorrect.*key"],
      "weight": 0.10
    },
    {
      "id": "f5",
      "description": "Explains that loadGroups uses 'name;file' format",
      "patterns": ["name.*file|file.*name|semicolon|;.*fn|name.*\\+.*file|rg\\.Name.*fn"],
      "weight": 0.08
    },
    {
      "id": "f6",
      "description": "Explains that ApplyConfig used only 'name' (before fix)",
      "patterns": ["newg\\.name|only.*name|just.*name|name.*alone"],
      "weight": 0.08
    },
    {
      "id": "f7",
      "description": "Mentions the fix commit (e86d82ad2 or PR #3382)",
      "patterns": ["e86d82ad2|e86d82ad|3382|PR.*3382|#3382"],
      "weight": 0.08
    },
    {
      "id": "f8",
      "description": "Identifies that state copying failed due to key mismatch",
      "patterns": ["copy.*state|state.*copy|state.*lost|state.*loss|CopyState|transfer.*state"],
      "weight": 0.08
    },
    {
      "id": "f9",
      "description": "Mentions alert rules or 'for' clause state being lost",
      "patterns": ["alert.*state|for.*clause|for.*duration|pending.*state|active.*alert"],
      "weight": 0.06
    },
    {
      "id": "f10",
      "description": "Identifies the groupKey helper function in the fix",
      "patterns": ["groupKey|group.*key.*func|key.*helper"],
      "weight": 0.08
    },
    {
      "id": "f11",
      "description": "Mentions June 2017 or mid-2017 timeframe for regression",
      "patterns": ["June.*2017|2017.*06|mid.*2017|summer.*2017"],
      "weight": 0.06
    },
    {
      "id": "f12",
      "description": "Explains that groups can have same name across different files",
      "patterns": ["unique.*file|same.*name.*file|different.*file|across.*file|groups.*name"],
      "weight": 0.08
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "Identifies rules/manager.go as the primary file",
      "patterns": ["rules/manager\\.go", "manager\\.go"],
      "weight": 0.30
    },
    {
      "id": "r2",
      "description": "References the ApplyConfig function",
      "patterns": ["ApplyConfig", "apply.*config"],
      "weight": 0.20
    },
    {
      "id": "r3",
      "description": "References the loadGroups function",
      "patterns": ["loadGroups", "load.*groups"],
      "weight": 0.20
    },
    {
      "id": "r4",
      "description": "References PR #3382 or the fix commit e86d82ad2",
      "patterns": ["pull/3382", "3382", "e86d82ad2", "#3382"],
      "weight": 0.15
    },
    {
      "id": "r5",
      "description": "References commit a48a01836 (the regressing commit)",
      "patterns": ["a48a01836", "a48a0183"],
      "weight": 0.10
    },
    {
      "id": "r6",
      "description": "References the Group struct or group management",
      "patterns": ["Group\\{|type.*Group|struct.*Group|m\\.groups"],
      "weight": 0.05
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Hop 1: Commit a48a01836 (June 2017) modified loadGroups to use 'rg.Name+\";\" +fn' as the map key instead of just 'rg.Name', to allow groups with the same name in different files",
      "patterns": ["a48a01836|a48a0183", "loadGroups|load.*groups", "rg\\.Name.*fn|name.*file.*key|semicolon.*separator"],
      "ordered": true,
      "weight": 0.25
    },
    {
      "id": "c2",
      "description": "Hop 2: However, the commit failed to update ApplyConfig to use the same key format - it still used 'm.groups[newg.name]' (only the name, without the filename)",
      "patterns": ["ApplyConfig|apply.*config", "newg\\.name|only.*name|didn't.*update|failed.*update|inconsist"],
      "ordered": true,
      "weight": 0.25
    },
    {
      "id": "c3",
      "description": "Hop 3: When config reload occurs, ApplyConfig looks up the old group using the wrong key format, so the lookup fails (returns nil/not found)",
      "patterns": ["lookup.*fail|key.*not.*found|mismatch|can't.*find|oldg.*ok.*false"],
      "ordered": true,
      "weight": 0.25
    },
    {
      "id": "c4",
      "description": "Hop 4: Because the old group isn't found, the 'copy state from old to new' logic is skipped, causing alert 'for' state and active alerts to be lost on every config reload",
      "patterns": ["copy.*skip|state.*lost|state.*not.*copied|alert.*reset|for.*duration.*lost"],
      "ordered": true,
      "weight": 0.25
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT blame the notification system or alertmanager as the root cause",
      "patterns": ["notif.*root.?cause|alertmanager.*root.?cause|alert.*send.*root.?cause"],
      "must_be_absent": true,
      "weight": 0.25
    },
    {
      "id": "n2",
      "description": "Does NOT claim it's a TSDB or storage issue",
      "patterns": ["TSDB.*root.?cause|storage.*root.?cause|disk.*root.?cause"],
      "must_be_absent": true,
      "weight": 0.25
    },
    {
      "id": "n3",
      "description": "Does NOT blame rule parsing or YAML loading as the cause",
      "patterns": ["parse.*root.?cause|YAML.*root.?cause|rulefmt.*root.?cause"],
      "must_be_absent": true,
      "weight": 0.25
    },
    {
      "id": "n4",
      "description": "Does NOT claim it's a race condition or concurrency bug",
      "patterns": ["race.*root.?cause|concurr.*root.?cause|mutex.*root.?cause|goroutine.*root.?cause"],
      "must_be_absent": true,
      "weight": 0.25
    }
  ]
}
