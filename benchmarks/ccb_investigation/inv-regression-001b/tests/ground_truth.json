{
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.30,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "description": "Identifies PR #15489 or commit e10bbf0a84 as the FIX (not the regression)",
      "patterns": [
        "PR #15489",
        "#15489",
        "e10bbf0a84",
        "e10bbf0a",
        "fix.*hot.*reload",
        "fix.*always_scrape_classic_histograms"
      ],
      "weight": 0.08
    },
    {
      "description": "Identifies that config works on startup but not on reload",
      "patterns": [
        "scrapePool\\.sync",
        "startup.*reload",
        "initial.*reload",
        "restartLoops"
      ],
      "weight": 0.09
    },
    {
      "description": "Identifies the two affected config options",
      "patterns": [
        "always_scrape_classic_histograms.*convert_classic_histograms",
        "convert_classic_histograms.*always_scrape_classic_histograms",
        "both.*histogram.*config"
      ],
      "weight": 0.08
    },
    {
      "description": "Identifies that scrapePool.sync applies configs but restartLoops does not",
      "patterns": [
        "sync.*applies",
        "restartLoops.*does not",
        "sync.*restartLoops",
        "reload.*path.*missing"
      ],
      "weight": 0.10
    },
    {
      "description": "Mentions the native histogram feature development context",
      "patterns": [
        "native histogram",
        "NHCB",
        "Prometheus 3\\.0",
        "v3\\.0",
        "3\\.0.*breaking"
      ],
      "weight": 0.07
    },
    {
      "description": "Identifies that the regression was introduced during scrape pool refactoring",
      "patterns": [
        "scrape.*pool.*refactor",
        "scrapePool.*changes",
        "manager.*refactor",
        "reload.*refactor"
      ],
      "weight": 0.09
    },
    {
      "description": "Uses git history or commit search to find the regressing commit",
      "patterns": [
        "git.*log",
        "git.*blame",
        "commit.*history",
        "git.*bisect",
        "introduced.*commit",
        "regressing.*commit"
      ],
      "weight": 0.10
    },
    {
      "description": "Identifies the specific commit or PR that introduced the regression",
      "patterns": [
        "[0-9a-f]{7,40}",
        "PR #[0-9]+",
        "introduced.*PR",
        "regression.*commit"
      ],
      "weight": 0.12
    },
    {
      "description": "Explains WHY the configs are missing from the reload path",
      "patterns": [
        "not.*passed.*restartLoops",
        "missing.*parameter",
        "config.*not.*propagated",
        "restartLoops.*signature",
        "reload.*missing.*config"
      ],
      "weight": 0.10
    },
    {
      "description": "References the scrape manager or scrape pool config handling",
      "patterns": [
        "scrape.*manager",
        "scrapePool",
        "scrape.*config",
        "reload.*config"
      ],
      "weight": 0.08
    },
    {
      "description": "Mentions that the fix adds the configs to restartLoops call",
      "patterns": [
        "fix.*adds.*restartLoops",
        "restartLoops.*now.*receives",
        "pass.*config.*restartLoops",
        "propagate.*config.*reload"
      ],
      "weight": 0.09
    }
  ],
  "file_references": [
    {
      "description": "References scrape/manager.go",
      "patterns": [
        "scrape/manager\\.go",
        "manager\\.go"
      ],
      "weight": 0.20
    },
    {
      "description": "References scrape/scrape.go",
      "patterns": [
        "scrape/scrape\\.go",
        "scrape\\.go"
      ],
      "weight": 0.18
    },
    {
      "description": "References config/config.go or scrape config struct",
      "patterns": [
        "config/config\\.go",
        "config\\.go",
        "ScrapeConfig"
      ],
      "weight": 0.15
    },
    {
      "description": "References PR #15489 (the fix)",
      "patterns": [
        "PR #15489",
        "#15489",
        "pull/15489"
      ],
      "weight": 0.12
    },
    {
      "description": "References commit e10bbf0a84 (the fix commit)",
      "patterns": [
        "e10bbf0a84",
        "e10bbf0a"
      ],
      "weight": 0.12
    },
    {
      "description": "References scrapePool.sync or scrapePool.restartLoops functions",
      "patterns": [
        "scrapePool\\.sync",
        "scrapePool\\.restartLoops",
        "\\.sync\\(",
        "\\.restartLoops\\("
      ],
      "weight": 0.13
    },
    {
      "description": "References the regressing commit SHA",
      "patterns": [
        "regress.*[0-9a-f]{7}",
        "introduced.*[0-9a-f]{7}",
        "broke.*[0-9a-f]{7}"
      ],
      "weight": 0.10
    }
  ],
  "causal_chain": [
    {
      "description": "Step 1: Scrape pool refactoring split startup and reload code paths",
      "patterns": [
        "scrape.*pool.*refactor",
        "split.*sync.*restart",
        "separate.*startup.*reload"
      ],
      "weight": 0.25
    },
    {
      "description": "Step 2: New histogram configs added to scrapePool.sync but not restartLoops",
      "patterns": [
        "histogram.*config.*sync",
        "sync.*receives.*config",
        "restartLoops.*missing.*config"
      ],
      "weight": 0.25
    },
    {
      "description": "Step 3: Hot reload calls restartLoops without histogram config parameters",
      "patterns": [
        "reload.*restartLoops",
        "restartLoops.*missing",
        "SIGHUP.*restartLoops"
      ],
      "weight": 0.25
    },
    {
      "description": "Step 4: Scrape targets continue using old histogram behavior despite config change",
      "patterns": [
        "targets.*old.*behavior",
        "config.*ignored.*reload",
        "histogram.*not.*applied"
      ],
      "weight": 0.25
    }
  ],
  "negative_checks": [
    {
      "description": "Does NOT blame the histogram parsing logic (it works correctly)",
      "patterns": [
        "histogram.*parsing.*bug",
        "config.*parse.*error",
        "YAML.*parse.*histogram"
      ],
      "weight": 0.30
    },
    {
      "description": "Does NOT blame the SIGHUP handler (it triggers reload correctly)",
      "patterns": [
        "SIGHUP.*broken",
        "signal.*handler.*bug",
        "reload.*endpoint.*bug"
      ],
      "weight": 0.35
    },
    {
      "description": "Does NOT claim the bug only affects scrapePool.sync",
      "patterns": [
        "sync.*broken",
        "startup.*fails",
        "initial.*config.*broken"
      ],
      "weight": 0.35
    }
  ]
}
