    "behavioral_notes": {
      "weight": 0.3,
      "items": [
        {
          "name": "Create vs CreateUnpinned pinning behavior",
          "patterns": [
            "CreateUnpinned.*without pinning",
            "Create.*pin"
          ],
          "weight": 0.09
        },
        {
          "name": "OpenOrCreate existing map behavior",
          "patterns": [
            "OpenOrCreate.*existing",
            "OpenOrCreate.*create"
          ],
          "weight": 0.09
        },
        {
          "name": "Recreate removes and re-creates map",
          "patterns": [
            "Recreate.*remove",
            "Recreate.*re-pin"
          ],
          "weight": 0.08
        },
        {
          "name": "DeleteLocked required within DumpCallback",
          "patterns": [
            "DeleteLocked.*DumpCallback",
            "DeleteLocked.*lock"
          ],
          "weight": 0.08
        },
        {
          "name": "SilentDelete returns (deleted bool, error)",
          "patterns": [
            "SilentDelete.*bool.*error",
            "SilentDelete.*return"
          ],
          "weight": 0.07
        },
        {
          "name": "DumpReliablyWithCallback tracks DumpStats",
          "patterns": [
            "DumpReliablyWithCallback.*stats",
            "DumpStats.*track"
          ],
          "weight": 0.07
        },
        {
          "name": "BatchIterator retry behavior on ENOSPC",
          "patterns": [
            "BatchIterator.*ENOSPC",
            "retry.*ENOSPC",
            "WithMaxRetries"
          ],
          "weight": 0.08
        },
        {
          "name": "Event subscription cleanup via Handle.Close()",
          "patterns": [
            "Handle.*Close",
            "event.*cleanup",
            "DumpAndSubscribe.*Handle"
          ],
          "weight": 0.08
        },
        {
          "name": "Map pinning to BPF filesystem paths",
          "patterns": [
            "pin.*filesystem",
            "BPFFSRoot",
            "/sys/fs/bpf"
          ],
          "weight": 0.07
        },
        {
          "name": "MapKey and MapValue must implement New() for allocation",
          "patterns": [
            "MapKey.*New",
            "MapValue.*New",
            "New().*MapKey"
          ],
          "weight": 0.08
        },
        {
          "name": "LoadCollection returns cleanup function",
          "patterns": [
            "LoadCollection.*cleanup",
            "LoadCollection.*func.*error"
          ],
          "weight": 0.07
        },
        {
          "name": "Per-CPU maps use MapPerCPUValue with NewSlice",
          "patterns": [
            "Per-CPU.*MapPerCPUValue",
            "NewSlice.*per-CPU"
          ],
          "weight": 0.07
        },
        {
          "name": "EndpointKey supports both IPv4 and IPv6",
          "patterns": [
            "EndpointKey.*IPv4.*IPv6",
            "EndpointKeyIPv4",
            "EndpointKeyIPv6"
          ],
          "weight": 0.07
        }
      ]
