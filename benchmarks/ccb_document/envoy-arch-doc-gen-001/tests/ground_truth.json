{
  "task_id": "docgen-arch-001",
  "description": "Envoy HTTP Connection Manager Architecture Documentation",
  "weights": {
    "required_topics": 0.40,
    "file_references": 0.25,
    "data_flow": 0.20,
    "extension_points": 0.15
  },
  "required_topics": [
    {
      "id": "t1",
      "description": "Explains ConnectionManagerImpl as a Network::ReadFilter",
      "patterns": ["ConnectionManagerImpl", "Network::ReadFilter|ReadFilter|network filter"],
      "weight": 0.10
    },
    {
      "id": "t2",
      "description": "Explains ActiveStream as per-request state",
      "patterns": ["ActiveStream"],
      "weight": 0.10
    },
    {
      "id": "t3",
      "description": "Explains codec creation (H1/H2/H3 protocol handling)",
      "patterns": ["codec|ServerConnection|createCodec"],
      "weight": 0.08
    },
    {
      "id": "t4",
      "description": "Explains FilterManager or DownstreamFilterManager",
      "patterns": ["FilterManager|filter.?manager"],
      "weight": 0.10
    },
    {
      "id": "t5",
      "description": "Explains decoder/encoder filter chain distinction",
      "patterns": ["[Dd]ecoder.*[Ff]ilter|[Ee]ncoder.*[Ff]ilter|decoder filter chain|encoder filter chain|StreamDecoderFilter|StreamEncoderFilter"],
      "weight": 0.10
    },
    {
      "id": "t6",
      "description": "Explains filter iteration (decodeHeaders/decodeData)",
      "patterns": ["decodeHeaders|decodeData|decodeTrailers"],
      "weight": 0.07
    },
    {
      "id": "t7",
      "description": "Explains Router::Filter as terminal decoder filter",
      "patterns": ["[Rr]outer.*[Ff]ilter|Router::Filter|terminal.*filter"],
      "weight": 0.10
    },
    {
      "id": "t8",
      "description": "Explains route selection via RouteConfiguration",
      "patterns": ["[Rr]oute.*[Cc]onfiguration|[Rr]oute.*selection|RouteConfigProvider"],
      "weight": 0.07
    },
    {
      "id": "t9",
      "description": "Explains ClusterManager providing connection pools",
      "patterns": ["ClusterManager|cluster.?manager"],
      "weight": 0.10
    },
    {
      "id": "t10",
      "description": "Explains upstream request lifecycle",
      "patterns": ["UpstreamRequest|upstream.*request"],
      "weight": 0.05
    },
    {
      "id": "t11",
      "description": "Explains load balancing",
      "patterns": ["load.?balanc|LoadBalancer"],
      "weight": 0.05
    },
    {
      "id": "t12",
      "description": "Explains watermark-based flow control",
      "patterns": ["watermark|flow.?control|readDisable|buffer.*high.*watermark"],
      "weight": 0.04
    },
    {
      "id": "t13",
      "description": "Explains retry logic",
      "patterns": ["retry|RetryState|retry.*policy"],
      "weight": 0.04
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References conn_manager_impl source files",
      "patterns": ["conn_manager_impl\\.cc|conn_manager_impl\\.h|source/common/http/conn_manager_impl"],
      "weight": 0.25
    },
    {
      "id": "r2",
      "description": "References filter_manager source files",
      "patterns": ["filter_manager\\.cc|filter_manager\\.h|source/common/http/filter_manager"],
      "weight": 0.25
    },
    {
      "id": "r3",
      "description": "References router source files",
      "patterns": ["source/common/router/router\\.cc|source/common/router/router\\.h|common/router/router"],
      "weight": 0.20
    },
    {
      "id": "r4",
      "description": "References cluster_manager_impl source files",
      "patterns": ["cluster_manager_impl\\.cc|cluster_manager_impl\\.h|source/common/upstream/cluster_manager"],
      "weight": 0.15
    },
    {
      "id": "r5",
      "description": "References codec subdirectory files (http1/, http2/, or http3/)",
      "patterns": ["source/common/http/http[123]/|http1/codec|http2/codec|http3/codec|http1/.*\\.cc|http2/.*\\.cc"],
      "weight": 0.15
    }
  ],
  "data_flow": [
    {
      "id": "d1",
      "description": "Downstream bytes -> codec -> ActiveStream -> FilterManager decode chain -> Router",
      "patterns": ["onData|ReadFilter|raw.*bytes|downstream", "codec|ServerConnection|decode", "ActiveStream|stream", "filter.*chain|FilterManager|decode"],
      "ordered": true,
      "weight": 0.50
    },
    {
      "id": "d2",
      "description": "Router -> ClusterManager -> connection pool -> upstream host -> response encode chain",
      "patterns": ["[Rr]outer|upstream", "ClusterManager|connection.*pool|conn.*pool|load.*balanc", "response|encode|encodeHeaders"],
      "ordered": true,
      "weight": 0.30
    },
    {
      "id": "d3",
      "description": "Error handling: sendLocalReply or stream reset on failure",
      "patterns": ["sendLocalReply|local.*reply|reset.*stream|stream.*reset|error|failure|4[0-9]{2}|5[0-9]{2}"],
      "weight": 0.20
    }
  ],
  "extension_points": [
    {
      "id": "e1",
      "description": "HTTP filter extensions (StreamDecoderFilter/StreamEncoderFilter/StreamFilter)",
      "patterns": ["StreamDecoderFilter|StreamEncoderFilter|StreamFilter|HTTP.*filter.*extension|custom.*filter"],
      "weight": 0.35
    },
    {
      "id": "e2",
      "description": "Access log handler extensions",
      "patterns": ["[Aa]ccess.*[Ll]og|AccessLogHandler|addAccessLogHandler"],
      "weight": 0.20
    },
    {
      "id": "e3",
      "description": "Load balancer or cluster extensions",
      "patterns": ["[Ll]oad.*[Bb]alanc.*extension|custom.*load.*balanc|[Cc]luster.*type|ClusterFactory|ThreadAwareLoadBalancer"],
      "weight": 0.25
    },
    {
      "id": "e4",
      "description": "HTTP codec or protocol extensions",
      "patterns": ["codec.*extension|custom.*codec|[Hh]eader.*[Vv]alidator|HeaderValidatorFactory|protocol.*extension"],
      "weight": 0.20
    }
  ]
}
