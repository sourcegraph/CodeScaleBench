{
  "task_id": "nlqa-flow-002",
  "description": "Envoy request routing: listener accept to upstream connection",
  "weights": {
    "required_findings": 0.35,
    "file_references": 0.25,
    "causal_chain": 0.30,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies Listener or ListenerImpl accepts TCP connections",
      "patterns": ["Listener|listener.*accept|ListenerImpl|onAccept"],
      "weight": 0.10
    },
    {
      "id": "f2",
      "description": "Explains FilterChainManager selects network filter chain based on connection properties",
      "patterns": ["FilterChainManager|filter.*chain.*manager", "findFilterChain|filter.*chain.*select"],
      "weight": 0.15
    },
    {
      "id": "f3",
      "description": "Identifies ConnectionManagerImpl (HCM) as a network filter",
      "patterns": ["ConnectionManagerImpl|conn_manager_impl", "Network::ReadFilter"],
      "weight": 0.12
    },
    {
      "id": "f4",
      "description": "Explains codec parses byte stream into HTTP messages",
      "patterns": ["codec|Codec|Http1.*Codec|dispatch|ServerConnection"],
      "weight": 0.12
    },
    {
      "id": "f5",
      "description": "Mentions ActiveStream represents a single request-response cycle",
      "patterns": ["ActiveStream|active.*stream|newStream"],
      "weight": 0.10
    },
    {
      "id": "f6",
      "description": "Identifies FilterManager manages HTTP filter chain iteration",
      "patterns": ["FilterManager|filter_manager", "decodeHeaders.*filter|filter.*iterate"],
      "weight": 0.12
    },
    {
      "id": "f7",
      "description": "Explains Router::Filter selects upstream cluster and host",
      "patterns": ["Router::Filter|router.*filter|router\\.cc", "cluster.*select|upstream.*select"],
      "weight": 0.15
    },
    {
      "id": "f8",
      "description": "Mentions connection pool manages upstream connections",
      "patterns": ["ConnectionPool|connection.*pool|GenericConnPool|newStream.*pool"],
      "weight": 0.10
    },
    {
      "id": "f9",
      "description": "Describes UpstreamRequest handles upstream request/response",
      "patterns": ["UpstreamRequest|upstream.*request|encodeHeaders.*upstream"],
      "weight": 0.04
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References listener_impl.h or listener_impl.cc",
      "patterns": ["source/server/listener_impl\\.(h|cc)|source/common/listener_manager/", "listener_impl\\.h|listener_impl\\.cc"],
      "weight": 0.15
    },
    {
      "id": "r2",
      "description": "References filter_chain_manager_impl.h",
      "patterns": ["filter_chain_manager_impl\\.h", "source/server/filter_chain_manager"],
      "weight": 0.15
    },
    {
      "id": "r3",
      "description": "References conn_manager_impl.h or conn_manager_impl.cc",
      "patterns": ["source/common/http/conn_manager_impl\\.(h|cc)", "conn_manager_impl\\.h|conn_manager_impl\\.cc"],
      "weight": 0.20
    },
    {
      "id": "r4",
      "description": "References filter_manager.h or filter_manager.cc",
      "patterns": ["source/common/http/filter_manager\\.(h|cc)", "filter_manager\\.h|filter_manager\\.cc"],
      "weight": 0.15
    },
    {
      "id": "r5",
      "description": "References router.h or router.cc",
      "patterns": ["source/common/router/router\\.(h|cc)", "router\\.h|router\\.cc"],
      "weight": 0.20
    },
    {
      "id": "r6",
      "description": "References upstream connection pool or codec files",
      "patterns": ["conn_pool|connection.*pool|upstream.*request|codec.*impl|http1.*codec"],
      "weight": 0.15
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Accept to HCM flow: Listener accepts → FilterChainManager selects chain → HCM installed as network filter → onData() receives bytes → codec parses HTTP",
      "patterns": [
        "listener.*accept|accept.*connection",
        "FilterChainManager|findFilterChain",
        "ConnectionManagerImpl|HCM|network.*filter",
        "onData",
        "codec.*dispatch|parse.*HTTP|ServerConnection"
      ],
      "ordered": true,
      "weight": 0.30
    },
    {
      "id": "c2",
      "description": "HTTP filter chain flow: codec calls newStream → ActiveStream created → FilterManager.decodeHeaders → filters iterate (A→B→C) → Router::Filter invoked",
      "patterns": [
        "newStream|ActiveStream",
        "FilterManager|filter_manager",
        "decodeHeaders|decode.*header",
        "filter.*iterate|iterate.*filter",
        "Router::Filter|router.*filter"
      ],
      "ordered": true,
      "weight": 0.35
    },
    {
      "id": "c3",
      "description": "Upstream flow: Router resolves route → selects cluster → picks host → ConnectionPool provides connection → UpstreamRequest writes to upstream",
      "patterns": [
        "route.*resolv|cached.*route|route.*entry",
        "cluster|upstream.*cluster",
        "host.*select|load.*balanc",
        "ConnectionPool|connection.*pool",
        "UpstreamRequest|encode.*upstream|upstream.*write"
      ],
      "ordered": true,
      "weight": 0.35
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT claim the router directly creates TCP sockets to upstream (it uses ConnectionPool)",
      "patterns": ["router.*direct.*socket|router.*create.*TCP.*connection|router.*bypass.*pool"],
      "must_be_absent": true,
      "weight": 0.50
    },
    {
      "id": "n2",
      "description": "Does NOT confuse decoder filter iteration (A→B→C) with encoder filter iteration (C→B→A)",
      "patterns": ["decoder.*reverse|encoder.*forward|decoder.*C.*B.*A"],
      "must_be_absent": true,
      "weight": 0.50
    }
  ]
}
