{
  "task_id": "onboard-orient-001",
  "description": "Cilium codebase orientation — onboarding exploration",
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.30,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies daemon/main.go as the agent entry point",
      "patterns": ["daemon/main\\.go", "daemon.*main"],
      "weight": 0.15
    },
    {
      "id": "f2",
      "description": "Mentions Hive dependency injection framework",
      "patterns": ["[Hh]ive", "dependency.?injection.*hive|hive.*dependency.?injection"],
      "weight": 0.10
    },
    {
      "id": "f3",
      "description": "Identifies pkg/policy/ as the policy engine package",
      "patterns": ["pkg/policy", "policy.*engine|policy.*repository|PolicyRepository"],
      "weight": 0.10
    },
    {
      "id": "f4",
      "description": "Identifies pkg/datapath/ as the datapath abstraction layer",
      "patterns": ["pkg/datapath", "datapath.*loader|datapath.*linux"],
      "weight": 0.10
    },
    {
      "id": "f5",
      "description": "Identifies pkg/k8s/ for Kubernetes integration",
      "patterns": ["pkg/k8s", "k8s.*watcher|k8s.*client|kubernetes.*integration"],
      "weight": 0.08
    },
    {
      "id": "f6",
      "description": "Identifies pkg/endpoint/ for endpoint management",
      "patterns": ["pkg/endpoint", "endpoint.*manager|endpointmanager"],
      "weight": 0.07
    },
    {
      "id": "f7",
      "description": "Identifies pkg/maps/ for BPF map management",
      "patterns": ["pkg/maps", "maps/policymap|policymap"],
      "weight": 0.07
    },
    {
      "id": "f8",
      "description": "Mentions Viper for configuration binding",
      "patterns": ["[Vv]iper", "spf13/viper"],
      "weight": 0.08
    },
    {
      "id": "f9",
      "description": "Identifies pkg/option/config.go as the main config struct location",
      "patterns": ["pkg/option", "option/config\\.go|DaemonConfig"],
      "weight": 0.08
    },
    {
      "id": "f10",
      "description": "Identifies multiple test approaches (unit, privileged, e2e/integration)",
      "patterns": ["privileged.*test|_privileged_test|test/controlplane|test/k8s|[Gg]inkgo"],
      "weight": 0.10
    },
    {
      "id": "f11",
      "description": "Identifies bpf/ directory for eBPF C programs",
      "patterns": ["bpf/bpf_lxc|bpf/lib/policy|bpf/.*\\.c"],
      "weight": 0.07
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References daemon/main.go or daemon/cmd/root.go",
      "patterns": ["daemon/main\\.go", "daemon/cmd/root\\.go", "daemon/cmd/daemon_main\\.go"],
      "weight": 0.15
    },
    {
      "id": "r2",
      "description": "References pkg/policy/api/ for policy API types",
      "patterns": ["pkg/policy/api", "policy/api/rule\\.go|policy/api/ingress|policy/api/egress"],
      "weight": 0.15
    },
    {
      "id": "r3",
      "description": "References pkg/k8s/apis/cilium.io/ for CRD types",
      "patterns": ["pkg/k8s/apis/cilium", "cilium\\.io/v2|cnp_types|ccnp_types"],
      "weight": 0.12
    },
    {
      "id": "r4",
      "description": "References pkg/option/config.go for configuration",
      "patterns": ["pkg/option/config\\.go", "option/config"],
      "weight": 0.10
    },
    {
      "id": "r5",
      "description": "References pkg/datapath/loader/ for BPF program loading",
      "patterns": ["pkg/datapath/loader", "datapath/loader/loader\\.go|datapath/loader/compile"],
      "weight": 0.12
    },
    {
      "id": "r6",
      "description": "References pkg/maps/policymap/ for BPF policy maps",
      "patterns": ["pkg/maps/policymap", "maps/policymap/policymap\\.go"],
      "weight": 0.10
    },
    {
      "id": "r7",
      "description": "References pkg/policy/repository.go or resolve.go",
      "patterns": ["policy/repository\\.go", "policy/resolve\\.go", "policy/mapstate\\.go"],
      "weight": 0.10
    },
    {
      "id": "r8",
      "description": "References test directory structure (test/controlplane or test/k8s)",
      "patterns": ["test/controlplane", "test/k8s", "test/runtime"],
      "weight": 0.08
    },
    {
      "id": "r9",
      "description": "References bpf/lib/policy.h for eBPF policy enforcement",
      "patterns": ["bpf/lib/policy\\.h", "bpf/bpf_lxc\\.c"],
      "weight": 0.08
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Policy pipeline: CRD types → K8s watcher → policy repository → endpoint regeneration → BPF map",
      "patterns": [
        "CRD|cnp_types|CiliumNetworkPolicy|api/rule",
        "watcher|k8s.*policy|policy.*k8s|PolicyImporter",
        "repository|resolve|mapstate|SelectorPolicy",
        "endpoint.*regen|UpdatePolicy|syncPolicyMap|bpf.*map|policymap"
      ],
      "ordered": true,
      "weight": 0.60
    },
    {
      "id": "c2",
      "description": "Config pipeline: Cobra CLI → Viper → DaemonConfig.Populate() → Validate()",
      "patterns": [
        "[Cc]obra|CLI|command",
        "[Vv]iper|config.*file|config.*dir",
        "DaemonConfig|Populate|config\\.go"
      ],
      "ordered": true,
      "weight": 0.40
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT claim cmd/cilium-agent/main.go is the entry point (it is daemon/main.go)",
      "patterns": ["cmd/cilium.agent/main\\.go.*entry|entry.*cmd/cilium.agent/main\\.go"],
      "must_be_absent": true,
      "weight": 0.50
    },
    {
      "id": "n2",
      "description": "Does NOT claim the project uses Make as its primary build system (it uses Go build with Hive)",
      "patterns": ["[Mm]ake.*primary.*build|primary.*build.*[Mm]akefile"],
      "must_be_absent": true,
      "weight": 0.50
    }
  ]
}
