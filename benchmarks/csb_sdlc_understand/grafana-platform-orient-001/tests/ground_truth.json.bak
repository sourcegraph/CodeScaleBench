{
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.30,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies pkg/cmd/grafana/main.go or cmd/grafana as the main entry point",
      "patterns": ["pkg/cmd/grafana", "cmd/grafana", "grafana-server"],
      "weight": 0.10
    },
    {
      "id": "f2",
      "description": "Identifies the service registry / wire dependency injection",
      "patterns": ["wire", "serviceRegistry", "service.registry", "pkg/server"],
      "weight": 0.10
    },
    {
      "id": "f3",
      "description": "Identifies pkg/api as the HTTP routing layer",
      "patterns": ["pkg/api", "HTTPServer", "RegisterRoutes"],
      "weight": 0.10
    },
    {
      "id": "f4",
      "description": "Identifies plugin system / grafana-plugin-sdk-go",
      "patterns": ["grafana-plugin-sdk", "plugin.*sdk", "backend.*plugin"],
      "weight": 0.10
    },
    {
      "id": "f5",
      "description": "Identifies gRPC communication with plugins",
      "patterns": ["gRPC", "grpc", "hashicorp.*plugin", "go-plugin"],
      "weight": 0.10
    },
    {
      "id": "f6",
      "description": "Identifies provisioning service and YAML config loading",
      "patterns": ["provisioning", "pkg/services/provisioning", "dashboards.*provisioning"],
      "weight": 0.10
    },
    {
      "id": "f7",
      "description": "Identifies React and webpack/vite frontend build",
      "patterns": ["React", "webpack", "vite", "packages/grafana-ui"],
      "weight": 0.10
    },
    {
      "id": "f8",
      "description": "Identifies alerting subsystem under pkg/services/ngalert",
      "patterns": ["ngalert", "pkg/services/ngalert", "alerting"],
      "weight": 0.10
    },
    {
      "id": "f9",
      "description": "Identifies authentication mechanisms",
      "patterns": ["pkg/services/authn", "pkg/services/auth", "OAuth", "SAML", "LDAP"],
      "weight": 0.10
    },
    {
      "id": "f10",
      "description": "Mentions panel plugin registration or discovery mechanism",
      "patterns": ["panel.*plugin", "plugin.*registry", "RegisterPlugin", "pluginstore"],
      "weight": 0.10
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References main entry point file",
      "patterns": ["pkg/cmd/grafana", "cmd/grafana-server", "pkg/cmd/grafana-server"],
      "weight": 0.12
    },
    {
      "id": "r2",
      "description": "References pkg/api/ directory or HTTPServer",
      "patterns": ["pkg/api/", "pkg/api/http_server", "api\\.go"],
      "weight": 0.12
    },
    {
      "id": "r3",
      "description": "References pkg/services/provisioning/",
      "patterns": ["pkg/services/provisioning/", "provisioning/dashboards"],
      "weight": 0.12
    },
    {
      "id": "r4",
      "description": "References plugin-related paths",
      "patterns": ["pkg/plugins/", "pkg/services/pluginsintegration", "pkg/tsdb/"],
      "weight": 0.12
    },
    {
      "id": "r5",
      "description": "References pkg/services/ngalert/",
      "patterns": ["pkg/services/ngalert/", "ngalert"],
      "weight": 0.10
    },
    {
      "id": "r6",
      "description": "References frontend source (public/app/ or packages/)",
      "patterns": ["public/app/", "packages/grafana-ui", "packages/grafana-data"],
      "weight": 0.12
    },
    {
      "id": "r7",
      "description": "References pkg/server/ (server bootstrap)",
      "patterns": ["pkg/server/", "server\\.go", "pkg/server/wire"],
      "weight": 0.10
    },
    {
      "id": "r8",
      "description": "References authentication paths",
      "patterns": ["pkg/services/authn/", "pkg/services/auth/", "pkg/login/"],
      "weight": 0.10
    },
    {
      "id": "r9",
      "description": "References conf/ or configuration loading",
      "patterns": ["conf/defaults\\.ini", "conf/", "pkg/setting/"],
      "weight": 0.10
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Startup chain: main entry → server init → service registry → HTTP server",
      "patterns": [
        "main|cmd/grafana|entry",
        "server|Server|Init",
        "registry|wire|service",
        "HTTP|api|routes"
      ],
      "ordered": true,
      "weight": 0.50
    },
    {
      "id": "c2",
      "description": "Provisioning pipeline: YAML config → provisioner service → database storage",
      "patterns": [
        "YAML|yaml|provisioning.*config",
        "provisioning.*service|Provisioner",
        "database|store|persist|save"
      ],
      "ordered": true,
      "weight": 0.50
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT claim Grafana is a single-binary monolith without plugins",
      "patterns": ["single.binary.*no.*plugin", "monolith.*without.*extensi"],
      "must_be_absent": true,
      "weight": 0.50
    },
    {
      "id": "n2",
      "description": "Does NOT claim Grafana frontend uses Angular (deprecated, now React)",
      "patterns": ["Angular.*primary|Angular.*main.*framework|built.*with.*Angular"],
      "must_be_absent": true,
      "weight": 0.50
    }
  ]
}
