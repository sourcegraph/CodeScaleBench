{
  "task_id": "nlqa-debug-002",
  "description": "Cilium eBPF program fault isolation: why doesn't one node's failure affect other nodes?",
  "weights": {
    "required_findings": 0.40,
    "file_references": 0.30,
    "causal_chain": 0.20,
    "negative_checks": 0.10
  },
  "required_findings": [
    {
      "id": "f1",
      "description": "Identifies DaemonSet deployment model (one cilium-agent pod per node)",
      "patterns": ["DaemonSet|daemon.*set|one.*agent.*per.*node|per.*node.*agent"],
      "weight": 0.15
    },
    {
      "id": "f2",
      "description": "Identifies Loader or datapath loader as the per-node eBPF compilation/loading component",
      "patterns": ["Loader|pkg/datapath/loader|Reinitialize|compileAndLoad"],
      "weight": 0.15
    },
    {
      "id": "f3",
      "description": "Explains node-specific configuration via node_config.h or HeaderfileWriter",
      "patterns": ["node_config\\.h|HeaderfileWriter|WriteNodeConfig|per.*node.*config|node.*specific"],
      "weight": 0.15
    },
    {
      "id": "f4",
      "description": "Explains eBPF programs attach to kernel-local TC hooks or netlink",
      "patterns": ["TC.*hook|traffic.*control|netlink|attach.*kernel|kernel.*local"],
      "weight": 0.10
    },
    {
      "id": "f5",
      "description": "Identifies BPF map pinning to /sys/fs/bpf (node-local filesystem)",
      "patterns": ["/sys/fs/bpf|bpf.*filesystem|PIN_GLOBAL_NS|PIN_OBJECT_NS|map.*pin"],
      "weight": 0.15
    },
    {
      "id": "f6",
      "description": "Explains CiliumNetworkPolicy CRDs are distributed cluster-wide but enforced per-node",
      "patterns": ["CiliumNetworkPolicy|CRD|cluster.*wide.*policy|distributed.*policy|Kubernetes.*watcher"],
      "weight": 0.10
    },
    {
      "id": "f7",
      "description": "Explains endpoint regeneration or endpoint manager triggers per-node BPF recompilation",
      "patterns": ["endpoint.*regenerat|EndpointManager|RegenerateAllEndpoints|endpoint.*lifecycle"],
      "weight": 0.10
    },
    {
      "id": "f8",
      "description": "Mentions datapath forwarding/enforcement doesn't require kvstore or etcd availability",
      "patterns": ["kvstore.*independ|etcd.*not.*required|datapath.*independ|local.*enforcement"],
      "weight": 0.10
    }
  ],
  "file_references": [
    {
      "id": "r1",
      "description": "References pkg/datapath/loader/base.go or loader.go",
      "patterns": ["pkg/datapath/loader/base\\.go|pkg/datapath/loader/loader\\.go|datapath/loader/"],
      "weight": 0.25
    },
    {
      "id": "r2",
      "description": "References pkg/datapath/linux/config/config.go (HeaderfileWriter)",
      "patterns": ["pkg/datapath/linux/config/config\\.go|HeaderfileWriter|WriteNodeConfig"],
      "weight": 0.20
    },
    {
      "id": "r3",
      "description": "References pkg/endpoint/ files (endpoint.go, regeneration/)",
      "patterns": ["pkg/endpoint/endpoint\\.go|pkg/endpoint/regeneration|endpoint/"],
      "weight": 0.20
    },
    {
      "id": "r4",
      "description": "References pkg/maps/ files or pkg/bpf/map_linux.go",
      "patterns": ["pkg/maps/|pkg/bpf/map_linux\\.go|LocalMapName"],
      "weight": 0.20
    },
    {
      "id": "r5",
      "description": "References bpf/node_config.h or bpf/ directory",
      "patterns": ["bpf/node_config\\.h|bpf/.*\\.c|bpf/"],
      "weight": 0.15
    }
  ],
  "causal_chain": [
    {
      "id": "c1",
      "description": "Full per-node eBPF lifecycle: cilium-agent starts → Loader.Reinitialize() → compiles node-specific BPF programs → loads into kernel → attaches to TC hooks → creates/pins maps to /sys/fs/bpf",
      "patterns": [
        "cilium-agent|agent.*start|daemon",
        "Reinitialize|Loader|compile",
        "node.*config|node_config\\.h|per.*node",
        "load.*kernel|verifier",
        "attach|TC|netlink",
        "/sys/fs/bpf|pin.*map|BPF.*filesystem"
      ],
      "ordered": true,
      "weight": 0.60
    },
    {
      "id": "c2",
      "description": "Policy enforcement flow: CiliumNetworkPolicy created → Kubernetes distributes CRD → each node's agent watches → triggers endpoint regeneration → recompiles BPF programs with new policy rules",
      "patterns": [
        "CiliumNetworkPolicy|policy.*CRD",
        "Kubernetes.*watch|API.*server|distributed",
        "endpoint.*regenerat|RegenerateAllEndpoints",
        "compile|BPF.*program|policy.*rule"
      ],
      "ordered": true,
      "weight": 0.40
    }
  ],
  "negative_checks": [
    {
      "id": "n1",
      "description": "Does NOT claim eBPF programs are compiled centrally and distributed as bytecode (they're compiled per-node with node-specific config)",
      "patterns": ["central.*compil|compile.*once.*distribute|bytecode.*distribut|shared.*eBPF.*program"],
      "must_be_absent": true,
      "weight": 0.50
    },
    {
      "id": "n2",
      "description": "Does NOT claim eBPF maps are shared across nodes via network (they're kernel-local)",
      "patterns": ["map.*shared.*network|map.*sync.*across.*node|remote.*map.*access|cluster.*wide.*map"],
      "must_be_absent": true,
      "weight": 0.50
    }
  ]
}
