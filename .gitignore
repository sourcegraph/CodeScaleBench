# Build and virtualenv
__pycache__/
*.pyc
*.pyo
.venv/

# All dotfiles/dotdirs (local tooling, IDE, CI, etc.)
.*
!.gitignore
!.gitattributes
# Repo CI (workflows live here; do not ignore)
!.github/
!.github/**

# Credentials and secrets
*.key
*.pem
*.env*
*.secret*
*credential*

# =============================================
# PUBLIC BRANCH: exclude development noise
# =============================================

# --- Docs: only keep technical_reports ---
docs/*
!docs/technical_reports/
!docs/technical_reports/**

# --- Runs: only keep analysis ---
runs/
!runs/
runs/*
!runs/analysis/
!runs/analysis/**
runs/analysis/**/agent/sessions/
runs/analysis/**/agent/.mcp.json

# --- Internal development directories ---
calibration/
configs/
data/
eval_reports/
fixtures/
jobs/
logs/
ralph/
ralph-*/
reports/
results/
sourcegraph_benchmarks/
sourcegraph_tasks/
templates/
tmp/

# --- Large external datasets ---
ccb_crossrepo/
!benchmarks/ccb_crossrepo/
harbor-ccb_crossrepo-dataset/
vendor/DependEval/
vendor/dependeval_repos/

# --- Harbor integration (private) ---
ccb_harbor/

# --- Misc ---
archive/
tasks/
oracle_curation_log.json
*.log
*.db
ds
browse/
