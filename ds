#!/bin/bash

set -e

VERSION="1.0.0"
SOURCEGRAPH_URL="${SOURCEGRAPH_URL:-https://sourcegraph.sourcegraph.com}"

error_exit() {
    echo "$1" >&2
    exit 1
}

check_env() {
    if [ -z "$SRC_ACCESS_TOKEN" ]; then
        error_exit "Error: SRC_ACCESS_TOKEN environment variable is required"
    fi
}

usage() {
    cat >&2 <<EOF
ds - Sourcegraph Deep Search CLI v${VERSION}

Usage:
  ds start --question "..." [--async]                          # Create new conversation
  ds ask --id <id> --question "..." [--async]                  # Add question to conversation
  ds get --id <id>                                             # Get conversation by ID or UUID
  ds list [--user-id <id>] [--first <n>] [--sort <field>]     # List conversations
  ds delete --id <id>                                          # Delete conversation
  ds delete-all                                                # Delete all conversations
  ds cancel --id <id> --question-id <qid>                      # Cancel a question
  ds rotate-token --id <id>                                    # Rotate read token

Environment Variables:
  SRC_ACCESS_TOKEN    Required. Sourcegraph access token
  SOURCEGRAPH_URL     Optional. Sourcegraph instance URL (default: https://sourcegraph.sourcegraph.com)
EOF
    exit 1
}

cmd_start() {
    local question=""
    local async_header=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --question)
                question="$2"
                shift 2
                ;;
            --async)
                async_header="Prefer: respond-async"
                shift
                ;;
            *)
                error_exit "Unknown option: $1"
                ;;
        esac
    done
    
    if [ -z "$question" ]; then
        error_exit "Error: --question is required"
    fi
    
    check_env
    
    local headers=(
        -H "Authorization: token $SRC_ACCESS_TOKEN"
        -H "X-Requested-With: ds-cli ${VERSION}"
        -H "Content-Type: application/json"
    )
    
    if [ -n "$async_header" ]; then
        headers+=(-H "$async_header")
    fi
    
    local payload=$(cat <<EOF
{
  "question": $(printf '%s' "$question" | jq -Rs .)
}
EOF
)
    
    curl -s -X POST \
        "${headers[@]}" \
        -d "$payload" \
        "${SOURCEGRAPH_URL}/.api/deepsearch/v1" || error_exit "Error: Failed to create conversation"
}

cmd_ask() {
    local conversation_id=""
    local question=""
    local async_header=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --id)
                conversation_id="$2"
                shift 2
                ;;
            --question)
                question="$2"
                shift 2
                ;;
            --async)
                async_header="Prefer: respond-async"
                shift
                ;;
            *)
                error_exit "Unknown option: $1"
                ;;
        esac
    done
    
    if [ -z "$conversation_id" ]; then
        error_exit "Error: --id is required"
    fi
    
    if [ -z "$question" ]; then
        error_exit "Error: --question is required"
    fi
    
    check_env
    
    # If ID is a UUID, look up numeric ID first
    if [[ "$conversation_id" =~ - ]]; then
        conversation_id=$(curl -s -X GET \
            -H "Authorization: token $SRC_ACCESS_TOKEN" \
            -H "X-Requested-With: ds-cli ${VERSION}" \
            "${SOURCEGRAPH_URL}/.api/deepsearch/v1?filter_read_token=${conversation_id}" | jq -r '.conversations[0].id // .deepsearches[0].id // empty')
        
        if [ -z "$conversation_id" ]; then
            error_exit "Error: Conversation not found for UUID"
        fi
    fi
    
    local headers=(
        -H "Authorization: token $SRC_ACCESS_TOKEN"
        -H "X-Requested-With: ds-cli ${VERSION}"
        -H "Content-Type: application/json"
    )
    
    if [ -n "$async_header" ]; then
        headers+=(-H "$async_header")
    fi
    
    local payload=$(cat <<EOF
{
  "question": $(printf '%s' "$question" | jq -Rs .)
}
EOF
)
    
    curl -s -X POST \
        "${headers[@]}" \
        -d "$payload" \
        "${SOURCEGRAPH_URL}/.api/deepsearch/v1/${conversation_id}/questions" || error_exit "Error: Failed to add question"
}

cmd_get() {
    local conversation_id=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --id)
                conversation_id="$2"
                shift 2
                ;;
            *)
                error_exit "Unknown option: $1"
                ;;
        esac
    done
    
    if [ -z "$conversation_id" ]; then
        error_exit "Error: --id is required"
    fi
    
    check_env
    
    # Check if ID is a UUID (contains hyphens) - treat as read_token
    if [[ "$conversation_id" =~ - ]]; then
        # UUID lookup: use filter_read_token parameter
        local response=$(curl -s -X GET \
            -H "Authorization: token $SRC_ACCESS_TOKEN" \
            -H "X-Requested-With: ds-cli ${VERSION}" \
            "${SOURCEGRAPH_URL}/.api/deepsearch/v1?filter_read_token=${conversation_id}")
        
        local result
        result=$(printf '%s' "$response" | jq '.conversations[0] // .deepsearches[0] // null' 2>/dev/null)
        
        if [ "$result" = "null" ] || [ -z "$result" ]; then
            error_exit "Error: Conversation not found for UUID: $conversation_id"
        fi
        
        printf '%s\n' "$result"
    else
        curl -s -X GET \
            -H "Authorization: token $SRC_ACCESS_TOKEN" \
            -H "X-Requested-With: ds-cli ${VERSION}" \
            "${SOURCEGRAPH_URL}/.api/deepsearch/v1/${conversation_id}" || error_exit "Error: Failed to get conversation"
    fi
}

cmd_list() {
    local user_id=""
    local first=""
    local sort=""
    local params=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --user-id)
                user_id="$2"
                shift 2
                ;;
            --first)
                first="$2"
                shift 2
                ;;
            --sort)
                sort="$2"
                shift 2
                ;;
            *)
                error_exit "Unknown option: $1"
                ;;
        esac
    done
    
    check_env
    
    # Build query parameters
    if [ -n "$user_id" ]; then
        params="${params}filter_user_id=${user_id}&"
    fi
    if [ -n "$first" ]; then
        params="${params}page_first=${first}&"
    fi
    if [ -n "$sort" ]; then
        params="${params}sort=${sort}&"
    fi
    
    # Remove trailing &
    params="${params%&}"
    
    local url="${SOURCEGRAPH_URL}/.api/deepsearch/v1"
    if [ -n "$params" ]; then
        url="${url}?${params}"
    fi
    
    curl -s -X GET \
        -H "Authorization: token $SRC_ACCESS_TOKEN" \
        -H "X-Requested-With: ds-cli ${VERSION}" \
        "${url}" || error_exit "Error: Failed to list conversations"
}

cmd_delete() {
    local conversation_id=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --id)
                conversation_id="$2"
                shift 2
                ;;
            *)
                error_exit "Unknown option: $1"
                ;;
        esac
    done
    
    if [ -z "$conversation_id" ]; then
        error_exit "Error: --id is required"
    fi
    
    check_env
    
    # If ID is a UUID, look up numeric ID first
    if [[ "$conversation_id" =~ - ]]; then
        conversation_id=$(curl -s -X GET \
            -H "Authorization: token $SRC_ACCESS_TOKEN" \
            -H "X-Requested-With: ds-cli ${VERSION}" \
            "${SOURCEGRAPH_URL}/.api/deepsearch/v1?filter_read_token=${conversation_id}" | jq -r '.conversations[0].id // .deepsearches[0].id // empty')
        
        if [ -z "$conversation_id" ]; then
            error_exit "Error: Conversation not found for UUID"
        fi
    fi
    
    curl -s -X DELETE \
        -H "Authorization: token $SRC_ACCESS_TOKEN" \
        -H "X-Requested-With: ds-cli ${VERSION}" \
        "${SOURCEGRAPH_URL}/.api/deepsearch/v1/${conversation_id}" || error_exit "Error: Failed to delete conversation"
}

cmd_delete_all() {
    check_env
    
    curl -s -X DELETE \
        -H "Authorization: token $SRC_ACCESS_TOKEN" \
        -H "X-Requested-With: ds-cli ${VERSION}" \
        "${SOURCEGRAPH_URL}/.api/deepsearch/v1" || error_exit "Error: Failed to delete all conversations"
}

cmd_cancel() {
    local conversation_id=""
    local question_id=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --id)
                conversation_id="$2"
                shift 2
                ;;
            --question-id)
                question_id="$2"
                shift 2
                ;;
            *)
                error_exit "Unknown option: $1"
                ;;
        esac
    done
    
    if [ -z "$conversation_id" ]; then
        error_exit "Error: --id is required"
    fi
    
    if [ -z "$question_id" ]; then
        error_exit "Error: --question-id is required"
    fi
    
    check_env
    
    curl -s -X POST \
        -H "Authorization: token $SRC_ACCESS_TOKEN" \
        -H "X-Requested-With: ds-cli ${VERSION}" \
        "${SOURCEGRAPH_URL}/.api/deepsearch/v1/${conversation_id}/questions/${question_id}/cancel" || error_exit "Error: Failed to cancel question"
}

cmd_rotate_token() {
    local conversation_id=""
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            --id)
                conversation_id="$2"
                shift 2
                ;;
            *)
                error_exit "Unknown option: $1"
                ;;
        esac
    done
    
    if [ -z "$conversation_id" ]; then
        error_exit "Error: --id is required"
    fi
    
    check_env
    
    # If ID is a UUID, look up numeric ID first
    if [[ "$conversation_id" =~ - ]]; then
        conversation_id=$(curl -s -X GET \
            -H "Authorization: token $SRC_ACCESS_TOKEN" \
            -H "X-Requested-With: ds-cli ${VERSION}" \
            "${SOURCEGRAPH_URL}/.api/deepsearch/v1?filter_read_token=${conversation_id}" | jq -r '.conversations[0].id // .deepsearches[0].id // empty')
        
        if [ -z "$conversation_id" ]; then
            error_exit "Error: Conversation not found for UUID"
        fi
    fi
    
    curl -s -X POST \
        -H "Authorization: token $SRC_ACCESS_TOKEN" \
        -H "X-Requested-With: ds-cli ${VERSION}" \
        "${SOURCEGRAPH_URL}/.api/deepsearch/v1/${conversation_id}/rotate-read-token" || error_exit "Error: Failed to rotate token"
}

if [ $# -eq 0 ]; then
    usage
fi

command="$1"
shift

case "$command" in
    start)
        cmd_start "$@"
        ;;
    ask)
        cmd_ask "$@"
        ;;
    get)
        cmd_get "$@"
        ;;
    list)
        cmd_list "$@"
        ;;
    delete)
        cmd_delete "$@"
        ;;
    delete-all)
        cmd_delete_all "$@"
        ;;
    cancel)
        cmd_cancel "$@"
        ;;
    rotate-token)
        cmd_rotate_token "$@"
        ;;
    -h|--help)
        usage
        ;;
    *)
        error_exit "Unknown command: $command"
        ;;
esac
