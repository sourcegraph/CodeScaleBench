#!/usr/bin/env python3
"""Evaluation Runner CLI wrapper.

This script provides the `run-eval` command for running experiments.

Usage:
    ./run-eval run -c configs/minimal.yaml
    ./run-eval dry-run -c configs/locobench_50_tasks_comparison.yaml
    ./run-eval validate -c configs/locobench_50_tasks_comparison.yaml
    ./run-eval status -e exp_xxx
"""

import sys
from pathlib import Path

repo_root = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(repo_root))

from lib.cli import main

if __name__ == "__main__":
    sys.exit(main())
