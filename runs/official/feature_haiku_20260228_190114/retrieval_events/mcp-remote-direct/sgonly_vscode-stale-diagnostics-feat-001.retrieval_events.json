        "file_path": "/workspace/extensions/typescript-language-features/src/typescriptServiceClient.ts",
        "old_string": "\t\tthis.diagnosticsManager = new DiagnosticsManager('typescript', this._configuration, this.telemetryReporter, onCaseInsensitiveFileSystem);\n\t\tthis.typescriptServerSpawner = new TypeScriptServerSpawner(this.versionProvider, this._versionManager, this._nodeVersionManager, this.logDirectoryProvider, this.pluginPathsProvider, this.logger, this.telemetryReporter, this.tracer, this.processFactory);\n\n\t\tthis._register(this.pluginManager.onDidUpdateConfig(update => {\n\t\t\tthis.configurePlugin(update.pluginId, update.config);\n\t\t}));\n\n\t\tthis._register(this.pluginManager.onDidChangePlugins(() => {\n\t\t\tthis.restartTsServer();\n\t\t}));\n\t}",
        "new_string": "\t\tthis.diagnosticsManager = new DiagnosticsManager('typescript', this._configuration, this.telemetryReporter, onCaseInsensitiveFileSystem);\n\t\tthis.typescriptServerSpawner = new TypeScriptServerSpawner(this.versionProvider, this._versionManager, this._nodeVersionManager, this.logDirectoryProvider, this.pluginPathsProvider, this.logger, this.telemetryReporter, this.tracer, this.processFactory);\n\n\t\t// Watch for file system changes (e.g., from git operations) to refresh diagnostics\n\t\tconst diagnosticsFileWatcher = this._register(vscode.workspace.createFileSystemWatcher('**/*.{ts,tsx,js,jsx}'));\n\t\tconst handleFileSystemChange = (uri: vscode.Uri) => {\n\t\t\t// Clear diagnostics for files that changed on disk\n\t\t\tthis.diagnosticsManager.deleteAllDiagnosticsInFile(uri);\n\t\t\t// If the file is open in the editor, request fresh diagnostics\n\t\t\tif (this.bufferSyncSupport.handles(uri)) {\n\t\t\t\tthis.bufferSyncSupport.getErr([uri]);\n\t\t\t}\n\t\t};\n\t\tthis._register(diagnosticsFileWatcher.onDidChange(handleFileSystemChange));\n\t\tthis._register(diagnosticsFileWatcher.onDidCreate(handleFileSystemChange));\n\t\tthis._register(diagnosticsFileWatcher.onDidDelete(uri => {\n\t\t\tthis.diagnosticsManager.deleteAllDiagnosticsInFile(uri);\n\t\t}));\n\n\t\tthis._register(this.pluginManager.onDidUpdateConfig(update => {\n\t\t\tthis.configurePlugin(update.pluginId, update.config);\n\t\t}));\n\n\t\tthis._register(this.pluginManager.onDidChangePlugins(() => {\n\t\t\tthis.restartTsServer();\n\t\t}));\n\t}",
