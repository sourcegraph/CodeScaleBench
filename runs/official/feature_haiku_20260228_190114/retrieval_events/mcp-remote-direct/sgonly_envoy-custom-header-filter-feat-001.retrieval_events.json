        "old_string": "#include \"source/extensions/filters/http/custom_header_injection/filter.h\"\n\n#include \"envoy/extensions/filters/http/custom_header_injection/v3/custom_header_injection.pb.h\"\n#include \"source/common/http/utility.h\"\n\nnamespace Envoy {\nnamespace Extensions {\nnamespace HttpFilters {\nnamespace CustomHeaderInjection {\n\nCustomHeaderInjectionConfig::CustomHeaderInjectionConfig(const ProtoConfig& config) {\n  for (const auto& rule : config.headers()) {\n    rules_.push_back({rule.header_name(), rule.header_value(), rule.inject_in_request(),\n                      rule.inject_in_response()});\n  }\n}\n\nPerRouteCustomHeaderInjection::PerRouteCustomHeaderInjection(const PerRouteProtoConfig& config) {\n  for (const auto& rule : config.headers()) {\n    rules_.push_back({rule.header_name(), rule.header_value(), rule.inject_in_request(),\n                      rule.inject_in_response()});\n  }\n}\n\nHttp::FilterHeadersStatus CustomHeaderInjectionFilter::decodeHeaders(Http::RequestHeaderMap& headers,\n                                                                    bool) {\n  // Get the effective config (global or route-specific)\n  const auto* config =\n      Http::Utility::resolveMostSpecificPerFilterConfig<CustomHeaderInjectionConfig>(\n          decoder_callbacks_);\n  if (!config) {\n    config = config_.get();\n  }\n\n  if (config) {\n    injectHeaders(headers, config->rules(), true);\n  }\n\n  return Http::FilterHeadersStatus::Continue;\n}\n\nHttp::FilterHeadersStatus CustomHeaderInjectionFilter::encodeHeaders(Http::ResponseHeaderMap& headers,\n                                                                    bool) {\n  // Get the effective config (global or route-specific)\n  const auto* config =\n      Http::Utility::resolveMostSpecificPerFilterConfig<CustomHeaderInjectionConfig>(\n          encoder_callbacks_);\n  if (!config) {\n    config = config_.get();\n  }\n\n  if (config) {\n    injectHeaders(headers, config->rules(), false);\n  }\n\n  return Http::FilterHeadersStatus::Continue;\n}\n\nvoid CustomHeaderInjectionFilter::injectHeaders(Http::HeaderMap& headers,\n                                                const std::vector<HeaderInjectionRule>& rules,\n                                                bool is_request) {\n  for (const auto& rule : rules) {\n    // Check if we should inject this header\n    if (is_request && !rule.inject_in_request) {\n      continue;\n    }\n    if (!is_request && !rule.inject_in_response) {\n      continue;\n    }\n\n    // Inject the header\n    Http::LowerCaseString lower_name(rule.header_name);\n    headers.setCopy(lower_name, rule.header_value);\n  }\n}\n\n} // namespace CustomHeaderInjection\n} // namespace HttpFilters\n} // namespace Extensions\n} // namespace Envoy",
        "new_string": "#include \"source/extensions/filters/http/custom_header_injection/filter.h\"\n\n#include \"envoy/extensions/filters/http/custom_header_injection/v3/custom_header_injection.pb.h\"\n#include \"source/common/http/utility.h\"\n\nnamespace Envoy {\nnamespace Extensions {\nnamespace HttpFilters {\nnamespace CustomHeaderInjection {\n\nCustomHeaderInjectionConfig::CustomHeaderInjectionConfig(const ProtoConfig& config) {\n  for (const auto& rule : config.headers()) {\n    rules_.push_back({rule.header_name(), rule.header_value(), rule.inject_in_request(),\n                      rule.inject_in_response()});\n  }\n}\n\nPerRouteCustomHeaderInjection::PerRouteCustomHeaderInjection(const PerRouteProtoConfig& config) {\n  for (const auto& rule : config.headers()) {\n    rules_.push_back({rule.header_name(), rule.header_value(), rule.inject_in_request(),\n                      rule.inject_in_response()});\n  }\n}\n\nHttp::FilterHeadersStatus CustomHeaderInjectionFilter::decodeHeaders(Http::RequestHeaderMap& headers,\n                                                                    bool) {\n  if (config_) {\n    injectHeaders(headers, config_->rules(), true);\n  }\n  return Http::FilterHeadersStatus::Continue;\n}\n\nHttp::FilterHeadersStatus CustomHeaderInjectionFilter::encodeHeaders(Http::ResponseHeaderMap& headers,\n                                                                    bool) {\n  if (config_) {\n    injectHeaders(headers, config_->rules(), false);\n  }\n  return Http::FilterHeadersStatus::Continue;\n}\n\nvoid CustomHeaderInjectionFilter::injectHeaders(Http::HeaderMap& headers,\n                                                const std::vector<HeaderInjectionRule>& rules,\n                                                bool is_request) const {\n  for (const auto& rule : rules) {\n    // Check if we should inject this header\n    if (is_request && !rule.inject_in_request) {\n      continue;\n    }\n    if (!is_request && !rule.inject_in_respo