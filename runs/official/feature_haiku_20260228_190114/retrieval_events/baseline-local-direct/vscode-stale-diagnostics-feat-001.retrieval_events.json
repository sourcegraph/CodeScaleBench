        "old_string": "\tpublic listen(): void {\n\t\tif (this.listening) {\n\t\t\treturn;\n\t\t}\n\t\tthis.listening = true;\n\t\tvscode.workspace.onDidOpenTextDocument(this.openTextDocument, this, this._disposables);\n\t\tvscode.workspace.onDidCloseTextDocument(this.onDidCloseTextDocument, this, this._disposables);\n\t\tvscode.workspace.onDidChangeTextDocument(this.onDidChangeTextDocument, this, this._disposables);\n\t\tvscode.window.onDidChangeVisibleTextEditors(e => {\n\t\t\tfor (const { document } of e) {\n\t\t\t\tconst syncedBuffer = this.syncedBuffers.get(document.uri);\n\t\t\t\tif (syncedBuffer) {\n\t\t\t\t\tthis.requestDiagnostic(syncedBuffer);\n\t\t\t\t}\n\t\t\t}\n\t\t}, this, this._disposables);\n\t\tvscode.workspace.textDocuments.forEach(this.openTextDocument, this);\n\t}",
        "new_string": "\tpublic listen(): void {\n\t\tif (this.listening) {\n\t\t\treturn;\n\t\t}\n\t\tthis.listening = true;\n\t\tvscode.workspace.onDidOpenTextDocument(this.openTextDocument, this, this._disposables);\n\t\tvscode.workspace.onDidCloseTextDocument(this.onDidCloseTextDocument, this, this._disposables);\n\t\tvscode.workspace.onDidChangeTextDocument(this.onDidChangeTextDocument, this, this._disposables);\n\t\tvscode.window.onDidChangeVisibleTextEditors(e => {\n\t\t\tfor (const { document } of e) {\n\t\t\t\tconst syncedBuffer = this.syncedBuffers.get(document.uri);\n\t\t\t\tif (syncedBuffer) {\n\t\t\t\t\tthis.requestDiagnostic(syncedBuffer);\n\t\t\t\t}\n\t\t\t}\n\t\t}, this, this._disposables);\n\n\t\t// Watch for file system changes (e.g., from git operations) to detect stale diagnostics\n\t\tthis.setupFileSystemWatcher();\n\n\t\tvscode.workspace.textDocuments.forEach(this.openTextDocument, this);\n\t}\n\n\tprivate setupFileSystemWatcher(): void {\n\t\t// Create file system watchers for TypeScript and JavaScript files\n\t\tconst patterns = [\n\t\t\t'**/*.ts',\n\t\t\t'**/*.tsx',\n\t\t\t'**/*.js',\n\t\t\t'**/*.jsx',\n\t\t];\n\n\t\tfor (const pattern of patterns) {\n\t\t\tconst watcher = vscode.workspace.createFileSystemWatcher(pattern);\n\n\t\t\twatcher.onDidChange((uri) => {\n\t\t\t\t// File was modified on disk - refresh diagnostics for this file\n\t\t\t\tthis.onFileSystemChange(uri);\n\t\t\t}, this, this._disposables);\n\n\t\t\twatcher.onDidDelete((uri) => {\n\t\t\t\t// File was deleted - clear diagnostics for this file\n\t\t\t\tthis.onFileSystemDelete(uri);\n\t\t\t}, this, this._disposables);\n\n\t\t\tthis._disposables.push(watcher);\n\t\t}\n\t}\n\n\tprivate onFileSystemChange(uri: vscode.Uri): void {\n\t\tconst syncedBuffer = this.syncedBuffers.get(uri);\n\t\tif (syncedBuffer) {\n\t\t\t// File has changed on disk, request fresh diagnostics\n\t\t\tthis.requestDiagnostic(syncedBuffer);\n\t\t} else {\n\t\t\t// File not currently synced, but request diagnostics anyway\n\t\t\t// This handles cases where the file is open but hasn't been modified in the editor\n\t\t\tif (this.shouldTriggerDiagnosticsForFile(uri)) {\n\t\t\t\tthis.pendingDiagnostics.set(uri, Date.now());\n\t\t\t\tthis.triggerDiagnostics();\n\t\t\t}\n\t\t}\n\t}\n\n\tprivate onFileSystemDelete(uri: vscode.Uri): void {\n\t\tconst syncedBuffer = this.syncedBuffers.get(uri);\n\t\tif (syncedBuffer) {\n\t\t\t// Clear diagnostics for deleted file\n\t\t\tthis.pendingDiagnostics.delete(uri);\n\t\t\tthis.pendingGetErr?.files.delete(uri);\n\t\t}\n\t}\n\n\tprivate shouldTriggerDiagnosticsForFile(uri: vscode.Uri): boolean {\n\t\t// Only trigger diagnostics for TypeScript/JavaScript files\n\t\tconst fileName = uri.fsPath.toLowerCase();\n\t\treturn fileName.endsWith('.ts') || fileName.endsWith('.tsx') ||\n\t\t\tfileName.endsWith('.js') || fileName.endsWith('.jsx');\n\t}",
