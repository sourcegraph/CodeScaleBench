        "old_string": "class ToggleImportFoldAction extends FoldingAction<void> {\n\n\tconstructor() {\n\t\tsuper({\n\t\t\tid: 'editor.toggleImportFold',\n\t\t\tlabel: nls.localize2('toggleImportFold.label', \"Toggle Import Fold\"),\n\t\t\tprecondition: CONTEXT_FOLDING_ENABLED,\n\t\t\tkbOpts: {\n\t\t\t\tkbExpr: EditorContextKeys.editorTextFocus,\n\t\t\t\tweight: KeybindingWeight.EditorContrib\n\t\t\t}\n\t\t});\n\t}\n\n\tasync invoke(foldingController: FoldingController, foldingModel: FoldingModel): Promise<void> {\n\t\tconst regionsToToggle: FoldingRegion[] = [];\n\t\tconst regions = foldingModel.regions;\n\t\tfor (let i = regions.length - 1; i >= 0; i--) {\n\t\t\tif (regions.getType(i) === FoldingRangeKind.Imports.value) {\n\t\t\t\tregionsToToggle.push(regions.toRegion(i));\n\t\t\t}\n\t\t}\n\t\tfoldingModel.toggleCollapseState(regionsToToggle);\n\t\tfoldingController.triggerFoldingModelChanged();\n\t}\n}",
        "new_string": "class ToggleImportFoldAction extends FoldingAction<void> {\n\n\tconstructor() {\n\t\tsuper({\n\t\t\tid: 'editor.toggleImportFold',\n\t\t\tlabel: nls.localize2('toggleImportFold.label', \"Toggle Import Fold\"),\n\t\t\tprecondition: CONTEXT_FOLDING_ENABLED,\n\t\t\tkbOpts: {\n\t\t\t\tkbExpr: EditorContextKeys.editorTextFocus,\n\t\t\t\tweight: KeybindingWeight.EditorContrib\n\t\t\t}\n\t\t});\n\t}\n\n\tasync invoke(foldingController: FoldingController, foldingModel: FoldingModel): Promise<void> {\n\t\tconst regionsToToggle: FoldingRegion[] = [];\n\t\tconst regions = foldingModel.regions;\n\t\tfor (let i = regions.length - 1; i >= 0; i--) {\n\t\t\tif (regions.getType(i) === FoldingRangeKind.Imports.value) {\n\t\t\t\tregionsToToggle.push(regions.toRegion(i));\n\t\t\t}\n\t\t}\n\t\tfoldingModel.toggleCollapseState(regionsToToggle);\n\t\tfoldingController.triggerFoldingModelChanged();\n\t}\n}\n\ninterface GoToNamedRegionPickItem extends IQuickPickItem {\n\tstartLineNumber: number;\n\tendLineNumber: number;\n\tregionName: string;\n}\n\nclass GoToNamedRegionAction extends EditorAction {\n\n\tconstructor() {\n\t\tsuper({\n\t\t\tid: 'editor.action.goToNamedRegion',\n\t\t\tlabel: nls.localize2('goToNamedRegion.label', \"Go to Named Region\"),\n\t\t\talias: 'Go to Named Region',\n\t\t\tprecondition: EditorContextKeys.editorTextFocus,\n\t\t\tkbOpts: {\n\t\t\t\tkbExpr: EditorContextKeys.editorTextFocus,\n\t\t\t\tprimary: KeyMod.CtrlCmd | KeyMod.Shift | KeyCode.KeyR,\n\t\t\t\tweight: KeybindingWeight.EditorContrib\n\t\t\t}\n\t\t});\n\t}\n\n\toverride async run(accessor: ServicesAccessor, editor: ICodeEditor): Promise<void> {\n\t\tif (!editor.hasModel()) {\n\t\t\treturn;\n\t\t}\n\n\t\tconst foldingController = FoldingController.get(editor);\n\t\tif (!foldingController) {\n\t\t\treturn;\n\t\t}\n\n\t\t// Get the folding model to access named regions\n\t\tconst foldingModel = await foldingController.getFoldingModel();\n\t\tif (!foldingModel) {\n\t\t\treturn;\n\t\t}\n\n\t\t// Create a NamedRangeProvider to extract named regions from the document\n\t\tconst namedRegions: any[] = [];\n\t\tconst { computeNamedRanges } = await import('./namedRangeProvider.js');\n\t\tconst foldingRanges = computeNamedRanges(editor.getModel()!, namedRegions);\n\n\t\tif (!foldingRanges || namedRegions.length === 0) {\n\t\t\treturn;\n\t\t}\n\n\t\t// Create quick pick items\n\t\tconst items: GoToNamedRegionPickItem[] = namedRegions.map(region => ({\n\t\t\tlabel: region.name,\n\t\t\tdescription: `Lines ${region.startLineNumber}-${region.endLineNumber}`,\n\t\t\tregionName: region.name,\n\t\t\tstartLineNumber: region.startLineNumber,\n\t\t\tendLineNumber: region.endLineNumber\n\t\t}));\n\n\t\t// Show quick pick\n\t\tconst quickInputService = accessor.get(IQuickInputService);\n\t\tconst selectedItem = await quickInputService.pick<GoToNamedRegionPickItem>(items, {\n\t\t\tplaceHolder: 'Select a region to go to'\n\t\t});\n\n\t\tif (!selectedItem) {\n\t\t\treturn;\n\t\t}\n\n\t\t// Navigate to the selected region\n\t\teditor.setPosition({\n\t\t\tlineNumber: selectedItem.startLineNumber,\n\t\t\tcolumn: 1\n\t\t});\n\n\t\t// Scroll to make the region visible\n\t\teditor.revealLineInCenterIfOutsideViewport(selectedItem.startLineNumber, 0);\n\n\t\t// Optionally unfold the region if it's collapsed\n\t\tconst region = foldingModel.getRegionAtLine(selectedItem.startLineNumber);\n\t\tif (region && region.isCollapsed) {\n\t\t\tfoldingModel.toggleCollapseState([region]);\n\t\t}\n\t}\n}",
