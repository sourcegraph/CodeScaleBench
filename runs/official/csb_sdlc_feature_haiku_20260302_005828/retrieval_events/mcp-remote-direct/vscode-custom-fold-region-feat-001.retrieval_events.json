        "old_string": "\tfor (let lineNumber = 1; lineNumber <= lineCount; lineNumber++) {\n\t\tconst lineContent = model.getLineContent(lineNumber);\n\t\tconst startMatch = lineContent.match(regionStartPattern);\n\t\tconst endMatch = lineContent.match(regionEndPattern);\n\n\t\tif (startMatch) {\n\t\t\t// Found a region start marker\n\t\t\tconst regionName = startMatch[1].trim();\n\t\t\tregionStack.push({\n\t\t\t\tname: regionName,\n\t\t\t\tstartLineNumber: lineNumber\n\t\t\t});\n\t\t} else if (endMatch && regionStack.length > 0) {\n\t\t\t// Found a region end marker\n\t\t\tconst region = regionStack.pop()!;\n\n\t\t\t// Only add if region has at least 2 lines (start and end)\n\t\t\tif (lineNumber > region.startLineNumber) {\n\t\t\t\tstartIndexes.push(region.startLineNumber);\n\t\t\t\tendIndexes.push(lineNumber);\n\t\t\t\tnames.push(region.name);\n\n\t\t\t\t// Store in namedRegions for quick access\n\t\t\t\tnamedRegions.push({\n\t\t\t\t\tname: region.name,\n\t\t\t\t\tstartLineNumber: region.startLineNumber,\n\t\t\t\t\tendLineNumber: lineNumber\n\t\t\t\t});\n\n\t\t\t\t// Check limit\n\t\t\t\tif (startIndexes.length >= foldingRangesLimit.limit) {\n\t\t\t\t\tfoldingRangesLimit.update(lineCount, foldingRangesLimit.limit);\n\t\t\t\t\tbreak;\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}",
