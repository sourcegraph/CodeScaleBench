        "new_string": "// mockFlagStore is a simple mock implementation for testing\ntype mockFlagStore struct {\n\tflags    map[string]*flipt.Flag\n\trollouts map[string][]*storage.EvaluationRollout\n}\n\nfunc newMockFlagStore() *mockFlagStore {\n\treturn &mockFlagStore{\n\t\tflags:    make(map[string]*flipt.Flag),\n\t\trollouts: make(map[string][]*storage.EvaluationRollout),\n\t}\n}\n\nfunc (m *mockFlagStore) String() string {\n\treturn \"mock\"\n}\n\nfunc (m *mockFlagStore) GetFlag(ctx context.Context, req storage.ResourceRequest) (*flipt.Flag, error) {\n\t// Create a key from namespace and flag key\n\tkey := req.NamespaceKey + \":\" + req.Key\n\tif flag, ok := m.flags[key]; ok {\n\t\treturn flag, nil\n\t}\n\treturn nil, fmt.Errorf(\"%s not found\", req.Key)\n}\n\nfunc (m *mockFlagStore) GetEvaluationRules(ctx context.Context, req storage.ResourceRequest) ([]*storage.EvaluationRule, error) {\n\treturn nil, nil\n}\n\nfunc (m *mockFlagStore) GetEvaluationDistributions(ctx context.Context, req storage.IDRequest) ([]*storage.EvaluationDistribution, error) {\n\treturn nil, nil\n}\n\nfunc (m *mockFlagStore) GetEvaluationRollouts(ctx context.Context, req storage.ResourceRequest) ([]*storage.EvaluationRollout, error) {\n\t// Create a key from namespace and flag key\n\tkey := req.NamespaceKey + \":\" + req.Key\n\tif rollouts, ok := m.rollouts[key]; ok {\n\t\treturn rollouts, nil\n\t}\n\treturn []*storage.EvaluationRollout{}, nil\n}",
