        "file_path": "/workspace/django-code/django/forms/forms.py",
        "old_string": "class DeclarativeFieldsMetaclass(MediaDefiningClass):\n    \"\"\"Collect Fields declared on the base classes.\"\"\"\n\n    def __new__(mcs, name, bases, attrs):\n        # Collect fields from current class and remove them from attrs.\n        attrs[\"declared_fields\"] = {\n            key: attrs.pop(key)\n            for key, value in list(attrs.items())\n            if isinstance(value, Field)\n        }\n\n        new_class = super().__new__(mcs, name, bases, attrs)\n\n        # Walk through the MRO.\n        declared_fields = {}\n        for base in reversed(new_class.__mro__):\n            # Collect fields from base class.\n            if hasattr(base, \"declared_fields\"):\n                declared_fields.update(base.declared_fields)\n\n            # Field shadowing.\n            for attr, value in base.__dict__.items():\n                if value is None and attr in declared_fields:\n                    declared_fields.pop(attr)\n\n        new_class.base_fields = declared_fields\n        new_class.declared_fields = declared_fields\n\n        return new_class",
        "new_string": "class DeclarativeFieldsMetaclass(MediaDefiningClass):\n    \"\"\"Collect Fields and CompositeFieldValidators declared on the base classes.\"\"\"\n\n    def __new__(mcs, name, bases, attrs):\n        # Collect fields from current class and remove them from attrs.\n        attrs[\"declared_fields\"] = {\n            key: attrs.pop(key)\n            for key, value in list(attrs.items())\n            if isinstance(value, Field)\n        }\n\n        # Collect composite field validators from current class and remove them from attrs.\n        attrs[\"declared_composite_validators\"] = {\n            key: attrs.pop(key)\n            for key, value in list(attrs.items())\n            if isinstance(value, CompositeFieldValidator)\n        }\n\n        new_class = super().__new__(mcs, name, bases, attrs)\n\n        # Walk through the MRO.\n        declared_fields = {}\n        declared_composite_validators = {}\n        for base in reversed(new_class.__mro__):\n            # Collect fields from base class.\n            if hasattr(base, \"declared_fields\"):\n                declared_fields.update(base.declared_fields)\n\n            # Collect composite validators from base class.\n            if hasattr(base, \"declared_composite_validators\"):\n                declared_composite_validators.update(base.declared_composite_validators)\n\n            # Field shadowing.\n            for attr, value in base.__dict__.items():\n                if value is None and attr in declared_fields:\n                    declared_fields.pop(attr)\n\n        new_class.base_fields = declared_fields\n        new_class.declared_fields = declared_fields\n        new_class.base_composite_validators = declared_composite_validators\n        new_class.declared_composite_validators = declared_composite_validators\n\n        return new_class",
