        "new_string": "func TestCredentialFunc(t *testing.T) {\n\tr := &ECR{}\n\t_, err := r.Credential(context.Background(), \"\")\n\tassert.Error(t, err)\n}\n\nfunc TestCredentialContextPropagation(t *testing.T) {\n\tt.Run(\"context timeout respected\", func(t *testing.T) {\n\t\tctx, cancel := context.WithCancel(context.Background())\n\t\tcancel() // Cancel context immediately\n\n\t\tclient := NewMockClient(t)\n\t\tr := &ECR{\n\t\t\tclient: client,\n\t\t}\n\n\t\t// Note: The Credential method will try to load config using the cancelled context\n\t\t// This tests that the context is properly propagated\n\t\t_, err := r.Credential(ctx, \"\")\n\t\tassert.Error(t, err)\n\t\t// The error should be related to context cancellation or config loading\n\t})\n\n\tt.Run(\"credential refresh on each call\", func(t *testing.T) {\n\t\tclient := NewMockClient(t)\n\t\tcallCount := 0\n\t\tclient.On(\"GetAuthorizationToken\", mock.Anything, mock.Anything).Return(\n\t\t\tfunc(ctx context.Context, params *ecr.GetAuthorizationTokenInput, optFns ...func(*ecr.Options)) *ecr.GetAuthorizationTokenOutput {\n\t\t\t\tcallCount++\n\t\t\t\treturn &ecr.GetAuthorizationTokenOutput{\n\t\t\t\t\tAuthorizationData: []types.AuthorizationData{\n\t\t\t\t\t\t{AuthorizationToken: ptr(\"dXNlcl9uYW1lOnBhc3N3b3Jk\")},\n\t\t\t\t\t},\n\t\t\t\t}\n\t\t\t},\n\t\t\tfunc(ctx context.Context, params *ecr.GetAuthorizationTokenInput, optFns ...func(*ecr.Options)) error {\n\t\t\t\treturn nil\n\t\t\t},\n\t\t)\n\n\t\tr := &ECR{\n\t\t\tclient: client,\n\t\t}\n\n\t\t// First call should succeed\n\t\tcred1, err := r.fetchCredential(context.Background())\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"user_name\", cred1.Username)\n\n\t\t// Second call should also call GetAuthorizationToken again\n\t\t// (simulating credential refresh)\n\t\tcred2, err := r.fetchCredential(context.Background())\n\t\tassert.NoError(t, err)\n\t\tassert.Equal(t, \"user_name\", cred2.Username)\n\n\t\t// Verify GetAuthorizationToken was called multiple times\n\t\tassert.GreaterOrEqual(t, callCount, 2)\n\t})\n}",
