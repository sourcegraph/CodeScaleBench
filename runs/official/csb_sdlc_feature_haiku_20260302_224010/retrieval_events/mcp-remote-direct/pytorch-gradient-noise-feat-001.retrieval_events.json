        "file_path": "/workspace/torch/optim/gradient_noise.py",
        "old_string": "    def step(self, closure=None):\n        \"\"\"Perform optimization step with noise injection.\n\n        Injects Gaussian noise into gradients according to the noise schedule,\n        then delegates to the base optimizer's step.\n\n        Args:\n            closure (callable, optional): A closure that reevaluates the model\n                and returns the loss.\n\n        Returns:\n            The loss value returned by the base optimizer's step if closure is provided.\n        \"\"\"\n        # Inject noise into gradients\n        for group in self.optimizer.param_groups:\n            for param in group[\"params\"]:\n                if param.grad is not None:\n                    # Calculate noise variance: sigma^2 = eta / (1 + t)^gamma\n                    sigma_sq = self.eta / (1 + self.step_count) ** self.gamma\n                    sigma = torch.sqrt(torch.tensor(sigma_sq))\n\n                    # Generate Gaussian noise\n                    noise = torch.randn_like(param.grad) * sigma\n\n                    # Add noise to gradient\n                    param.grad.add_(noise)\n\n        # Increment step count\n        self.step_count += 1\n\n        # Call the base optimizer's step\n        return self.optimizer.step(closure)",
        "new_string": "    def step(self, closure=None):\n        \"\"\"Perform optimization step with noise injection.\n\n        Injects Gaussian noise into gradients according to the noise schedule,\n        then delegates to the base optimizer's step.\n\n        Args:\n            closure (callable, optional): A closure that reevaluates the model\n                and returns the loss.\n\n        Returns:\n            The loss value returned by the base optimizer's step if closure is provided.\n        \"\"\"\n        # Inject noise into gradients\n        for group in self.optimizer.param_groups:\n            for param in group[\"params\"]:\n                if param.grad is not None:\n                    # Calculate noise variance: sigma^2 = eta / (1 + t)^gamma\n                    sigma_sq = self.eta / (1 + self.step_count) ** self.gamma\n                    sigma = sigma_sq ** 0.5\n\n                    # Generate Gaussian noise\n                    noise = torch.randn_like(param.grad) * sigma\n\n                    # Add noise to gradient\n                    param.grad.add_(noise)\n\n        # Increment step count\n        self.step_count += 1\n\n        # Call the base optimizer's step\n        return self.optimizer.step(closure)",
