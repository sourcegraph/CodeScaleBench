        "old_string": "// LogEvaluation logs the results of a policy evaluation including information\n// about the policy key, selector cache matches, and the evaluation result.\nfunc (pal *PolicyAuditLogger) LogEvaluation(ctx context.Context, policyKey string, selectorCache *SelectorCache, result string) {\n\tpal.Lock()\n\tdefer pal.Unlock()\n\n\tif pal.logger == nil {\n\t\treturn\n\t}\n\n\tfields := logrus.Fields{\n\t\tlogfields.PolicyKey: policyKey,\n\t\t\"result\":            result,\n\t}\n\n\tscopedLog := pal.logger.WithFields(fields)\n\n\t// Try to get identity statistics from selector cache if available\n\thitCount := 0\n\tmissCount := 0\n\tif selectorCache != nil {\n\t\t// Estimate hit/miss based on identity cache size\n\t\thitCount = len(selectorCache.GetIdentityCache())\n\t}\n\n\tif pal.enableJSON {\n\t\tevaluation := AuditEvaluation{\n\t\t\tPolicyKey:      policyKey,\n\t\t\tResult:         result,\n\t\t\tIdentitiesHit:  hitCount,\n\t\t\tIdentitiesMiss: missCount,\n\t\t\tTimestamp:      getCurrentTimestamp(),\n\t\t}\n\t\tevalJSON, err := json.Marshal(evaluation)\n\t\tif err == nil {\n\t\t\tscopedLog.WithField(\"audit_data\", string(evalJSON)).Log(pal.logLevel, \"policy evaluation\")\n\t\t}\n\t} else {\n\t\tscopedLog.Log(pal.logLevel, \"policy evaluation\")\n\t}\n}",
        "new_string": "// LogEvaluation logs the results of a policy evaluation including information\n// about the policy key, selector cache matches, and the evaluation result.\nfunc (pal *PolicyAuditLogger) LogEvaluation(ctx context.Context, policyKey string, selectorCache *SelectorCache, result string) {\n\tpal.Lock()\n\tdefer pal.Unlock()\n\n\tif pal.logger == nil {\n\t\treturn\n\t}\n\n\tfields := logrus.Fields{\n\t\tlogfields.PolicyKey: policyKey,\n\t\t\"result\":            result,\n\t}\n\n\tscopedLog := pal.logger.WithFields(fields)\n\n\tif pal.enableJSON {\n\t\tevaluation := AuditEvaluation{\n\t\t\tPolicyKey:      policyKey,\n\t\t\tResult:         result,\n\t\t\tIdentitiesHit:  0,\n\t\t\tIdentitiesMiss: 0,\n\t\t\tTimestamp:      getCurrentTimestamp(),\n\t\t}\n\t\tevalJSON, err := json.Marshal(evaluation)\n\t\tif err == nil {\n\t\t\tscopedLog.WithField(\"audit_data\", string(evalJSON)).Log(pal.logLevel, \"policy evaluation\")\n\t\t}\n\t} else {\n\t\tscopedLog.Log(pal.logLevel, \"policy evaluation\")\n\t}\n}",
