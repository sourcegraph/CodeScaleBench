        "new_string": "\t\tthis.client.onTsServerStarted(() => {\n\t\t\tthis.triggerAllDiagnostics();\n\t\t});\n\n\t\tvscode.workspace.onDidChangeConfiguration(this.configurationChanged, this, this._disposables);\n\t\tthis.configurationChanged();\n\t\tthis._register(new LogLevelMonitor(context));\n\n\t\t// Watch for file system changes (e.g., from git operations) and refresh diagnostics\n\t\tthis._register(this.setupFileWatcher());\n\t}\n\n\tprivate setupFileWatcher(): vscode.Disposable {\n\t\tconst watchers: vscode.Disposable[] = [];\n\n\t\t// Watch TypeScript/JavaScript files in the workspace\n\t\tfor (const folder of vscode.workspace.workspaceFolders || []) {\n\t\t\tconst fileWatcher = vscode.workspace.createFileSystemWatcher(\n\t\t\t\tnew vscode.RelativePattern(folder, '**/*.{ts,tsx,js,jsx,mts,cts,mjs,cjs}'),\n\t\t\t\ttrue,  // ignoreCreateEvents\n\t\t\t\tfalse, // ignoreChangeEvents\n\t\t\t\tfalse  // ignoreDeleteEvents\n\t\t\t);\n\n\t\t\tfileWatcher.onDidChange(uri => {\n\t\t\t\tthis.onFileChanged(uri);\n\t\t\t});\n\n\t\t\tfileWatcher.onDidDelete(uri => {\n\t\t\t\tthis.onFileDeleted(uri);\n\t\t\t});\n\n\t\t\twatchers.push(fileWatcher);\n\t\t}\n\n\t\t// Return a disposable that disposes all watchers\n\t\treturn {\n\t\t\tdispose: () => {\n\t\t\t\twatchers.forEach(w => w.dispose());\n\t\t\t}\n\t\t};\n\t}\n\n\tprivate onFileChanged(uri: vscode.Uri): void {\n\t\t// When a file changes on disk, clear stale diagnostics and request re-analysis\n\t\tfor (const language of this.languages) {\n\t\t\tif (language.handlesUri(uri)) {\n\t\t\t\tlanguage.onFileChanged(uri);\n\t\t\t\tbreak;\n\t\t\t}\n\t\t}\n\n\t\t// Request the TypeScript server to re-analyze this file\n\t\tthis.client.bufferSyncSupport.getErr([uri]);\n\t}\n\n\tprivate onFileDeleted(uri: vscode.Uri): void {\n\t\t// When a file is deleted, clear its diagnostics\n\t\tfor (const language of this.languages) {\n\t\t\tif (language.handlesUri(uri)) {\n\t\t\t\tlanguage.onFileDeleted(uri);\n\t\t\t\tbreak;\n\t\t\t}\n\t\t}\n\t}",
