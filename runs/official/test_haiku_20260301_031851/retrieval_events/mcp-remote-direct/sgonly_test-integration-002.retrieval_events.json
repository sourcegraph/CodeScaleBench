        "new_string": "// Mock implementations for testing\n\ntype mockPlaylists struct{}\n\nfunc (mp *mockPlaylists) ImportFile(ctx context.Context, dir string, fname string) (*model.Playlist, error) {\n\treturn nil, nil\n}\n\ntype mockCacheWarmer struct{}\n\nfunc (mcw *mockCacheWarmer) WarmCache(ctx context.Context) error {\n\treturn nil\n}\n\nfunc (mcw *mockCacheWarmer) Cache(ctx context.Context, artwork ...model.ArtworkID) error {\n\treturn nil\n}\n\nfunc (mcw *mockCacheWarmer) PreCache(artwork ...model.ArtworkID) error {\n\treturn nil\n}\n\n// ExtendedMockMediaFileRepo extends MockMediaFileRepo with scanner-required methods\ntype ExtendedMockMediaFileRepo struct {\n\t*tests.MockMediaFileRepo\n\tpaths map[string]struct{}\n}\n\nfunc NewExtendedMockMediaFileRepo() *ExtendedMockMediaFileRepo {\n\treturn &ExtendedMockMediaFileRepo{\n\t\tMockMediaFileRepo: tests.CreateMockMediaFileRepo(),\n\t\tpaths:             make(map[string]struct{}),\n\t}\n}\n\nfunc (m *ExtendedMockMediaFileRepo) Put(mf *model.MediaFile) error {\n\tif mf.Path != \"\" {\n\t\tm.paths[mf.Path] = struct{}{}\n\t}\n\treturn m.MockMediaFileRepo.Put(mf)\n}\n\nfunc (m *ExtendedMockMediaFileRepo) FindPathsRecursively(basePath string) ([]string, error) {\n\t// Return all paths that start with basePath\n\tvar result []string\n\tfor path := range m.paths {\n\t\tif strings.HasPrefix(path, basePath) {\n\t\t\tresult = append(result, filepath.Dir(path))\n\t\t}\n\t}\n\treturn result, nil\n}\n\nfunc (m *ExtendedMockMediaFileRepo) FindAllByPath(path string) (model.MediaFiles, error) {\n\tvar result model.MediaFiles\n\tall, _ := m.MockMediaFileRepo.GetAll()\n\tfor _, mf := range all {\n\t\tif strings.HasPrefix(mf.Path, path) {\n\t\t\tresult = append(result, mf)\n\t\t}\n\t}\n\treturn result, nil\n}\n\nfunc (m *ExtendedMockMediaFileRepo) FindByPath(path string) (*model.MediaFile, error) {\n\tall, _ := m.MockMediaFileRepo.GetAll()\n\tfor _, mf := range all {\n\t\tif mf.Path == path {\n\t\t\treturn &mf, nil\n\t\t}\n\t}\n\treturn nil, model.ErrNotFound\n}\n\nfunc (m *ExtendedMockMediaFileRepo) FindByPaths(paths []string) (model.MediaFiles, error) {\n\tpathMap := make(map[string]struct{})\n\tfor _, p := range paths {\n\t\tpathMap[p] = struct{}{}\n\t}\n\tvar result model.MediaFiles\n\tall, _ := m.MockMediaFileRepo.GetAll()\n\tfor _, mf := range all {\n\t\tif _, ok := pathMap[mf.Path]; ok {\n\t\t\tresult = append(result, mf)\n\t\t}\n\t}\n\treturn result, nil\n}\n\nfunc (m *ExtendedMockMediaFileRepo) DeleteByPath(path string) (int64, error) {\n\tall, _ := m.MockMediaFileRepo.GetAll()\n\tcount := int64(0)\n\tfor _, mf := range all {\n\t\tif strings.HasPrefix(mf.Path, path) {\n\t\t\t_ = m.MockMediaFileRepo.Delete(mf.ID)\n\t\t\tdelete(m.paths, mf.Path)\n\t\t\tcount++\n\t\t}\n\t}\n\treturn count, nil\n}\n\nfunc (m *ExtendedMockMediaFileRepo) Delete(id string) error {\n\tmf, _ := m.MockMediaFileRepo.Get(id)\n\tif mf != nil {\n\t\tdelete(m.paths, mf.Path)\n\t}\n\treturn m.MockMediaFileRepo.Delete(id)\n}\n\n// Implement remaining interface methods as no-ops or with reasonable defaults\nfunc (m *ExtendedMockMediaFileRepo) CountAll(options ...model.QueryOptions) (int64, error) {\n\tall, _ := m.GetAll()\n\treturn int64(len(all)), nil\n}\n\nfunc (m *ExtendedMockMediaFileRepo) Search(q string, offset int, size int) (model.MediaFiles, error) {\n\treturn model.MediaFiles{}, nil\n}\n\n// Helper to suppress log output during tests\nfunc init() {\n\tlog.SetLevel(log.LevelFatal)\n}",
