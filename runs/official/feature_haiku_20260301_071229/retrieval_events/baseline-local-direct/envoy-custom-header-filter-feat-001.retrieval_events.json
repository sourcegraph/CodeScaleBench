        "old_string": "#include \"source/extensions/filters/http/custom_header_injection/filter.h\"\n\n#include \"envoy/extensions/filters/http/custom_header_injection/v3/custom_header_injection.pb.h\"\n#include \"source/common/http/header_utility.h\"\n\nnamespace Envoy {\nnamespace Extensions {\nnamespace HttpFilters {\nnamespace CustomHeaderInjection {\n\nFilterConfig::FilterConfig(const ProtoConfig& config) : config_(config) {}\n\nCustomHeaderInjectionFilter::CustomHeaderInjectionFilter(FilterConfigSharedPtr config)\n    : config_(std::move(config)) {}\n\nHttp::FilterHeadersStatus CustomHeaderInjectionFilter::decodeHeaders(Http::RequestHeaderMap& headers,\n                                                                    bool) {\n  // Inject request headers\n  for (const auto& header_to_add : config_->config().request_headers_to_add()) {\n    Http::HeaderUtility::addHeader(headers, header_to_add);\n  }\n  return Http::FilterHeadersStatus::Continue;\n}\n\nHttp::FilterHeadersStatus CustomHeaderInjectionFilter::encodeHeaders(Http::ResponseHeaderMap& headers,\n                                                                    bool) {\n  // Inject response headers\n  for (const auto& header_to_add : config_->config().response_headers_to_add()) {\n    Http::HeaderUtility::addHeader(headers, header_to_add);\n  }\n  return Http::FilterHeadersStatus::Continue;\n}\n\n} // namespace CustomHeaderInjection\n} // namespace HttpFilters\n} // namespace Extensions\n} // namespace Envoy",
        "new_string": "#include \"source/extensions/filters/http/custom_header_injection/filter.h\"\n\n#include \"envoy/extensions/filters/http/custom_header_injection/v3/custom_header_injection.pb.h\"\n\nnamespace Envoy {\nnamespace Extensions {\nnamespace HttpFilters {\nnamespace CustomHeaderInjection {\n\nFilterConfig::FilterConfig(const ProtoConfig& config) : config_(config) {}\n\nCustomHeaderInjectionFilter::CustomHeaderInjectionFilter(FilterConfigSharedPtr config)\n    : config_(std::move(config)) {}\n\nHttp::FilterHeadersStatus CustomHeaderInjectionFilter::decodeHeaders(Http::RequestHeaderMap& headers,\n                                                                    bool) {\n  // Inject request headers\n  for (const auto& header_to_add : config_->config().request_headers_to_add()) {\n    const auto& header_key = Http::LowerCaseString(header_to_add.header().key());\n    const auto& header_value = header_to_add.header().value();\n    headers.setCopy(header_key, header_value);\n  }\n  return Http::FilterHeadersStatus::Continue;\n}\n\nHttp::FilterHeadersStatus CustomHeaderInjectionFilter::encodeHeaders(Http::ResponseHeaderMap& headers,\n                                                                    bool) {\n  // Inject response headers\n  for (const auto& header_to_add : config_->config().response_headers_to_add()) {\n    const auto& header_key = Http::LowerCaseString(header_to_add.header().key());\n    const auto& header_value = header_to_add.header().value();\n    headers.setCopy(header_key, header_value);\n  }\n  return Http::FilterHeadersStatus::Continue;\n}\n\n} // namespace CustomHeaderInjection\n} // namespace HttpFilters\n} // namespace Extensions\n} // namespace Envoy",
