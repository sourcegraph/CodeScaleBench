        "old_string": "def _sum(a, axis=None, dtype=None, out=None, keepdims=False,\n         initial=_NoValue, where=True):\n    return umr_sum(a, axis, dtype, out, keepdims, initial, where)",
        "new_string": "def _sum(a, axis=None, dtype=None, out=None, keepdims=False,\n         initial=_NoValue, where=True):\n    # Use einsum for optimized summation when possible\n    # Fall back to umr_sum for complex cases\n\n    # If we have a where mask or initial value, use the original reduce\n    # because einsum doesn't support these parameters\n    if where is not True or initial is not _NoValue:\n        return umr_sum(a, axis, dtype, out, keepdims, initial, where)\n\n    try:\n        # Use einsum for efficient summation across axes\n        # Build the einsum string dynamically based on axes\n        a_arr = asanyarray(a)\n\n        if axis is None:\n            # Sum all elements\n            result = np.einsum('...', a_arr)\n        else:\n            # Normalize axis\n            if isinstance(axis, int):\n                axes = (axis,) if axis >= 0 else (a_arr.ndim + axis,)\n            else:\n                axes = tuple(ax if ax >= 0 else a_arr.ndim + ax for ax in axis)\n\n            # Generate einsum subscripts\n            all_chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ'\n            if a_arr.ndim > len(all_chars):\n                # Fall back if array has too many dimensions\n                raise ValueError(\"Array has too many dimensions for einsum optimization\")\n\n            input_subscript = ''.join(all_chars[i] for i in range(a_arr.ndim))\n\n            # Create output subscript by excluding reduced axes\n            output_subscript = ''.join(\n                all_chars[i] for i in range(a_arr.ndim)\n                if i not in axes\n            )\n\n            # Perform einsum\n            einsum_str = f'{input_subscript}->{output_subscript}'\n            result = np.einsum(einsum_str, a_arr, optimize=True)\n\n            # Handle keepdims\n            if keepdims:\n                new_shape = list(a_arr.shape)\n                for ax in axes:\n                    new_shape[ax] = 1\n                result = result.reshape(new_shape)\n\n        # Convert dtype if specified\n        if dtype is not None:\n            result = result.astype(dtype, copy=False)\n\n        # Handle out parameter\n        if out is not None:\n            out[...] = result\n            return out\n\n        return result\n    except Exception:\n        # Fall back to original reduce on any error\n        return umr_sum(a, axis, dtype, out, keepdims, initial, where)",
        "replace_all": false
