        "old_string": "\treturn nil\n}",
        "new_string": "\treturn nil\n}\n\n// EndpointRegenerator handles the regeneration of all endpoints.\ntype EndpointRegenerator struct {\n\t// endpointGetter is a function to retrieve all endpoints\n\tendpointGetter func() []*Endpoint\n\tlogger         logrus.FieldLogger\n}\n\n// NewEndpointRegenerator creates a new EndpointRegenerator.\nfunc NewEndpointRegenerator(endpointGetter func() []*Endpoint) *EndpointRegenerator {\n\treturn &EndpointRegenerator{\n\t\tendpointGetter: endpointGetter,\n\t\tlogger:         logging.DefaultLogger.WithField(logfields.LogSubsys, \"endpoint-manager\"),\n\t}\n}\n\n// RegenerateAllEndpoints calls a setState for each endpoint and\n// regenerates if state transaction is valid. During this process, the endpoint\n// list is locked and cannot be modified.\n// Returns a waiting group that can be used to know when all the endpoints are\n// regenerated.\nfunc (er *EndpointRegenerator) RegenerateAllEndpoints(regenMetadata *regeneration.ExternalRegenerationMetadata) *sync.WaitGroup {\n\tvar wg sync.WaitGroup\n\n\teps := er.endpointGetter()\n\twg.Add(len(eps))\n\n\t// Dereference \"reason\" field outside of logging statement; see\n\t// https://github.com/sirupsen/logrus/issues/1003.\n\treason := regenMetadata.Reason\n\ter.logger.WithFields(logrus.Fields{\"reason\": reason}).Info(\"regenerating all endpoints\")\n\tfor _, ep := range eps {\n\t\tgo func(ep *Endpoint) {\n\t\t\t<-ep.RegenerateIfAlive(regenMetadata)\n\t\t\twg.Done()\n\t\t}(ep)\n\t}\n\n\treturn &wg\n}",
        "replace_all": false
