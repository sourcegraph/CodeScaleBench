        "file_path": "/workspace/repo/numpy/_core/_methods.py",
        "old_string": "def _sum(a, axis=None, dtype=None, out=None, keepdims=False,\n         initial=_NoValue, where=True):\n    return umr_sum(a, axis, dtype, out, keepdims, initial, where)",
        "new_string": "def _sum(a, axis=None, dtype=None, out=None, keepdims=False,\n         initial=_NoValue, where=True):\n    # Optimization: use einsum for efficient summation in common cases\n    if where is True and initial is _NoValue and out is None:\n        arr = asanyarray(a)\n\n        if axis is None:\n            # Sum all elements using einsum\n            result = np.einsum('...->',arr)\n            if dtype is not None:\n                result = result.astype(dtype, copy=False)\n            if keepdims:\n                result = result.reshape((1,) * arr.ndim)\n            return result\n        else:\n            # Normalize axis\n            if isinstance(axis, int):\n                axis = (axis,)\n            if isinstance(axis, tuple):\n                ndim = arr.ndim\n                # Normalize negative axes\n                axis = tuple(ax % ndim if ax < 0 else ax for ax in axis)\n                # Create einsum string for summation\n                axes_in = [chr(ord('a') + i) for i in range(ndim)]\n                axes_out = [axes_in[i] for i in range(ndim) if i not in axis]\n                einsum_str = ''.join(axes_in) + '->' + ''.join(axes_out)\n                result = np.einsum(einsum_str, arr, optimize=True)\n\n                if dtype is not None:\n                    result = result.astype(dtype, copy=False)\n                if keepdims:\n                    # Expand dimensions that were reduced\n                    shape = list(arr.shape)\n                    for ax in sorted(axis):\n                        shape[ax] = 1\n                    result = result.reshape(shape)\n                return result\n\n    # Fall back to original implementation for complex cases\n    return umr_sum(a, axis, dtype, out, keepdims, initial, where)",
        "replace_all": false
      },
