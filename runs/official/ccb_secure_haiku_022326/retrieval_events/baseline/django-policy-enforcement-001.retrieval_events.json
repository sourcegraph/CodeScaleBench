        "new_string": "class EmptyManager(Manager):\n    def __init__(self, model):\n        super().__init__()\n        self.model = model\n\n    def get_queryset(self):\n        return super().get_queryset().none()\n\n\nclass SoftDeleteManager(Manager):\n    \"\"\"\n    A custom manager that provides bulk soft-delete functionality.\n\n    Soft-deletion marks records as deleted without removing them from the database,\n    allowing for audit compliance and record recovery.\n    \"\"\"\n\n    def bulk_soft_delete(\n        self,\n        queryset_or_ids: Union[QuerySet, Iterable[Any]],\n        deleted_by: Optional[str] = None,\n    ) -> int:\n        \"\"\"\n        Soft-delete multiple records by marking them as deleted.\n\n        This method marks records with a deletion timestamp without actually\n        removing them from the database. Records can be restored using bulk_restore().\n\n        Args:\n            queryset_or_ids: Either a QuerySet or an iterable of primary keys\n                           to soft-delete.\n            deleted_by: Optional string to record who performed the deletion\n                       (e.g., username or user ID). If provided, will be stored\n                       in the deleted_by field if the model has one.\n\n        Returns:\n            The number of records that were soft-deleted.\n\n        Example:\n            # Delete all inactive users\n            count = User.soft_delete_objects.bulk_soft_delete(\n                User.objects.filter(is_active=False),\n                deleted_by='admin_user'\n            )\n\n            # Delete by IDs\n            count = User.soft_delete_objects.bulk_soft_delete([1, 2, 3])\n        \"\"\"\n        # Convert IDs to queryset if needed\n        if not isinstance(queryset_or_ids, QuerySet):\n            queryset = self.get_queryset().filter(pk__in=queryset_or_ids)\n        else:\n            queryset = queryset_or_ids\n\n        # Prepare the update values\n        update_values = {\n            \"is_deleted\": True,\n            \"deleted_at\": timezone.now(),\n        }\n\n        # Add deleted_by if provided and model supports it\n        if deleted_by is not None and hasattr(self.model, \"deleted_by\"):\n            update_values[\"deleted_by\"] = deleted_by\n\n        # Perform the bulk update\n        return queryset.update(**update_values)\n\n    bulk_soft_delete.alters_data = True\n\n    def bulk_restore(\n        self,\n        queryset_or_ids: Union[QuerySet, Iterable[Any]],\n    ) -> int:\n        \"\"\"\n        Restore (undo) soft-deleted records.\n\n        This method removes the deletion flag and timestamp from soft-deleted\n        records, effectively restoring them.\n\n        Args:\n            queryset_or_ids: Either a QuerySet or an iterable of primary keys\n                           to restore.\n\n        Returns:\n            The number of records that were restored.\n\n        Example:\n            # Restore all soft-deleted users\n            count = User.soft_delete_objects.bulk_restore(\n                User.soft_delete_objects.filter(is_deleted=True)\n            )\n\n            # Restore by IDs\n            count = User.soft_delete_objects.bulk_restore([1, 2, 3])\n        \"\"\"\n        # Convert IDs to queryset if needed\n        if not isinstance(queryset_or_ids, QuerySet):\n            queryset = self.get_queryset().filter(pk__in=queryset_or_ids)\n        else:\n            queryset = queryset_or_ids\n\n        # Prepare the update values\n        update_values = {\n            \"is_deleted\": False,\n            \"deleted_at\": None,\n        }\n\n        # Clear deleted_by if model supports it\n        if hasattr(self.model, \"deleted_by\"):\n            update_values[\"deleted_by\"] = None\n\n        # Perform the bulk update\n        return queryset.update(**update_values)\n\n    bulk_restore.alters_data = True",
