        "old_string": "class EmptyManager(Manager):\n    def __init__(self, model):\n        super().__init__()\n        self.model = model\n\n    def get_queryset(self):\n        return super().get_queryset().none()",
        "new_string": "class EmptyManager(Manager):\n    def __init__(self, model):\n        super().__init__()\n        self.model = model\n\n    def get_queryset(self):\n        return super().get_queryset().none()\n\n\nclass SoftDeleteManager(Manager):\n    \"\"\"\n    A custom manager that provides bulk soft-delete functionality.\n\n    This manager marks records as deleted without removing them from the database,\n    allowing for audit compliance and record recovery.\n    \"\"\"\n\n    def bulk_soft_delete(\n        self,\n        queryset_or_ids: Union[QuerySet, Iterable],\n        deleted_by: Optional[str] = None,\n    ) -> int:\n        \"\"\"\n        Perform a bulk soft-deletion by marking records as deleted.\n\n        Marks matching records with a deleted flag and timestamp using ORM\n        update operations. This method preserves the deleted records in the\n        database for audit purposes.\n\n        Args:\n            queryset_or_ids: Either a QuerySet or an iterable of primary keys\n                to soft-delete. If a QuerySet is provided, all records matching\n                the queryset will be soft-deleted. If an iterable is provided,\n                records with primary keys in the iterable will be soft-deleted.\n            deleted_by: Optional string parameter to record who performed the\n                deletion. This is stored as a metadata field and can be used\n                for audit trails.\n\n        Returns:\n            The count of records that were soft-deleted.\n\n        Raises:\n            AttributeError: If the model does not have 'deleted' or\n                'deleted_at' fields.\n        \"\"\"\n        if isinstance(queryset_or_ids, QuerySet):\n            qs = queryset_or_ids\n        else:\n            qs = self.filter(pk__in=queryset_or_ids)\n\n        # Verify that the model has the required fields\n        if not hasattr(self.model, \"deleted\"):\n            raise AttributeError(\n                f\"Model {self.model.__name__} does not have a 'deleted' field\"\n            )\n        if not hasattr(self.model, \"deleted_at\"):\n            raise AttributeError(\n                f\"Model {self.model.__name__} does not have a 'deleted_at' field\"\n            )\n\n        # Use ORM update to mark records as deleted\n        update_data = {\n            \"deleted\": True,\n            \"deleted_at\": now(),\n        }\n\n        # If deleted_by is provided, store it in a metadata field\n        if deleted_by is not None and hasattr(self.model, \"deleted_by\"):\n            update_data[\"deleted_by\"] = deleted_by\n\n        return qs.update(**update_data)\n\n    def bulk_restore(\n        self,\n        queryset_or_ids: Union[QuerySet, Iterable],\n    ) -> int:\n        \"\"\"\n        Restore (undo) soft-deleted records.\n\n        Marks soft-deleted records as active again by clearing the deleted\n        flag and timestamp. This allows recovery of previously soft-deleted\n        records.\n\n        Args:\n            queryset_or_ids: Either a QuerySet or an iterable of primary keys\n                to restore. If a QuerySet is provided, all soft-deleted records\n                matching the queryset will be restored. If an iterable is\n                provided, soft-deleted records with primary keys in the iterable\n                will be restored.\n\n        Returns:\n            The count of records that were restored.\n\n        Raises:\n            AttributeError: If the model does not have 'deleted' or\n                'deleted_at' fields.\n        \"\"\"\n        if isinstance(queryset_or_ids, QuerySet):\n            qs = queryset_or_ids\n        else:\n            qs = self.filter(pk__in=queryset_or_ids)\n\n        # Verify that the model has the required fields\n        if not hasattr(self.model, \"deleted\"):\n            raise AttributeError(\n                f\"Model {self.model.__name__} does not have a 'deleted' field\"\n            )\n        if not hasattr(self.model, \"deleted_at\"):\n            raise AttributeError(\n                f\"Model {self.model.__name__} does not have a 'deleted_at' field\"\n            )\n\n        # Use ORM update to restore records\n        update_data = {\n            \"deleted\": False,\n            \"deleted_at\": None,\n        }\n\n        # Clear the deleted_by field if it exists\n        if hasattr(self.model, \"deleted_by\"):\n            update_data[\"deleted_by\"] = None\n\n        return qs.update(**update_data)",
