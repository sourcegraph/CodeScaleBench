        "new_string": "    def cleanup(self) -> None:\n        # There is a reference cycle between tracer and OutputGraph, causing\n        # some of the tensor objects to be held alive for longer than necessary.\n        self.root_tx = None  # type: ignore[assignment]\n        self.nn_modules.clear()\n        self.param_name_to_source = None\n\n        for node in self.graph.nodes:\n            if \"grapharg\" in node.meta:\n                del node.meta[\"grapharg\"]\n        self.real_value_cache.clear()\n        self.input_name_to_proxy.clear()\n        self.side_effects.clear()\n        self.variable_tracker_cache.clear()\n        self.register_finalizer_fns.clear()\n        self.dynamo_flat_name_to_original_fqn.clear()\n        self.tracing_context.clear()\n        self.input_source_to_var.clear()\n        self.unspec_variable_map.clear()\n        self.backward_state.clear()\n\n    def cleanup_on_failed_trace(self) -> None:\n        \"\"\"\n        Cleanup graphs from failed dynamo tracer outputs to break reference cycles.\n\n        These graphs hold onto reference cycles:\n        1. The nodes of the graph form a doubly linked list and point back to the graph\n        2. FakeTensorMode \u2192 ShapeEnv \u2192 TrackedFake \u2192 FakeTensor \u2192 FakeTensorMode\n\n        Manually cleaning up these reference cycles allows for immediate garbage collection\n        without needing a full GC pass.\n        \"\"\"\n        # Break the doubly-linked list cycle in graph nodes\n        for node in self.graph.nodes:\n            # Clear the linked list pointers to break the cycle\n            node._prev = None  # type: ignore[attr-defined]\n            node._next = None  # type: ignore[attr-defined]\n\n        # Break the FakeTensorMode \u2192 ShapeEnv \u2192 TrackedFake \u2192 FakeTensor \u2192 FakeTensorMode cycle\n        # by clearing the tracked_fakes reference in shape_env\n        try:\n            shape_env = self.shape_env\n            if shape_env is not None and hasattr(shape_env, 'tracked_fakes'):\n                shape_env.tracked_fakes = None  # type: ignore[assignment]\n        except Exception:\n            # If we can't access shape_env, just continue\n            pass\n\n    def add_graph_finalizer(",
