        "file_path": "/logs/agent/solution.md",
        "old_string": "## Proposed Fix\n\n```diff\n--- a/clients/src/main/java/org/apache/kafka/clients/producer/internals/Sender.java\n+++ b/clients/src/main/java/org/apache/kafka/clients/producer/internals/Sender.java\n@@ -170,9 +170,20 @@ public class Sender implements Runnable {\n     }\n\n     private void maybeRemoveAndDeallocateBatch(ProducerBatch batch) {\n+        // Check if the batch is in the inflight batches list\n+        List<ProducerBatch> inflight = inFlightBatches.get(batch.topicPartition);\n+        boolean wasInFlight = inflight != null && inflight.remove(batch);\n+\n         maybeRemoveFromInflightBatches(batch);\n-        this.accumulator.deallocate(batch);\n+\n+        // Only deallocate if the batch was NOT in-flight. If it was in-flight,\n+        // the buffer is still being transmitted by the network layer, so defer\n+        // deallocation to the response handler.\n+        if (!wasInFlight) {\n+            this.accumulator.deallocate(batch);\n+        }\n     }\n\n     /**\n      *  Get the in-flight batches that has reached delivery timeout.\n\n@@ -744,8 +755,10 @@ public class Sender implements Runnable {\n     private void completeBatch(ProducerBatch batch, ProduceResponse.PartitionResponse response) {\n         if (transactionManager != null) {\n             transactionManager.handleCompletedBatch(batch, response);\n         }\n\n-        if (batch.complete(response.baseOffset, response.logAppendTime)) {\n+        batch.complete(response.baseOffset, response.logAppendTime);\n+        // Always deallocate when handling response, even if batch was already failed\n+        if (!inFlightBatches.getOrDefault(batch.topicPartition, Collections.emptyList()).contains(batch)) {\n             maybeRemoveAndDeallocateBatch(batch);\n         }\n     }\n```",
        "new_string": "## Proposed Fix\n\n```diff\n--- a/clients/src/main/java/org/apache/kafka/clients/producer/internals/Sender.java\n+++ b/clients/src/main/java/org/apache/kafka/clients/producer/internals/Sender.java\n@@ -170,9 +170,21 @@ public class Sender implements Runnable {\n     }\n\n     private void maybeRemoveAndDeallocateBatch(ProducerBatch batch) {\n+        // Check if the batch is currently in-flight before removing it\n+        List<ProducerBatch> inflightBatches = inFlightBatches.get(batch.topicPartition);\n+        boolean isInflight = inflightBatches != null && inflightBatches.contains(batch);\n+\n         maybeRemoveFromInflightBatches(batch);\n-        this.accumulator.deallocate(batch);\n+\n+        // Only deallocate the buffer if the batch is NOT in-flight.\n+        // If it was in-flight (being transmitted), defer deallocation because the\n+        // network layer may still be serializing the request using this buffer.\n+        // The deallocation will happen in the response handler after transmission completes.\n+        if (!isInflight) {\n+            this.accumulator.deallocate(batch);\n+        }\n     }\n\n     /**\n      *  Get the in-flight batches that has reached delivery timeout.\n\n@@ -744,9 +756,10 @@ public class Sender implements Runnable {\n     private void completeBatch(ProducerBatch batch, ProduceResponse.PartitionResponse response) {\n         if (transactionManager != null) {\n             transactionManager.handleCompletedBatch(batch, response);\n         }\n\n-        if (batch.complete(response.baseOffset, response.logAppendTime)) {\n+        batch.complete(response.baseOffset, response.logAppendTime);\n+        // Always deallocate when response is received, even if batch was already failed.\n+        // This ensures deferred deallocations from failBatch() are completed.\n+        if (batch.complete(response.baseOffset, response.logAppendTime)) {\n             maybeRemoveAndDeallocateBatch(batch);\n         }\n     }\n```",
