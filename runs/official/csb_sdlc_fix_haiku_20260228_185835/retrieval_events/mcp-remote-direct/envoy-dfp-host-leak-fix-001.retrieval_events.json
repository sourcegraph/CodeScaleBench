      "arguments": {
        "file_path": "/workspace/source/extensions/clusters/dynamic_forward_proxy/cluster.cc",
        "old_string": "void Cluster::addOrUpdateHost(\n    absl::string_view host,\n    const Extensions::Common::DynamicForwardProxy::DnsHostInfoSharedPtr& host_info) {\n  Upstream::HostVector hosts_added;\n  Upstream::HostVector hosts_removed;\n\n  {\n    absl::WriterMutexLock lock{&host_map_lock_};\n\n    const auto host_map_it = host_map_.find(host);\n    if (host_map_it != host_map_.end()) {\n      // Host exists. Check if address has changed.\n      if (host_info->address() != host_map_it->second.logical_host_->address()) {\n        // Address changed. Remove old host and create a new one.\n        ENVOY_LOG(debug, \"updating dfproxy cluster host address '{}' - removing old and adding new\",\n                  host);\n        hosts_removed.emplace_back(host_map_it->second.logical_host_);\n        host_map_.erase(host_map_it);\n\n        // Create new host with new address\n        auto emplaced_host =\n            host_map_\n                .try_emplace(host, host_info,\n                             std::make_shared<Upstream::LogicalHost>(\n                                 info(), std::string{host}, host_info->address(),\n                                 host_info->addressList(), dummy_locality_lb_endpoint_,\n                                 dummy_lb_endpoint_, nullptr, time_source_))\n                .first->second.logical_host_;\n        hosts_added.emplace_back(emplaced_host);\n      } else {\n        // Address is the same, no update needed\n        return;\n      }\n    } else {\n      // New host\n      ENVOY_LOG(debug, \"adding new dfproxy cluster host '{}'\", host);\n      auto emplaced_host =\n          host_map_\n              .try_emplace(host, host_info,\n                           std::make_shared<Upstream::LogicalHost>(\n                               info(), std::string{host}, host_info->address(),\n                               host_info->addressList(), dummy_locality_lb_endpoint_,\n                               dummy_lb_endpoint_, nullptr, time_source_))\n              .first->second.logical_host_;\n      hosts_added.emplace_back(emplaced_host);\n    }\n  }\n\n  // Update priority state outside the lock\n  updatePriorityState(hosts_added, hosts_removed);\n}",
        "new_string": "void Cluster::addOrUpdateHost(\n    absl::string_view host,\n    const Extensions::Common::DynamicForwardProxy::DnsHostInfoSharedPtr& host_info) {\n  Upstream::HostVector hosts_added;\n  Upstream::HostVector hosts_removed;\n\n  {\n    absl::WriterMutexLock lock{&host_map_lock_};\n\n    const auto host_map_it = host_map_.find(host);\n    if (host_map_it != host_map_.end()) {\n      // Host exists. Check if address has changed.\n      if (host_info->address() != host_map_it->second.logical_host_->address()) {\n        // Address changed. Remove old host and create a new one.\n        ENVOY_LOG(debug, \"updating dfproxy cluster host address '{}' - removing old and adding new\",\n                  host);\n        hosts_removed.emplace_back(host_map_it->second.logical_host_);\n        host_map_.erase(host_map_it);\n\n        // Create new host with new address\n        auto emplaced_host =\n            host_map_\n                .try_emplace(host, host_info,\n                             std::make_shared<Upstream::LogicalHost>(\n                                 info(), std::string{host}, host_info->address(),\n                                 host_info->addressList(), dummy_locality_lb_endpoint_,\n                                 dummy_lb_endpoint_, nullptr, time_source_))\n                .first->second.logical_host_;\n        hosts_added.emplace_back(emplaced_host);\n      } else {\n        // Address is the same, no update needed\n        return;\n      }\n    } else {\n      // New host\n      ENVOY_LOG(debug, \"adding new dfproxy cluster host '{}'\", host);\n      auto emplaced_host =\n          host_map_\n              .try_emplace(host, host_info,\n                           std::make_shared<Upstream::LogicalHost>(\n                               info(), std::string{host}, host_info->address(),\n                               host_info->addressList(), dummy_locality_lb_endpoint_,\n                               dummy_lb_endpoint_, nullptr, time_source_))\n              .first->second.logical_host_;\n      hosts_added.emplace_back(emplaced_host);\n    }\n  }\n\n  // Update priority state outside the lock\n  // For address changes, emit removal first, then addition as separate events\n  if (!hosts_removed.empty()) {\n    updatePriorityState({}, hosts_removed);\n    updatePriorityState(hosts_added, {});\n  } else if (!hosts_added.empty()) {\n    updatePriorityState(hosts_added, {});\n  }\n}",
        "replace_all": false
      },
