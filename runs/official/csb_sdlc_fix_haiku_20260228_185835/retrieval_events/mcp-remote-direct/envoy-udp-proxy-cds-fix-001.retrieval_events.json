        "old_string": "  filter_.reset();\n  EXPECT_EQ(output_.size(), 1);\n  EXPECT_THAT(output_.front(), testing::HasSubstr(\"session_complete\"));\n}\n\nclass HttpUpstreamImplTest : public testing::Test {",
        "new_string": "  filter_.reset();\n  EXPECT_EQ(output_.size(), 1);\n  EXPECT_THAT(output_.front(), testing::HasSubstr(\"session_complete\"));\n}\n\n// Test that cluster info map is properly updated when a cluster is updated via CDS.\nTEST_F(UdpProxyFilterTest, ClusterDynamicInfoMapUpdate) {\n  InSequence s;\n\n  setup(readConfig(R\"EOF(\nstat_prefix: foo\nmatcher:\n  on_no_match:\n    action:\n      name: route\n      typed_config:\n        '@type': type.googleapis.com/envoy.extensions.filters.udp.udp_proxy.v3.Route\n        cluster: fake_cluster\n)EOF\"));\n\n  // Verify that the cluster info was initialized in the constructor.\n  EXPECT_EQ(1, filter_->cluster_infos_.size());\n  auto initial_cluster_info = filter_->cluster_infos_[\"fake_cluster\"].get();\n  EXPECT_NE(nullptr, initial_cluster_info);\n\n  // Simulate a cluster update by calling onClusterAddOrUpdate with the same cluster name\n  // but a new ThreadLocalCluster instance. This would happen during dynamic cluster updates.\n  // The old implementation would use emplace() which fails silently when the key already exists,\n  // leaving a stale pointer. The fixed implementation should use insert_or_assign() to replace it.\n  Upstream::ThreadLocalClusterCommand updated_cluster_command = [this]() -> Upstream::ThreadLocalCluster& {\n    return factory_context_.server_factory_context_.cluster_manager_.thread_local_cluster_;\n  };\n\n  filter_->onClusterAddOrUpdate(\"fake_cluster\", updated_cluster_command);\n\n  // After the update, the map should still have exactly one entry for the cluster.\n  EXPECT_EQ(1, filter_->cluster_infos_.size());\n\n  // The cluster info should now point to the new/updated cluster, not the old one.\n  // With the buggy emplace() implementation, this would fail because the old entry would\n  // remain. With insert_or_assign(), the entry is replaced.\n  auto updated_cluster_info = filter_->cluster_infos_[\"fake_cluster\"].get();\n  EXPECT_NE(nullptr, updated_cluster_info);\n\n  // Verify we can still process data with the updated cluster info.\n  expectSessionCreate(upstream_address_);\n  test_sessions_[0].expectWriteToUpstream(\"hello\", 0, nullptr, true);\n  recvDataFromDownstream(\"10.0.0.1:1000\", \"10.0.0.2:80\", \"hello\");\n}\n\nclass HttpUpstreamImplTest : public testing::Test {",
        "replace_all": false
      },
