-            return x - 1
-
-        def pattern2(x: torch.Tensor) -> torch.Tensor:
-            return x + 2
-
-        def replacement2(x: torch.Tensor) -> torch.Tensor:
-            return x - 2
-
-        patterns = PatternMatcherPass()
