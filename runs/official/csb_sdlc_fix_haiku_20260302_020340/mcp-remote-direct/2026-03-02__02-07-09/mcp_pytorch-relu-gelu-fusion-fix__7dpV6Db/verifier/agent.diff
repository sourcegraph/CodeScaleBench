+ def register_noop_decomp(targets, nop_arg=0):
+     def register_fun(cond):
+         register_decomposition(targets, registry=noop_registry, unsafe=True)(
+             (cond, nop_arg)  # type: ignore[arg-type]
+         )
+         return cond
+ 
+     return register_fun
+ 
