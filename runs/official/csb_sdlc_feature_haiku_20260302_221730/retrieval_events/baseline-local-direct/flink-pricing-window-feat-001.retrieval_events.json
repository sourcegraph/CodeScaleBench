        "file_path": "/workspace/flink-streaming-java/src/main/java/org/apache/flink/streaming/api/windowing/assigners/PricingSessionWindow.java",
        "old_string": "    @Override\n    public Collection<TimeWindow> assignWindows(\n            Object element, long timestamp, WindowAssignerContext context) {\n        // Convert timestamp to the market's timezone\n        ZonedDateTime zonedDateTime = Instant.ofEpochMilli(timestamp).atZone(timezone);\n        LocalDateTime localDateTime = zonedDateTime.toLocalDateTime();\n        LocalTime timeOfDay = localDateTime.toLocalTime();\n        LocalDate date = localDateTime.toLocalDate();\n\n        // Determine which session this timestamp belongs to\n        LocalDateTime sessionStartDateTime;\n        LocalDateTime sessionEndDateTime;\n\n        if (isOvernightSession()) {\n            // For overnight sessions (e.g., close >= open), e.g. 18:00 to 09:00 next day\n            if (timeOfDay.isBefore(sessionClose)) {\n                // We're in the early morning part of an overnight session\n                // Session started yesterday\n                sessionStartDateTime = LocalDateTime.of(date.minusDays(1), sessionOpen);\n                sessionEndDateTime = LocalDateTime.of(date, sessionClose);\n            } else if (timeOfDay.isBefore(sessionOpen) || timeOfDay.equals(sessionOpen)) {\n                // Before session open on the same day - not in a session\n                // Return a window for the previous session that ended\n                sessionStartDateTime = LocalDateTime.of(date.minusDays(1), sessionOpen);\n                sessionEndDateTime = LocalDateTime.of(date, sessionClose);\n            } else {\n                // We're in the main trading period of an overnight session\n                sessionStartDateTime = LocalDateTime.of(date, sessionOpen);\n                sessionEndDateTime = LocalDateTime.of(date.plusDays(1), sessionClose);\n            }\n        } else {\n            // For regular sessions (e.g., open < close like 09:30 to 16:00)\n            if (timeOfDay.isBefore(sessionOpen)) {\n                // Before session opens - use yesterday's session\n                sessionStartDateTime = LocalDateTime.of(date.minusDays(1), sessionOpen);\n                sessionEndDateTime = LocalDateTime.of(date.minusDays(1), sessionClose);\n            } else if (timeOfDay.isBefore(sessionClose) || timeOfDay.equals(sessionOpen)) {\n                // During session\n                sessionStartDateTime = LocalDateTime.of(date, sessionOpen);\n                sessionEndDateTime = LocalDateTime.of(date, sessionClose);\n            } else {\n                // After session close - use today's session\n                sessionStartDateTime = LocalDateTime.of(date, sessionOpen);\n                sessionEndDateTime = LocalDateTime.of(date, sessionClose);\n            }\n        }\n\n        // Convert back to UTC milliseconds\n        long sessionStartMillis = sessionStartDateTime.atZone(timezone).toInstant().toEpochMilli();\n        long sessionEndMillis = sessionEndDateTime.atZone(timezone).toInstant().toEpochMilli();\n\n        return Collections.singletonList(new TimeWindow(sessionStartMillis, sessionEndMillis));\n    }",
        "new_string": "    @Override\n    public Collection<TimeWindow> assignWindows(\n            Object element, long timestamp, WindowAssignerContext context) {\n        // Convert timestamp to the market's timezone\n        ZonedDateTime zonedDateTime = Instant.ofEpochMilli(timestamp).atZone(timezone);\n        LocalDateTime localDateTime = zonedDateTime.toLocalDateTime();\n        LocalTime timeOfDay = localDateTime.toLocalTime();\n        LocalDate date = localDateTime.toLocalDate();\n\n        // Determine which session this timestamp belongs to\n        LocalDateTime sessionStartDateTime;\n        LocalDateTime sessionEndDateTime;\n\n        if (isOvernightSession()) {\n            // Overnight sessions, e.g., 18:00 to 09:30 (close < open)\n            if (timeOfDay.isBefore(sessionClose)) {\n                // Early morning, before session close (e.g., 03:00, before 09:30)\n                // This is the end of yesterday's overnight session\n                sessionStartDateTime = LocalDateTime.of(date.minusDays(1), sessionOpen);\n                sessionEndDateTime = LocalDateTime.of(date, sessionClose);\n            } else {\n                // Evening/late, at or after session open (e.g., 20:00, at or after 18:00)\n                // This is the start of today's overnight session\n                sessionStartDateTime = LocalDateTime.of(date, sessionOpen);\n                sessionEndDateTime = LocalDateTime.of(date.plusDays(1), sessionClose);\n            }\n        } else {\n            // Regular sessions, e.g., 09:30 to 16:00 (open < close)\n            // All times within this date belong to today's session (including pre/post market)\n            sessionStartDateTime = LocalDateTime.of(date, sessionOpen);\n            sessionEndDateTime = LocalDateTime.of(date, sessionClose);\n        }\n\n        // Convert back to UTC milliseconds\n        long sessionStartMillis = sessionStartDateTime.atZone(timezone).toInstant().toEpochMilli();\n        long sessionEndMillis = sessionEndDateTime.atZone(timezone).toInstant().toEpochMilli();\n\n        return Collections.singletonList(new TimeWindow(sessionStartMillis, sessionEndMillis));\n    }",
