        "old_string": "func TestSilenceBulkSuccess(t *testing.T) {\n\tapi := &API{\n\t\tsilenceStore: NewSilenceStore(),\n\t\tready:        func(f http.HandlerFunc) http.HandlerFunc { return f },\n\t}\n\n\tnow := time.Now()\n\tstartTime := now.Add(1 * time.Hour)\n\tendTime := now.Add(2 * time.Hour)\n\n\trequests := []SilenceRequest{\n\t\t{\n\t\t\tMatchers: []Matcher{\n\t\t\t\t{Name: \"alertname\", Value: \"TestAlert1\", IsRegex: false},\n\t\t\t},\n\t\t\tStartsAt:  startTime,\n\t\t\tEndsAt:    endTime,\n\t\t\tCreatedBy: \"test-user\",\n\t\t\tComment:   \"Test silence 1\",\n\t\t},\n\t\t{\n\t\t\tMatchers: []Matcher{\n\t\t\t\t{Name: \"alertname\", Value: \"TestAlert2\", IsRegex: false},\n\t\t\t},\n\t\t\tStartsAt:  startTime,\n\t\t\tEndsAt:    endTime,\n\t\t\tCreatedBy: \"test-user\",\n\t\t\tComment:   \"Test silence 2\",\n\t\t},\n\t}\n\n\tbody, err := json.Marshal(requests)\n\trequire.NoError(t, err)\n\n\tr := httptest.NewRequest(\"POST\", \"/api/v1/silences/bulk\", bytes.NewReader(body))\n\tw := httptest.NewRecorder()\n\n\tapi.silenceBulk(r)\n\n\tresp := w.Header()\n\trequire.NoError(t, err)\n\trequire.Equal(t, \"success\", resp.Get(\"X-Mock-Status\"))\n\n\t// Parse the response\n\tresult := api.silenceBulk(r)\n\trequire.NoError(t, result.err)\n\n\tresponse := result.data.(*BulkSilenceResponse)\n\trequire.Len(t, response.IDs, 2)\n\n\t// Verify that silences were actually created\n\tfor _, id := range response.IDs {\n\t\trequire.NotEmpty(t, id)\n\t}\n}",
        "new_string": "func TestSilenceBulkSuccess(t *testing.T) {\n\tapi := &API{\n\t\tsilenceStore: NewSilenceStore(),\n\t\tready:        func(f http.HandlerFunc) http.HandlerFunc { return f },\n\t}\n\n\tnow := time.Now()\n\tstartTime := now.Add(1 * time.Hour)\n\tendTime := now.Add(2 * time.Hour)\n\n\trequests := []SilenceRequest{\n\t\t{\n\t\t\tMatchers: []Matcher{\n\t\t\t\t{Name: \"alertname\", Value: \"TestAlert1\", IsRegex: false},\n\t\t\t},\n\t\t\tStartsAt:  startTime,\n\t\t\tEndsAt:    endTime,\n\t\t\tCreatedBy: \"test-user\",\n\t\t\tComment:   \"Test silence 1\",\n\t\t},\n\t\t{\n\t\t\tMatchers: []Matcher{\n\t\t\t\t{Name: \"alertname\", Value: \"TestAlert2\", IsRegex: false},\n\t\t\t},\n\t\t\tStartsAt:  startTime,\n\t\t\tEndsAt:    endTime,\n\t\t\tCreatedBy: \"test-user\",\n\t\t\tComment:   \"Test silence 2\",\n\t\t},\n\t}\n\n\tbody, err := json.Marshal(requests)\n\trequire.NoError(t, err)\n\n\tr := httptest.NewRequest(\"POST\", \"/api/v1/silences/bulk\", bytes.NewReader(body))\n\tresult := api.silenceBulk(r)\n\n\trequire.NoError(t, result.err)\n\n\tresponse := result.data.(*BulkSilenceResponse)\n\trequire.Len(t, response.IDs, 2)\n\n\t// Verify that silences were actually created\n\tfor _, id := range response.IDs {\n\t\trequire.NotEmpty(t, id)\n\t}\n}",
        "replace_all": false
