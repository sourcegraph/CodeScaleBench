        "new_string": "    return rout\n\n\ndef _rolling_median_dispatcher(a, window_size, axis=None, mode=None):\n    return (a,)\n\n\n@array_function_dispatch(_rolling_median_dispatcher)\ndef rolling_median(a, window_size, *, axis=-1, mode='valid'):\n    \"\"\"\n    Compute the rolling (sliding window) median over a 1-D or N-D array.\n\n    Parameters\n    ----------\n    a : array_like\n        Input array or object that can be converted to an array.\n    window_size : int\n        The size of the sliding window. Must be a positive integer.\n    axis : int, optional\n        The axis along which to compute the rolling median. Default is -1 (last axis).\n    mode : {'valid', 'same', 'full'}, optional\n        Determines the shape of the output along the given axis. Default is 'valid'.\n\n        - 'valid': output is of length max(M, N) - min(M, N) + 1.\n          Only positions where the window fully overlaps the input are included.\n        - 'same': output is of the same size as the input along the given axis.\n        - 'full': output is of length M + N - 1.\n          All positions where the window has any overlap are included.\n\n    Returns\n    -------\n    rolling_median : ndarray\n        The rolling median of the input array along the specified axis.\n        The output dtype is float64.\n\n    See Also\n    --------\n    median : Compute the median along a given axis.\n    percentile : Compute the q-th percentile along a given axis.\n\n    Examples\n    --------\n    >>> import numpy as np\n    >>> a = np.array([1, 2, 3, 4, 5])\n    >>> np.rolling_median(a, 3)\n    array([2., 3., 4.])\n    >>> np.rolling_median(a, 3, mode='same')\n    array([1.5, 2. , 3. , 4. , 4.5])\n    \"\"\"\n    a = asanyarray(a)\n\n    # Validate window_size\n    if not isinstance(window_size, (int, _nx.integer)):\n        try:\n            window_size = operator.index(window_size)\n        except (TypeError, AttributeError):\n            raise TypeError(f\"window_size must be an integer, got {type(window_size).__name__}\")\n\n    if window_size <= 0:\n        raise ValueError(f\"window_size must be positive, got {window_size}\")\n\n    # Validate mode\n    if mode not in ('valid', 'same', 'full'):\n        raise ValueError(f\"mode must be one of 'valid', 'same', or 'full', got {mode!r}\")\n\n    # Normalize axis\n    axis = normalize_axis_index(axis, a.ndim)\n\n    # Get the size along the specified axis\n    n = a.shape[axis]\n\n    # Calculate output size\n    if mode == 'valid':\n        if window_size > n:\n            output_size = 0\n        else:\n            output_size = n - window_size + 1\n    elif mode == 'same':\n        output_size = n\n    else:  # mode == 'full'\n        output_size = n + window_size - 1\n\n    # Create output array\n    output_shape = list(a.shape)\n    output_shape[axis] = output_size\n    result = empty(output_shape, dtype=np.float64)\n\n    if output_size == 0:\n        return result\n\n    # Compute rolling median\n    for i in range(output_size):\n        if mode == 'valid':\n            start = i\n            end = i + window_size\n        elif mode == 'same':\n            # Center the window around position i\n            start = i - window_size // 2\n            end = start + window_size\n        else:  # mode == 'full'\n            start = i - window_size + 1\n            end = i + 1\n\n        # Clamp indices to valid range\n        start = max(0, start)\n        end = min(n, end)\n\n        # Extract window\n        idx = [slice(None)] * a.ndim\n        idx[axis] = slice(start, end)\n        window = a[tuple(idx)]\n\n        # Compute median of window\n        window_median = median(window, axis=axis, overwrite_input=False, keepdims=True)\n\n        # Store result\n        idx_out = [slice(None)] * a.ndim\n        idx_out[axis] = i\n        result[tuple(idx_out)] = window_median.squeeze(axis=axis)\n\n    return result\n\n\ndef _percentile_dispatcher(a, q, axis=None, out=None, overwrite_input=None,\n                           method=None, keepdims=None, *, weights=None,\n                           interpolation=None):\n    return (a, q, out, weights)",
