        "file_path": "/workspace/regression_test.py",
        "old_string": "    def test_increment_in_anchor_with_encoded_hash(self):\n        \"\"\"Test increment in anchor with encoded character and number.\n\n        URL: http://example.com/#anchor%2D5\n        %2D = encoded '-'\n        Should increment the 5, preserve %2D (the dash)\n        \"\"\"\n        url = QUrl(\"http://example.com/#anchor%2D5\")\n        # Note: The anchor with encoded characters may not be decoded by PrettyDecoded\n        # This tests that encoded characters in anchors don't break the increment\n        try:\n            result = incdec_number(url, 'increment', count=1, segments={'anchor'})\n            assert result.isValid(), (\n                f\"BUG: Result URL became invalid! \"\n                f\"Result: '{result.toString()}'\"\n            )\n        except Exception:\n            # If the anchor doesn't have the right format, skip this test\n            # since it's about verifying encoding preservation more than finding numbers\n            pass",
        "new_string": "    def test_increment_in_anchor_with_encoded_space(self):\n        \"\"\"Test increment in anchor with encoded space.\n\n        URL: http://example.com/#file%205\n        %20 = encoded space\n        After increment, %20 should be preserved and space should not break URL\n        \"\"\"\n        url = QUrl(\"http://example.com/#file%205\")\n        result = incdec_number(url, 'increment', count=1, segments={'anchor'})\n\n        # Result should be valid\n        assert result.isValid(), (\n            f\"BUG: Result URL became invalid! \"\n            f\"Result: '{result.toString()}'\"\n        )\n\n        # The encoded space should be preserved\n        result_str = result.toString()\n        assert '%20' in result_str, (\n            f\"BUG: Encoded space %20 was corrupted in anchor! \"\n            f\"Got: {result_str}\"\n        )",
