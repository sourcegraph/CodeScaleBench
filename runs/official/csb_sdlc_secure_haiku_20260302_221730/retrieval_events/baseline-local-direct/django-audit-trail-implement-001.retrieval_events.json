        "old_string": "    def new(self, values=None):\n        \"\"\"\n        Return a new context with the same properties, but with only the\n        values given in 'values' stored.\n        \"\"\"\n        new_context = copy(self)\n        new_context._reset_dicts(values)\n        return new_context",
        "new_string": "    def new(self, values=None, isolated=False):\n        \"\"\"\n        Return a new context with the same properties, but with only the\n        values given in 'values' stored.\n\n        If isolated=True, create a fresh render_context to prevent\n        leakage of parent context state.\n        \"\"\"\n        new_context = copy(self)\n        new_context._reset_dicts(values)\n        if isolated:\n            # Create a fresh render_context to ensure complete isolation\n            new_context.render_context = RenderContext()\n        return new_context",
