        "file_path": "/workspace/django/forms/forms.py",
        "old_string": "    def _collect_composit_validators(self):\n        \"\"\"\n        Collect CompositFieldValidator instances from the form class.\n        These are stored as class attributes or in a composit_validators list.\n        \"\"\"\n        from .validators import CompositFieldValidator\n\n        # Get the class attribute, not the instance attribute\n        # This avoids infinite recursion and properly collects from the class\n        validators = getattr(self.__class__, \"composit_validators\", None)\n\n        if validators is None:\n            # Check instance for the attribute (set by subclasses)\n            validators = getattr(self, \"composit_validators\", None)\n\n        if validators is not None and isinstance(validators, list):\n            self.composit_validators = list(validators)  # Make a copy\n        else:\n            self.composit_validators = []",
        "new_string": "    def _collect_composit_validators(self):\n        \"\"\"\n        Collect CompositFieldValidator instances from the form class.\n        These are stored as class attributes or in a composit_validators list.\n        \"\"\"\n        from .validators import CompositFieldValidator\n\n        # Walk through the MRO to collect composit_validators\n        composit_validators = []\n        for base in reversed(self.__class__.__mro__):\n            # Look in the class __dict__ to avoid calling __getattribute__\n            if \"composit_validators\" in base.__dict__:\n                base_validators = base.__dict__[\"composit_validators\"]\n                if isinstance(base_validators, list):\n                    composit_validators.extend(base_validators)\n\n        # Store as instance attribute so it can be modified if needed\n        self.composit_validators = composit_validators",
