        "old_string": "    def create(self):\n        while True:\n            self._session_key = self._get_new_session_key()\n            try:\n                # Save immediately to ensure we have a unique entry in the\n                # database.\n                self.save(must_create=True)\n            except CreateError:\n                # Key wasn't unique. Try again.\n                continue\n            self.modified = True\n            return\n\n    async def acreate(self):\n        while True:\n            self._session_key = await self._aget_new_session_key()\n            try:\n                # Save immediately to ensure we have a unique entry in the\n                # database.\n                await self.asave(must_create=True)\n            except CreateError:\n                # Key wasn't unique. Try again.\n                continue\n            self.modified = True\n            return",
        "new_string": "    def create(self):\n        # Maximum number of attempts to create a unique session.\n        # This prevents infinite retries due to repeated key collisions.\n        max_attempts = 100\n        for attempt in range(max_attempts):\n            self._session_key = self._get_new_session_key()\n            try:\n                # Save immediately to ensure we have a unique entry in the\n                # database.\n                self.save(must_create=True)\n            except CreateError:\n                # Key wasn't unique. Try again.\n                if attempt == max_attempts - 1:\n                    # Exhausted all retry attempts\n                    raise\n                continue\n            self.modified = True\n            return\n\n    async def acreate(self):\n        # Maximum number of attempts to create a unique session.\n        # This prevents infinite retries due to repeated key collisions.\n        max_attempts = 100\n        for attempt in range(max_attempts):\n            self._session_key = await self._aget_new_session_key()\n            try:\n                # Save immediately to ensure we have a unique entry in the\n                # database.\n                await self.asave(must_create=True)\n            except CreateError:\n                # Key wasn't unique. Try again.\n                if attempt == max_attempts - 1:\n                    # Exhausted all retry attempts\n                    raise\n                continue\n            self.modified = True\n            return",
