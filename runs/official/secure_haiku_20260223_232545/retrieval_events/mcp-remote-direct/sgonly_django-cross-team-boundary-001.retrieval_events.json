        "old_string": "    def _get_new_session_key(self):\n        \"Return session key that isn't being used.\"\n        while True:\n            session_key = get_random_string(32, VALID_KEY_CHARS)\n            if not self.exists(session_key):\n                return session_key\n\n    async def _aget_new_session_key(self):\n        while True:\n            session_key = get_random_string(32, VALID_KEY_CHARS)\n            if not await self.aexists(session_key):\n                return session_key",
        "new_string": "    def _get_new_session_key(self):\n        \"Return session key that isn't being used.\"\n        # Maximum number of attempts to generate a unique key.\n        # This prevents infinite loops in case of many collisions.\n        max_attempts = 100\n        for _ in range(max_attempts):\n            session_key = get_random_string(32, VALID_KEY_CHARS)\n            if not self.exists(session_key):\n                return session_key\n        # If we can't find a unique key after many attempts, raise an error\n        raise CreateError(\n            \"Unable to create a unique session key after %d attempts. \"\n            \"Possible key collision under high concurrency.\" % max_attempts\n        )\n\n    async def _aget_new_session_key(self):\n        # Maximum number of attempts to generate a unique key.\n        # This prevents infinite loops in case of many collisions.\n        max_attempts = 100\n        for _ in range(max_attempts):\n            session_key = get_random_string(32, VALID_KEY_CHARS)\n            if not await self.aexists(session_key):\n                return session_key\n        # If we can't find a unique key after many attempts, raise an error\n        raise CreateError(\n            \"Unable to create a unique session key after %d attempts. \"\n            \"Possible key collision under high concurrency.\" % max_attempts\n        )",
