        "new_string": "    def test_render_custom_attrs(self):\n        self.check_html(\n            self.widget,\n            \"email\",\n            \"test@example.com\",\n            attrs={\"class\": \"fun\"},\n            html=(\n                '<input type=\"text\" name=\"email\" value=\"test@example.com\" class=\"fun\">'\n            ),\n        )\n\n    def test_render_custom_attrs_with_special_chars(self):\n        \"\"\"Custom attributes with special characters are properly HTML-escaped.\"\"\"\n        self.check_html(\n            self.widget,\n            \"email\",\n            \"test@example.com\",\n            attrs={\"data-label\": 'Value with \"quotes\"'},\n            html=(\n                '<input type=\"text\" name=\"email\" value=\"test@example.com\" '\n                'data-label=\"Value with &quot;quotes&quot;\">'\n            ),\n        )\n\n    def test_render_custom_attrs_with_ampersand(self):\n        \"\"\"Custom attributes with ampersands are properly HTML-escaped.\"\"\"\n        self.check_html(\n            self.widget,\n            \"email\",\n            \"test@example.com\",\n            attrs={\"data-value\": \"A & B\"},\n            html=(\n                '<input type=\"text\" name=\"email\" value=\"test@example.com\" '\n                'data-value=\"A &amp; B\">'\n            ),\n        )\n\n    def test_render_custom_attrs_with_angle_brackets(self):\n        \"\"\"Custom attributes with angle brackets are properly HTML-escaped.\"\"\"\n        self.check_html(\n            self.widget,\n            \"email\",\n            \"test@example.com\",\n            attrs={\"data-content\": \"<script>alert(1)</script>\"},\n            html=(\n                '<input type=\"text\" name=\"email\" value=\"test@example.com\" '\n                'data-content=\"&lt;script&gt;alert(1)&lt;/script&gt;\">'\n            ),\n        )\n\n    def test_render_custom_attrs_with_none_value(self):\n        \"\"\"Custom attributes with None values are not rendered.\"\"\"\n        self.check_html(\n            self.widget,\n            \"email\",\n            \"test@example.com\",\n            attrs={\"data-optional\": None},\n            html='<input type=\"text\" name=\"email\" value=\"test@example.com\">',\n        )\n\n    def test_render_unicode(self):",
