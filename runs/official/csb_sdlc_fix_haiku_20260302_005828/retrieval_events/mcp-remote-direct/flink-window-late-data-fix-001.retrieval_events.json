n\n        ConcurrentLinkedQueue<Object> expected = new ConcurrentLinkedQueue<>();\n        ConcurrentLinkedQueue<Object> sideExpected = new ConcurrentLinkedQueue<>();\n\n        // Create a session window at timestamp 100\n        testHarness.processElement(new StreamRecord<>(new Tuple2<>(\"key1\", 1), 100));\n\n        // Advance watermark past the session window's cleanup time (100 + 5 + 0 = 105)\n        // This makes any new windows at timestamp <= 104 be considered late\n        testHarness.processWatermark(new Watermark(200));\n        expected.add(new Watermark(200));\n\n        // Send a late element at timestamp 102 that could extend the session\n        // Even though it's technically late (102 + 0 <= 200), it should extend\n        // the existing session instead of being sent to side output\n        testHarness.processElement(new StreamRecord<>(new Tuple2<>(\"key1\", 2), 102));\n\n        // Advance watermark to trigger the window output\n        testHarness.processWatermark(new Watermark(300));\n\n        // The session window should have merged the late element with the original session\n        // and emitted it with sum 3 (1 + 2)\n        expected.add(new StreamRecord<>(new Tuple3<>(\"key1-3\", 100L, 107L), 106));\n        expected.add(new Watermark(300));\n\n        // The late element should NOT appear in side output\n        // because it was merged with the existing session\n\n        TestHarnessUtil.assertOutputEqualsSorted(\n                \"Output was not correct.\",\n                expected,\n                testHarness.getOutput(),\n                new Tuple3ResultSortComparator());\n\n        TestHarnessUtil.assertOutputEqualsSorted(\n                \"SideOutput was not correct.\",\n                sideExpected,\n                (Iterable) testHarness.getSideOutput(lateOutputTag),\n                new Tuple2ResultSortComparator());\n\n        testHarness.close();\n    }\n\n    @Test\n    void testCleanupTimerWithEmptyListStateForSessionWindows() throws Exception {",
