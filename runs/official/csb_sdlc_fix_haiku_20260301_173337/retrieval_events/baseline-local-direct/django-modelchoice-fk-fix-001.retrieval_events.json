        "old_string": "        self.assertEqual(obj.name, \"class default value\")\n        self.assertEqual(obj.value, 99)\n        self.assertEqual(obj.def_date, datetime.date(1999, 3, 2))\n\n\nclass RelatedModelFormTests(SimpleTestCase):",
        "new_string": "        self.assertEqual(obj.name, \"class default value\")\n        self.assertEqual(obj.value, 99)\n        self.assertEqual(obj.def_date, datetime.date(1999, 3, 2))\n\n\nclass ForeignKeyToFieldTestCase(TestCase):\n    def setUp(self):\n        self.country_us = CountryModel.objects.create(code=\"US\", name=\"United States\")\n        self.country_gb = CountryModel.objects.create(code=\"GB\", name=\"Great Britain\")\n        self.city_ny = CityModel.objects.create(name=\"New York\", country=self.country_us)\n        self.city_london = CityModel.objects.create(name=\"London\", country=self.country_gb)\n\n    def test_model_to_dict_with_to_field_fk(self):\n        \"\"\"\n        Test that model_to_dict correctly returns the to_field value\n        for ForeignKey fields with non-default target fields.\n        \"\"\"\n        from django.forms.models import model_to_dict\n\n        # For a city with country_us\n        data = model_to_dict(self.city_ny, fields=[\"name\", \"country\"])\n        self.assertEqual(data[\"country\"], \"US\")\n\n        # For a city with country_gb\n        data = model_to_dict(self.city_london, fields=[\"name\", \"country\"])\n        self.assertEqual(data[\"country\"], \"GB\")\n\n    def test_model_form_initial_with_to_field_fk(self):\n        \"\"\"\n        Test that ModelForm correctly renders selected option for ForeignKey\n        with non-default target field.\n        \"\"\"\n        class CityForm(ModelForm):\n            class Meta:\n                model = CityModel\n                fields = [\"name\", \"country\"]\n\n        # Create a form with an instance\n        form = CityForm(instance=self.city_ny)\n        # The initial value should be the code, not the pk\n        self.assertEqual(form.initial[\"country\"], \"US\")\n\n        form = CityForm(instance=self.city_london)\n        self.assertEqual(form.initial[\"country\"], \"GB\")\n\n    def test_model_form_rendering_with_to_field_fk(self):\n        \"\"\"\n        Test that the form dropdown has the correct option selected when\n        using ForeignKey with to_field.\n        \"\"\"\n        class CityForm(ModelForm):\n            class Meta:\n                model = CityModel\n                fields = [\"name\", \"country\"]\n\n        # Create a form with an instance\n        form = CityForm(instance=self.city_ny)\n        rendered = form.as_p()\n        # The option for \"US\" should be selected\n        self.assertIn('value=\"US\" selected', rendered)\n        # The option for \"GB\" should not be selected\n        self.assertNotIn('value=\"GB\" selected', rendered)\n\n        form = CityForm(instance=self.city_london)\n        rendered = form.as_p()\n        # The option for \"GB\" should be selected\n        self.assertIn('value=\"GB\" selected', rendered)\n        # The option for \"US\" should not be selected\n        self.assertNotIn('value=\"US\" selected', rendered)\n\n\nclass RelatedModelFormTests(SimpleTestCase):",
