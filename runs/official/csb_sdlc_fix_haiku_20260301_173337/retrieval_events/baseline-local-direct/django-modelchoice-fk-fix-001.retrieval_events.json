        "file_path": "/workspace/django/forms/models.py",
        "old_string": "def model_to_dict(instance, fields=None, exclude=None):\n    \"\"\"\n    Return a dict containing the data in ``instance`` suitable for passing as\n    a Form's ``initial`` keyword argument.\n\n    ``fields`` is an optional list of field names. If provided, return only the\n    named.\n\n    ``exclude`` is an optional list of field names. If provided, exclude the\n    named from the returned dict, even if they are listed in the ``fields``\n    argument.\n    \"\"\"\n    opts = instance._meta\n    data = {}\n    for f in chain(opts.concrete_fields, opts.private_fields, opts.many_to_many):\n        if not getattr(f, \"editable\", False):\n            continue\n        if fields is not None and f.name not in fields:\n            continue\n        if exclude and f.name in exclude:\n            continue\n        # For ForeignKey/OneToOneField fields with a non-default target field,\n        # get the value from the target field of the related object.\n        if hasattr(f, \"remote_field\") and f.remote_field is not None:\n            # Check if this is a ForeignKey or OneToOneField with to_field\n            if hasattr(f.remote_field, \"field_name\"):\n                # If the target field is not the primary key, get the value from it\n                if f.remote_field.field_name != \"pk\":\n                    related_obj = getattr(instance, f.name, None)\n                    if related_obj is not None:\n                        data[f.name] = getattr(\n                            related_obj, f.remote_field.field_name\n                        )\n                    else:\n                        data[f.name] = None\n                    continue\n        data[f.name] = f.value_from_object(instance)\n    return data",
        "new_string": "def model_to_dict(instance, fields=None, exclude=None):\n    \"\"\"\n    Return a dict containing the data in ``instance`` suitable for passing as\n    a Form's ``initial`` keyword argument.\n\n    ``fields`` is an optional list of field names. If provided, return only the\n    named.\n\n    ``exclude`` is an optional list of field names. If provided, exclude the\n    named from the returned dict, even if they are listed in the ``fields``\n    argument.\n    \"\"\"\n    opts = instance._meta\n    data = {}\n    for f in chain(opts.concrete_fields, opts.private_fields, opts.many_to_many):\n        if not getattr(f, \"editable\", False):\n            continue\n        if fields is not None and f.name not in fields:\n            continue\n        if exclude and f.name in exclude:\n            continue\n        # For ForeignKey/OneToOneField fields with a non-default target field,\n        # get the value from the target field of the related object.\n        if hasattr(f, \"remote_field\") and f.remote_field is not None:\n            # Check if this is a ForeignKey or OneToOneField with to_field\n            if hasattr(f.remote_field, \"field_name\") and hasattr(\n                f.remote_field, \"model\"\n            ):\n                # If the target field is not the primary key, get the value from it\n                remote_model_pk_name = f.remote_field.model._meta.pk.name\n                if f.remote_field.field_name != remote_model_pk_name:\n                    related_obj = getattr(instance, f.name, None)\n                    if related_obj is not None:\n                        data[f.name] = getattr(\n                            related_obj, f.remote_field.field_name\n                        )\n                    else:\n                        data[f.name] = None\n                    continue\n        data[f.name] = f.value_from_object(instance)\n    return data",
