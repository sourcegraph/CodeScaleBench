        "file_path": "/workspace/torch/optim/gradient_noise.py",
        "old_string": "    def step(self, closure: Optional[Callable[[], float]] = None) -> Optional[float]:\n        r\"\"\"Perform a single optimization step with gradient noise injection.\n\n        Injects Gaussian noise into the gradients before calling the wrapped\n        optimizer's step method.\n\n        Args:\n            closure (Callable, optional): A closure that reevaluates the model\n                and returns the loss.\n\n        Returns:\n            Optional[float]: The loss value if closure is provided, otherwise None.\n        \"\"\"\n        # Compute noise variance for this step\n        # sigma^2 = eta / (1 + t)^gamma\n        noise_variance = self.eta / ((1 + self.step_count) ** self.gamma)\n\n        # Inject noise into gradients\n        for group in self.optimizer.param_groups:\n            for param in group[\"params\"]:\n                if param.grad is not None:\n                    # Add Gaussian noise with computed variance\n                    noise = torch.randn_like(param.grad) * (noise_variance ** 0.5)\n                    param.grad.add_(noise)\n\n        # Call the wrapped optimizer's step\n        loss = self.optimizer.step(closure)\n\n        # Increment step counter\n        self.step_count += 1\n\n        return loss",
        "new_string": "    def step(self, closure: Optional[Callable[[], float]] = None) -> Optional[float]:\n        r\"\"\"Perform a single optimization step with gradient noise injection.\n\n        Injects Gaussian noise into the gradients before calling the wrapped\n        optimizer's step method.\n\n        Args:\n            closure (Callable, optional): A closure that reevaluates the model\n                and returns the loss.\n\n        Returns:\n            Optional[float]: The loss value if closure is provided, otherwise None.\n        \"\"\"\n        # Compute noise variance for this step\n        # sigma^2 = eta / (1 + t)^gamma\n        noise_variance = self.eta / ((1 + self.step_count) ** self.gamma)\n\n        def _inject_noise():\n            \"\"\"Helper to inject noise into current gradients.\"\"\"\n            for group in self.optimizer.param_groups:\n                for param in group[\"params\"]:\n                    if param.grad is not None:\n                        # Add Gaussian noise with computed variance\n                        noise = torch.randn_like(param.grad) * (noise_variance ** 0.5)\n                        param.grad.add_(noise)\n\n        if closure is not None:\n            # Wrap closure to inject noise after it computes gradients\n            def closure_with_noise():\n                loss = closure()\n                _inject_noise()\n                return loss\n\n            loss = self.optimizer.step(closure_with_noise)\n        else:\n            # No closure: inject noise into existing gradients\n            _inject_noise()\n            loss = self.optimizer.step(None)\n\n        # Increment step counter\n        self.step_count += 1\n\n        return loss",
