        "file_path": "/workspace/pandas/tests/reshape/merge/test_merge_asof.py",
        "old_string": "def test_merge_asof_multiby_with_categorical():\n    # GH 43541\n    left = pd.DataFrame(\n        {\n            \"c1\": pd.Categorical([\"a\", \"a\", \"b\", \"b\"], categories=[\"a\", \"b\"]),\n            \"c2\": [\"x\"] * 4,\n            \"t\": [1] * 4,\n            \"v\": range(4),\n        }\n    )\n    right = pd.DataFrame(\n        {\n            \"c1\": pd.Categorical([\"b\", \"b\"], categories=[\"b\", \"a\"]),\n            \"c2\": [\"x\"] * 2,\n            \"t\": [1, 2],\n            \"v\": range(2),\n        }\n    )\n    result = merge_asof(\n        left,\n        right,\n        by=[\"c1\", \"c2\"],\n        on=\"t\",\n        direction=\"forward\",\n        suffixes=[\"_left\", \"_right\"],\n    )\n    expected = pd.DataFrame(\n        {\n            \"c1\": pd.Categorical([\"a\", \"a\", \"b\", \"b\"], categories=[\"a\", \"b\"]),\n            \"c2\": [\"x\"] * 4,\n            \"t\": [1] * 4,\n            \"v_left\": range(4),\n            \"v_right\": [np.nan, np.nan, 0.0, 0.0],\n        }\n    )\n    tm.assert_frame_equal(result, expected)",
        "new_string": "def test_merge_asof_multiby_with_categorical():\n    # GH 43541\n    left = pd.DataFrame(\n        {\n            \"c1\": pd.Categorical([\"a\", \"a\", \"b\", \"b\"], categories=[\"a\", \"b\"]),\n            \"c2\": [\"x\"] * 4,\n            \"t\": [1] * 4,\n            \"v\": range(4),\n        }\n    )\n    right = pd.DataFrame(\n        {\n            \"c1\": pd.Categorical([\"b\", \"b\"], categories=[\"b\", \"a\"]),\n            \"c2\": [\"x\"] * 2,\n            \"t\": [1, 2],\n            \"v\": range(2),\n        }\n    )\n    result = merge_asof(\n        left,\n        right,\n        by=[\"c1\", \"c2\"],\n        on=\"t\",\n        direction=\"forward\",\n        suffixes=[\"_left\", \"_right\"],\n    )\n    expected = pd.DataFrame(\n        {\n            \"c1\": pd.Categorical([\"a\", \"a\", \"b\", \"b\"], categories=[\"a\", \"b\"]),\n            \"c2\": [\"x\"] * 4,\n            \"t\": [1] * 4,\n            \"v_left\": range(4),\n            \"v_right\": [np.nan, np.nan, 0.0, 0.0],\n        }\n    )\n    tm.assert_frame_equal(result, expected)\n\n\ndef test_merge_asof_indicator():\n    # Test that indicator parameter works with merge_asof\n    left = pd.DataFrame({\"a\": [1, 5, 10], \"left_val\": [\"a\", \"b\", \"c\"]})\n    right = pd.DataFrame({\"a\": [1, 2, 3, 6, 7], \"right_val\": [1, 2, 3, 6, 7]})\n\n    result = merge_asof(left, right, on=\"a\", indicator=True)\n\n    # Check that _merge column exists\n    assert \"_merge\" in result.columns\n    assert result[\"_merge\"].dtype.name == \"category\"\n\n    # For asof merge with default backward direction, all rows should match\n    # First row (a=1) matches exactly, so it's \"both\"\n    # Second row (a=5) has a match (a=3), so it's \"both\"\n    # Third row (a=10) has a match (a=7), so it's \"both\"\n    assert (result[\"_merge\"] == \"both\").all()\n\n\ndef test_merge_asof_indicator_with_custom_name():\n    # Test that indicator parameter works with custom name\n    left = pd.DataFrame({\"a\": [1, 5, 10], \"left_val\": [\"a\", \"b\", \"c\"]})\n    right = pd.DataFrame({\"a\": [1, 2, 3, 6, 7], \"right_val\": [1, 2, 3, 6, 7]})\n\n    result = merge_asof(left, right, on=\"a\", indicator=\"custom_merge\")\n\n    # Check that custom_merge column exists\n    assert \"custom_merge\" in result.columns\n    assert result[\"custom_merge\"].dtype.name == \"category\"\n\n\ndef test_merge_asof_indicator_no_matches():\n    # Test indicator when some rows don't have matches\n    left = pd.DataFrame({\"a\": [1, 5, 10], \"left_val\": [\"a\", \"b\", \"c\"]})\n    right = pd.DataFrame({\"a\": [1, 2, 3], \"right_val\": [1, 2, 3]})\n\n    result = merge_asof(left, right, on=\"a\", indicator=True)\n\n    # Check that _merge column exists\n    assert \"_merge\" in result.columns\n\n    # First row (a=1) matches exactly\n    # Second row (a=5) has no match (max in right is 3)\n    # Third row (a=10) has no match (max in right is 3)\n    assert result.iloc[0][\"_merge\"] == \"both\"\n    assert result.iloc[1][\"_merge\"] == \"left_only\"\n    assert result.iloc[2][\"_merge\"] == \"left_only\"\n\n\ndef test_merge_asof_indicator_false():\n    # Test that indicator=False doesn't add _merge column\n    left = pd.DataFrame({\"a\": [1, 5, 10], \"left_val\": [\"a\", \"b\", \"c\"]})\n    right = pd.DataFrame({\"a\": [1, 2, 3, 6, 7], \"right_val\": [1, 2, 3, 6, 7]})\n\n    result = merge_asof(left, right, on=\"a\", indicator=False)\n\n    # Check that _merge column does not exist\n    assert \"_merge\" not in result.columns",
        "replace_all": false
