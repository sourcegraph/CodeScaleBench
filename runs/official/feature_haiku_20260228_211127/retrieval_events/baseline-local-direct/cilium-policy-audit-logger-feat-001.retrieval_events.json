        "old_string": "// LogEvaluation logs a policy evaluation result with context, policy key, selector cache, and result.\n// This method is thread-safe and provides detailed evaluation information for debugging.\nfunc (pal *PolicyAuditLogger) LogEvaluation(ctx context.Context, policyKey string, selectorCache *SelectorCache, result interface{}) {\n\tpal.Lock()\n\tdefer pal.Unlock()\n\n\tif pal.logger == nil {\n\t\treturn\n\t}\n\n\tattrs := []slog.Attr{\n\t\tslog.String(logfields.PolicyKey, policyKey),\n\t\tslog.Any(\"result\", result),\n\t\tslog.Int64(\"timestamp\", time.Now().UnixNano()),\n\t}\n\n\t// If selectorCache is available, log its revision\n\tif selectorCache != nil {\n\t\tattrs = append(attrs, slog.Uint64(\"selector_revision\", uint64(selectorCache.Revision())))\n\t}\n\n\tpal.logger.LogAttrs(ctx, pal.logLevel,\n\t\t\"policy evaluation\",\n\t\tattrs...,\n\t)\n}",
        "new_string": "// LogEvaluation logs a policy evaluation result with context, policy key, selector cache, and result.\n// This method is thread-safe and provides detailed evaluation information for debugging.\nfunc (pal *PolicyAuditLogger) LogEvaluation(ctx context.Context, policyKey string, selectorCache *SelectorCache, result interface{}) {\n\tpal.Lock()\n\tdefer pal.Unlock()\n\n\tif pal.logger == nil {\n\t\treturn\n\t}\n\n\tattrs := []slog.Attr{\n\t\tslog.String(logfields.PolicyKey, policyKey),\n\t\tslog.Any(\"result\", result),\n\t\tslog.Int64(\"timestamp\", time.Now().UnixNano()),\n\t}\n\n\t// If selectorCache is available, include it in the log\n\tif selectorCache != nil {\n\t\tattrs = append(attrs, slog.Bool(\"selectorCacheAvailable\", true))\n\t}\n\n\tpal.logger.LogAttrs(ctx, pal.logLevel,\n\t\t\"policy evaluation\",\n\t\tattrs...,\n\t)\n}",
