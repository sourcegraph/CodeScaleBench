        "new_string": "// IsZero returns true if the tracing config is not enabled.\n// This is used for marshalling to YAML for `config init`.\nfunc (c TracingConfig) IsZero() bool {\n\treturn !c.Enabled\n}\n\n// Validate checks if the tracing configuration is valid.\nfunc (c TracingConfig) Validate() error {\n\tif !c.Enabled {\n\t\treturn nil\n\t}\n\n\t// Validate sampling rate\n\tif c.SamplingRate < 0 || c.SamplingRate > 1 {\n\t\treturn fmt.Errorf(\"invalid sampling rate: %f (must be between 0 and 1)\", c.SamplingRate)\n\t}\n\n\t// Validate propagators\n\tvalidPropagators := map[string]bool{\n\t\t\"tracecontext\": true,\n\t\t\"baggage\":      true,\n\t\t\"jaeger\":       true,\n\t\t\"xray\":         true,\n\t\t\"ottrace\":      true,\n\t}\n\n\tfor _, prop := range c.Propagators {\n\t\tif !validPropagators[prop] {\n\t\t\treturn fmt.Errorf(\"invalid propagator: %q (supported: tracecontext, baggage, jaeger, xray, ottrace)\", prop)\n\t\t}\n\t}\n\n\treturn nil\n}",
