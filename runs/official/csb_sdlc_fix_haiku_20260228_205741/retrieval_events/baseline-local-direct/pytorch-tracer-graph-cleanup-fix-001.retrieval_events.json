        "new_string": "    def cleanup(self) -> None:\n        # There is a reference cycle between tracer and OutputGraph, causing\n        # some of the tensor objects to be held alive for longer than necessary.\n        self.root_tx = None  # type: ignore[assignment]\n        self.nn_modules.clear()\n        self.param_name_to_source = None\n\n        for node in self.graph.nodes:\n            if \"grapharg\" in node.meta:\n                del node.meta[\"grapharg\"]\n            # Break the doubly linked list cycle in graph nodes\n            node._prev = None  # type: ignore[assignment]\n            node._next = None  # type: ignore[assignment]\n        self.real_value_cache.clear()\n        self.input_name_to_proxy.clear()\n        self.side_effects.clear()\n        self.variable_tracker_cache.clear()\n        self.register_finalizer_fns.clear()\n        self.dynamo_flat_name_to_original_fqn.clear()\n        self.tracing_context.clear()\n        self.input_source_to_var.clear()\n        self.unspec_variable_map.clear()\n        self.backward_state.clear()\n\n        # Break the reference cycle between FakeTensorMode \u2192 ShapeEnv \u2192 TrackedFake \u2192 FakeTensor\n        # Clear the tracked_fakes list to break the cycle from ShapeEnv back to FakeTensors\n        self.tracked_fakes.clear()\n\n        # Clear the shape_env reference in the fake_mode to break the FakeTensorMode -> ShapeEnv cycle\n        if self.tracing_context.fake_mode is not None:\n            self.tracing_context.fake_mode.shape_env = None  # type: ignore[assignment]",
