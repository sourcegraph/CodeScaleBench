      "arguments": {
        "file_path": "/workspace/django/forms/models.py",
        "old_string": "def model_to_dict(instance, fields=None, exclude=None):\n    \"\"\"\n    Return a dict containing the data in ``instance`` suitable for passing as\n    a Form's ``initial`` keyword argument.\n\n    ``fields`` is an optional list of field names. If provided, return only the\n    named.\n\n    ``exclude`` is an optional list of field names. If provided, exclude the\n    named from the returned dict, even if they are listed in the ``fields``\n    argument.\n    \"\"\"\n    opts = instance._meta\n    data = {}\n    for f in chain(opts.concrete_fields, opts.private_fields, opts.many_to_many):\n        if not getattr(f, \"editable\", False):\n            continue\n        if fields is not None and f.name not in fields:\n            continue\n        if exclude and f.name in exclude:\n            continue\n        data[f.name] = f.value_from_object(instance)\n    return data",
        "new_string": "def model_to_dict(instance, fields=None, exclude=None):\n    \"\"\"\n    Return a dict containing the data in ``instance`` suitable for passing as\n    a Form's ``initial`` keyword argument.\n\n    ``fields`` is an optional list of field names. If provided, return only the\n    named.\n\n    ``exclude`` is an optional list of field names. If provided, exclude the\n    named from the returned dict, even if they are listed in the ``fields``\n    argument.\n    \"\"\"\n    opts = instance._meta\n    data = {}\n    for f in chain(opts.concrete_fields, opts.private_fields, opts.many_to_many):\n        if not getattr(f, \"editable\", False):\n            continue\n        if fields is not None and f.name not in fields:\n            continue\n        if exclude and f.name in exclude:\n            continue\n        # For ForeignKey/OneToOneField with a non-PK to_field, return the\n        # value of the to_field instead of the primary key to match what\n        # the form field expects when rendering the form.\n        if hasattr(f, \"remote_field\") and f.remote_field:\n            field_name = f.remote_field.field_name\n            if field_name != \"pk\":\n                related_obj = getattr(instance, f.name, None)\n                if related_obj is not None:\n                    data[f.name] = getattr(related_obj, field_name)\n                else:\n                    data[f.name] = None\n                continue\n        data[f.name] = f.value_from_object(instance)\n    return data",
        "replace_all": false
