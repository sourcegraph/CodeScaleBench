        "old_string": "  filter_.reset();\n  EXPECT_EQ(output_.size(), 1);\n  EXPECT_THAT(output_.front(), testing::HasSubstr(\"session_complete\"));\n}\n\nclass HttpUpstreamImplTest : public testing::Test {",
        "new_string": "  filter_.reset();\n  EXPECT_EQ(output_.size(), 1);\n  EXPECT_THAT(output_.front(), testing::HasSubstr(\"session_complete\"));\n}\n\n// Test that cluster updates correctly replace old cluster info in the info map.\nTEST_F(UdpProxyFilterTest, ClusterDynamicInfoMapUpdate) {\n  InSequence s;\n\n  setup(readConfig(R\"EOF(\nstat_prefix: foo\nmatcher:\n  on_no_match:\n    action:\n      name: route\n      typed_config:\n        '@type': type.googleapis.com/envoy.extensions.filters.udp.udp_proxy.v3.Route\n        cluster: fake_cluster\n  )EOF\"));\n\n  // Create a session with the initial cluster.\n  expectSessionCreate(upstream_address_);\n  test_sessions_[0].expectWriteToUpstream(\"hello\", 0, nullptr, true);\n  recvDataFromDownstream(\"10.0.0.1:1000\", \"10.0.0.2:80\", \"hello\");\n  EXPECT_EQ(1, config_->stats().downstream_sess_total_.value());\n  EXPECT_EQ(1, config_->stats().downstream_sess_active_.value());\n\n  // Now simulate a cluster update with a new ThreadLocalCluster.\n  // Create a new mock cluster with the same name.\n  NiceMock<Upstream::MockThreadLocalCluster> updated_cluster;\n  updated_cluster.cluster_.info_->name_ = \"fake_cluster\";\n\n  {\n    Upstream::ThreadLocalClusterCommand command =\n        [&updated_cluster]() -> Upstream::ThreadLocalCluster& {\n      return updated_cluster;\n    };\n    cluster_update_callbacks_->onClusterAddOrUpdate(\"fake_cluster\", command);\n  }\n\n  // With the fix, the cluster info map should now point to the new cluster.\n  // Verify this by creating a session with the updated cluster.\n  // This session should use the updated cluster, not the old one.\n  auto updated_host = createHost(Network::Utility::parseInternetAddressAndPort(\"10.0.0.3:443\", false));\n  EXPECT_CALL(updated_cluster.lb_, chooseHost(_))\n      .WillOnce(Return(updated_host));\n\n  Network::MockSocket* updated_socket = new NiceMock<Network::MockSocket>();\n  EXPECT_CALL(dynamic_cast<TestUdpProxyFilter&>(*filter_), createUdpSocket(_))\n      .WillOnce(ReturnNew<Network::MockSocket>());\n\n  test_sessions_[1].expectWriteToUpstream(\"world\", 0, nullptr, true);\n  recvDataFromDownstream(\"10.0.0.1:1001\", \"10.0.0.2:80\", \"world\");\n}\n\nclass HttpUpstreamImplTest : public testing::Test {",
        "replace_all": false
