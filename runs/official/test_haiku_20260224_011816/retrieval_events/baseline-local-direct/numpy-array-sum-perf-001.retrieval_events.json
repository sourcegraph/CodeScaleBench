        "old_string": "\n\n/*NUMPY_API\n *Sum\n */\nNPY_NO_EXPORT PyObject *\nPyArray_Sum(PyArrayObject *self, int axis, int rtype, PyArrayObject *out)\n{\n    PyObject *arr, *ret;\n\n    arr = PyArray_CheckAxis(self, &axis, 0);\n    if (arr == NULL) {\n        return NULL;\n    }\n    ret = PyArray_GenericReduceFunction((PyArrayObject *)arr, n_ops.add, axis,\n                                        rtype, out);\n    Py_DECREF(arr);\n    return ret;\n}",
        "new_string": "\n/* Optimized summation for float arrays using vectorized loops\n * with improved cache locality for better performance\n */\nstatic PyObject *\n_PyArray_Sum_Optimized(PyArrayObject *self, int axis, int rtype, PyArrayObject *out)\n{\n    /* Fast path for float arrays - uses vectorized operations\n     * with improved cache efficiency */\n    PyArray_Descr *descr = PyArray_DESCR(self);\n    int ndim = PyArray_NDIM(self);\n    npy_intp size = PyArray_SIZE(self);\n\n    /* Only apply optimization for float types on large arrays */\n    if (size < 1000) {\n        return NULL;  /* Fall back to generic path for small arrays */\n    }\n\n    if ((descr->type_num != NPY_FLOAT64 && descr->type_num != NPY_FLOAT32)) {\n        return NULL;  /* Fall back for non-float types */\n    }\n\n    /* Check if this is a total reduction (summing all elements) */\n    /* When axis=-1 is passed by user or axis=None is converted */\n    if (!(axis == -1 || axis == NPY_RAVEL_AXIS)) {\n        /* Check if axis has been normalized by caller */\n        int check_axis = axis;\n        if (check_axis < 0) {\n            check_axis += ndim;\n        }\n        if (check_axis >= 0 && check_axis < ndim) {\n            /* This is a reduction along one axis, not all elements */\n            return NULL;\n        }\n    }\n\n    /* Skip optimization if there's an output array (different code path) */\n    if (out != NULL) {\n        return NULL;\n    }\n\n    /* Skip if a different rtype is requested - fall back to generic path */\n    if (rtype != descr->type_num && rtype != -1 && rtype != NPY_NOTYPE) {\n        return NULL;\n    }\n\n    char *data = PyArray_DATA(self);\n\n    if (descr->type_num == NPY_FLOAT64) {\n        double sum = 0.0;\n        double *ptr = (double *)data;\n        npy_intp n = size;\n\n        /* Unroll loop by 8 for better CPU pipelining and cache efficiency\n         * This reduces the number of branches and improves instruction-level parallelism\n         */\n        npy_intp i;\n        for (i = 0; i + 7 < n; i += 8) {\n            sum += ptr[i] + ptr[i+1] + ptr[i+2] + ptr[i+3] +\n                   ptr[i+4] + ptr[i+5] + ptr[i+6] + ptr[i+7];\n        }\n        /* Handle remaining elements */\n        for (; i < n; i++) {\n            sum += ptr[i];\n        }\n\n        return PyFloat_FromDouble(sum);\n    }\n    else if (descr->type_num == NPY_FLOAT32) {\n        double sum = 0.0;  /* Use double accumulator for better precision */\n        float *ptr = (float *)data;\n        npy_intp n = size;\n\n        /* Unroll loop by 8 for better CPU pipelining and cache efficiency */\n        npy_intp i;\n        for (i = 0; i + 7 < n; i += 8) {\n            sum += ptr[i] + ptr[i+1] + ptr[i+2] + ptr[i+3] +\n                   ptr[i+4] + ptr[i+5] + ptr[i+6] + ptr[i+7];\n        }\n        /* Handle remaining elements */\n        for (; i < n; i++) {\n            sum += ptr[i];\n        }\n\n        return PyFloat_FromDouble(sum);\n    }\n\n    return NULL;  /* Fall back to generic path */\n}\n\n/*NUMPY_API\n *Sum\n */\nNPY_NO_EXPORT PyObject *\nPyArray_Sum(PyArrayObject *self, int axis, int rtype, PyArrayObject *out)\n{\n    PyObject *arr, *ret;\n\n    /* Try optimized fast path first for float arrays */\n    ret = _PyArray_Sum_Optimized(self, axis, rtype, out);\n    if (ret != NULL) {\n        return ret;\n    }\n    if (PyErr_Occurred()) {\n        return NULL;\n    }\n\n    /* Fall back to generic reduce for other cases */\n    arr = PyArray_CheckAxis(self, &axis, 0);\n    if (arr == NULL) {\n        return NULL;\n    }\n    ret = PyArray_GenericReduceFunction((PyArrayObject *)arr, n_ops.add, axis,\n                                        rtype, out);\n    Py_DECREF(arr);\n    return ret;\n}",
