        "file_path": "/workspace/tests/template_tests/test_extends.py",
        "old_string": "    def test_extends_not_first_tag_in_extended_template_from_string(self):\n        template_string = \"{% block content %}B{% endblock %}{% extends 'base.html' %}\"\n        msg = \"{% extends 'base.html' %} must be the first tag in the template.\"\n        with self.assertRaisesMessage(TemplateSyntaxError, msg):\n            Engine().from_string(template_string)",
        "new_string": "    def test_extends_not_first_tag_in_extended_template_from_string(self):\n        template_string = \"{% block content %}B{% endblock %}{% extends 'base.html' %}\"\n        msg = \"{% extends 'base.html' %} must be the first tag in the template.\"\n        with self.assertRaisesMessage(TemplateSyntaxError, msg):\n            Engine().from_string(template_string)\n\n    def test_nested_blocks_three_level_inheritance(self):\n        \"\"\"\n        Test that nested blocks correctly resolve in 3-level inheritance.\n        base.html has outer block containing inner block.\n        middle.html extends base.html and overrides outer block.\n        child.html extends middle.html and overrides inner block.\n        The inner block override from child.html should be used, not base.html's.\n        \"\"\"\n        engine = Engine(dirs=[os.path.join(ROOT, \"nested_block_templates\")])\n        template = engine.get_template(\"child.html\")\n        output = template.render(Context({}))\n        # Should contain \"outer middle\" from middle.html and \"inner child\" from child.html\n        self.assertIn(\"outer middle\", output)\n        self.assertIn(\"inner child\", output)\n        self.assertNotIn(\"outer base\", output)\n        self.assertNotIn(\"inner base\", output)",
        "replace_all": false
      },
