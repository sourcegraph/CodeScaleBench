        "new_string": "}\n\nclass GoToNamedRegionAction extends EditorAction {\n\n\tconstructor() {\n\t\tsuper({\n\t\t\tid: 'editor.goToNamedRegion',\n\t\t\tlabel: nls.localize2('goToNamedRegion.label', \"Go to Named Region\"),\n\t\t\tprecondition: CONTEXT_FOLDING_ENABLED,\n\t\t\tkbOpts: {\n\t\t\t\tkbExpr: EditorContextKeys.editorTextFocus,\n\t\t\t\tprimary: KeyChord(KeyMod.CtrlCmd | KeyCode.KeyK, KeyMod.CtrlCmd | KeyCode.KeyN),\n\t\t\t\tweight: KeybindingWeight.EditorContrib\n\t\t\t}\n\t\t});\n\t}\n\n\toverride async run(accessor: ServicesAccessor, editor: ICodeEditor): Promise<void> {\n\t\tconst model = editor.getModel();\n\t\tif (!model) {\n\t\t\treturn;\n\t\t}\n\n\t\tconst quickInputService = accessor.get(IQuickInputService);\n\n\t\t// Extract named regions from the current file\n\t\tconst regions = NamedRegionProvider.extractNamedRegions(model);\n\n\t\tif (regions.length === 0) {\n\t\t\treturn;\n\t\t}\n\n\t\t// Create quick pick items\n\t\tconst items = regions.map((region, index) => ({\n\t\t\tlabel: region.name,\n\t\t\tdescription: `Line ${region.startLineNumber}`,\n\t\t\tregion,\n\t\t\tindex\n\t\t}));\n\n\t\t// Show quick pick\n\t\tconst selectedItem = await quickInputService.pick(items, {\n\t\t\tplaceHolder: 'Select a region to navigate to',\n\t\t\tmatchOnDescription: true,\n\t\t\tmatchOnDetail: true\n\t\t});\n\n\t\tif (!selectedItem) {\n\t\t\treturn;\n\t\t}\n\n\t\t// Navigate to the selected region\n\t\tconst region = selectedItem.region;\n\t\teditor.setSelection({\n\t\t\tstartLineNumber: region.startLineNumber,\n\t\t\tstartColumn: 1,\n\t\t\tendLineNumber: region.startLineNumber,\n\t\t\tendColumn: 1\n\t\t});\n\n\t\t// Reveal the line in the center of the viewport\n\t\teditor.revealPositionInCenterIfOutsideViewport(\n\t\t\t{ lineNumber: region.startLineNumber, column: 1 },\n\t\t\tScrollType.Smooth\n\t\t);\n\n\t\t// Unfold the region if it's collapsed\n\t\tconst foldingController = FoldingController.get(editor);\n\t\tif (foldingController) {\n\t\t\tfoldingCon