        "old_string": "// TestServerSkipAuthenticationMechanism verifies the existence of\n// the server skip authentication mechanism\nfunc TestServerSkipAuthenticationMechanism(t *testing.T) {\n\tt.Run(\"SkipsAuthenticationInterface\", func(t *testing.T) {\n\t\tt.Log(\"Server Skip Authentication Mechanism Analysis:\")\n\t\tt.Log(\"\")\n\t\tt.Log(\"A mechanism EXISTS to skip authentication:\")\n\t\tt.Log(\"- Interface: SkipsAuthenticationServer (defined in middleware/grpc/middleware.go)\")\n\t\tt.Log(\"- Method: SkipsAuthentication(ctx context.Context) bool\")\n\t\tt.Log(\"\")\n\t\tt.Log(\"Implementation:\")\n\t\tt.Log(\"- OIDC server: implements SkipsAuthentication() returning true\")\n\t\tt.Log(\"- Github server: implements SkipsAuthentication() returning true\")\n\t\tt.Log(\"- Kubernetes server: implements SkipsAuthentication() returning true\")\n\t\tt.Log(\"- Public auth server: implements SkipsAuthentication() returning true\")\n\t\tt.Log(\"\")\n\t\tt.Log(\"Configuration option EXISTS:\")\n\t\tt.Log(\"- WithServerSkipsAuthentication(server any) allows pre-configuring servers\")\n\t\tt.Log(\"- The middleware checks both interface implementation AND pre-configured servers\")\n\t\tt.Log(\"\")\n\t\tt.Log(\"Status: \u2713 Server-level authentication bypass mechanism EXISTS\")\n\t\tt.Log(\"        and is properly integrated for delegated authentication flows\")\n\t})\n}",
        "new_string": "// TestServerSkipAuthenticationMechanism verifies the existence of\n// the server skip authentication mechanism\nfunc TestServerSkipAuthenticationMechanism(t *testing.T) {\n\tt.Run(\"SkipsAuthenticationInterface\", func(t *testing.T) {\n\t\tt.Log(\"Server Skip Authentication Mechanism Analysis:\")\n\t\tt.Log(\"\")\n\t\tt.Log(\"A mechanism EXISTS to skip authentication:\")\n\t\tt.Log(\"- Interface: SkipsAuthenticationServer (defined in middleware/grpc/middleware.go)\")\n\t\tt.Log(\"- Method: SkipsAuthentication(ctx context.Context) bool\")\n\t\tt.Log(\"\")\n\t\tt.Log(\"Implementation:\")\n\t\tt.Log(\"- OIDC server: implements SkipsAuthentication() returning true\")\n\t\tt.Log(\"- Github server: implements SkipsAuthentication() returning true\")\n\t\tt.Log(\"- Kubernetes server: implements SkipsAuthentication() returning true\")\n\t\tt.Log(\"- Public auth server: implements SkipsAuthentication() returning true\")\n\t\tt.Log(\"\")\n\t\tt.Log(\"Configuration option EXISTS:\")\n\t\tt.Log(\"- WithServerSkipsAuthentication(server any) allows pre-configuring servers\")\n\t\tt.Log(\"- The middleware checks both interface implementation AND pre-configured servers\")\n\t\tt.Log(\"\")\n\t\tt.Log(\"Status: \u2713 Server-level authentication bypass mechanism EXISTS\")\n\t\tt.Log(\"        and is properly integrated for delegated authentication flows\")\n\t})\n}\n\n// TestBrowserCookieScenario demonstrates a real-world scenario where\n// browser-based authentication fails due to the ForwardCookies bug\nfunc TestBrowserCookieScenario(t *testing.T) {\n\tt.Log(\"Real-World Scenario: Browser-Based SPA Authentication\")\n\tt.Log(\"\")\n\tt.Log(\"SETUP:\")\n\tt.Log(\"1. Flipt UI is a React SPA running on https://flipt.example.com\")\n\tt.Log(\"2. User logs in via OIDC, receives flipt_client_token cookie\")\n\tt.Log(\"3. Cookie is set HttpOnly=true for security (can't be accessed by JS)\")\n\tt.Log(\"4. Browser stores token in secure cookie\")\n\tt.Log(\"\")\n\tt.Log(\"EXPECTED BEHAVIOR:\")\n\tt.Log(\"- User makes API calls to gRPC gateway\")\n\tt.Log(\"- Browser automatically includes Cookie header with every request\")\n\tt.Log(\"- ForwardCookies extracts flipt_client_token cookie\")\n\tt.Log(\"- Converts to gRPC metadata for middleware validation\")\n\tt.Log(\"- User authentication succeeds\")\n\tt.Log(\"\")\n\tt.Log(\"ACTUAL BEHAVIOR (BUG):\")\n\tt.Log(\"- User makes API calls to gRPC gateway\")\n\tt.Log(\"- Browser automatically includes Cookie header with every request\")\n\tt.Log(\"- ForwardCookies FAILS to extract token properly \u2717\")\n\tt.Log(\"- gRPC middleware receives no authentication\")\n\tt.Log(\"- Middleware returns 'unauthenticated' error\")\n\tt.Log(\"- User is logged out unexpectedly\")\n\tt.Log(\"- User has to manually include Authorization header (defeats security)\")\n\tt.Log(\"\")\n\tt.Log(\"ROOT CAUSE:\")\n\tt.Log(\"The ForwardCookies function in http.go has TWO bugs:\")\n\tt.Log(\"1. It always uses 'stateCookieKey' regardless of loop iteration\")\n\tt.Log(\"2. It sets individual cookie keys instead of 'grpcgateway-cookie' metadata\")\n\tt.Log(\"\")\n\tt.Log(\"IMPACT: Cookie-based authentication is completely broken for browser clients\")\n}\n\n// TestMetadataFormatMismatch demonstrates the metadata format issue\nfunc TestMetadataFormatMismatch(t *testing.T) {\n\tt.Log(\"Metadata Format Mismatch Analysis\")\n\tt.Log(\"\")\n\tt.Log(\"HTTP COOKIE HEADER FORMAT:\")\n\tt.Log(`  Cookie: name1=value1; name2=value2`)\n\tt.Log(\"\")\n\tt.Log(\"EXPECTED gRPC METADATA FORMAT (for grpcgateway-cookie key):\")\n\tt.Log(`  metadata.MD{`)\n\tt.Log(`    \"grpcgateway-cookie\": []string{\"name=value\"},`)\n\tt.Log(`  }`)\n\tt.Log(\"\")\n\tt.Log(\"CURRENT (BUGGY) METADATA FORMAT:\")\n\tt.Log(`  metadata.MD{`)\n\tt.Log(`    \"stateCookieKey\": []string{\"state_value\"},`)\n\tt.Log(`    \"tokenCookieKey\": []string{\"token_value\"},  // Actually, always overwrites with stateCookieKey`)\n\tt.Log(`  }`)\n\tt.Log(\"\")\n\tt.Log(\"Why this breaks:\")\n\tt.Log(\"- gRPC middleware looks for metadata key 'grpcgateway-cookie'\")\n\tt.Log(\"- It constructs an HTTP Cookie header from the metadata value\")\n\tt.Log(\"- Then uses net/http Cookie parsing to extract individual cookies\")\n\tt.Log(\"- But the metadata doesn't have 'grpcgateway-cookie' key, so it fails\")\n\tt.Log(\"\")\n\tt.Log(\"Middleware code in grpc/middleware.go:\")\n\tt.Log(`  func cookieFromMetadata(md metadata.MD, key string) (*http.Cookie, error) {`)\n\tt.Log(`    return (&http.Request{`)\n\tt.Log(`      Header: http.Header{\"Cookie\": md.Get(cookieHeaderKey)},  // \u2190 Looks for 'grpcgateway-cookie'`)\n\tt.Log(`    }).Cookie(key)`)\n\tt.Log(`  }`)\n}",
