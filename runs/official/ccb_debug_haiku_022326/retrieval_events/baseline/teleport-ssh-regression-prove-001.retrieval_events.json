        "new_string": "func newTestAuthServer(t *testing.T) (*auth.Server, *memory.Memory) {\n\tbackendSvc, err := memory.New(memory.Config{})\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create backend: %v\", err)\n\t}\n\n\t// Create cluster name\n\tclusterName, err := services.NewClusterName(services.ClusterNameSpecV2{\n\t\tClusterName: \"test.localhost\",\n\t})\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create cluster name: %v\", err)\n\t}\n\n\tauthConfig := &auth.InitConfig{\n\t\tClusterName:            clusterName,\n\t\tBackend:                backendSvc,\n\t\tAuthority:              testauthority.New(),\n\t\tSkipPeriodicOperations: true,\n\t\tClock:                  clockwork.NewRealClock(),\n\t}\n\n\tauthServer, err := auth.NewServer(authConfig)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create auth server: %v\", err)\n\t}\n\n\t// Set cluster name\n\terr = authServer.SetClusterName(clusterName)\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to set cluster name: %v\", err)\n\t}\n\n\t// Set default auth preference to support U2F\n\tcap, err := services.NewAuthPreference(services.AuthPreferenceSpecV2{\n\t\tType: \"u2f\",\n\t\tU2F: &types.U2F{\n\t\t\tAppID:  \"https://example.com\",\n\t\t\tFacets: []string{\"https://example.com\"},\n\t\t},\n\t})\n\tif err != nil {\n\t\tt.Fatalf(\"Failed to create auth preference: %v\", err)\n\t}\n\n\tif err := authServer.SetAuthPreference(cap); err != nil {\n\t\tt.Fatalf(\"Failed to set auth preference: %v\", err)\n\t}\n\n\treturn authServer, backendSvc\n}",
