        "new_string": "    @final\n    def _aggregate_series_pure_python(\n        self, obj: Series, func: Callable\n    ) -> npt.NDArray[np.object_]:\n        result = np.empty(self.ngroups, dtype=\"O\")\n        initialized = False\n\n        splitter = self._get_splitter(obj)\n\n        for i, group in enumerate(splitter):\n            res = func(group)\n            res = extract_result(res)\n\n            if not initialized:\n                # We only do this validation on the first iteration\n                check_result_array(res, group.dtype)\n                initialized = True\n\n            result[i] = res\n\n        return result\n\n    @final\n    def _aggregate_series_fast(\n        self, obj: Series, func: Callable\n    ) -> npt.NDArray[np.object_]:\n        \"\"\"\n        Faster aggregation using direct label indexing instead of creating sorted groups.\n        Avoids the overhead of DataSplitter sorting and Series object creation.\n        \"\"\"\n        result = np.empty(self.ngroups, dtype=\"O\")\n        initialized = False\n        ids = self.ids\n\n        # Accumulate indices for each group label\n        group_indices: dict[int, list[int]] = {}\n        for label_id in range(self.ngroups):\n            group_indices[label_id] = []\n\n        # Collect indices for each group (skip NA labels)\n        for i, label_id in enumerate(ids):\n            if label_id >= 0:\n                group_indices[label_id].append(i)\n\n        # Apply function to each group\n        for label_id in range(self.ngroups):\n            indices = group_indices[label_id]\n            if indices:\n                # Use iloc to create group without sorting/copying\n                group = obj.iloc[indices]\n            else:\n                # Empty group - create empty Series with same dtype\n                group = obj.iloc[:0]\n\n            res = func(group)\n            res = extract_result(res)\n\n            if not initialized:\n                # We only do this validation on the first iteration\n                check_result_array(res, obj.dtype)\n                initialized = True\n\n            result[label_id] = res\n\n        return result",
