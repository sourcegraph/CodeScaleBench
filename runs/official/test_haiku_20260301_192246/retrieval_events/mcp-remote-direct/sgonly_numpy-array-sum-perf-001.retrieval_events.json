        "old_string": "def _sum(a, axis=None, dtype=None, out=None, keepdims=False,\n         initial=_NoValue, where=True):\n    return umr_sum(a, axis, dtype, out, keepdims, initial, where)",
        "new_string": "def _sum(a, axis=None, dtype=None, out=None, keepdims=False,\n         initial=_NoValue, where=True):\n    # Fast path using einsum for common cases\n    if where is True and out is None and initial is _NoValue:\n        from numpy._core.einsumfunc import einsum\n        arr = asanyarray(a)\n        ndim = arr.ndim\n\n        if axis is None:\n            # Sum all elements\n            if ndim == 0:\n                # Scalar - return as-is or with dtype conversion\n                if dtype is None:\n                    return arr\n                return arr.astype(dtype)\n            # Create einsum string that sums all dimensions\n            einsum_str = ''.join(chr(ord('a') + i) for i in range(min(ndim, 52)))\n            einsum_str += '->'\n            result = einsum(einsum_str, arr, dtype=dtype)\n            return result\n        elif isinstance(axis, int):\n            # Single axis case\n            ax = mu.normalize_axis_index(axis, ndim)\n            if ndim == 0:\n                # Scalar\n                if keepdims:\n                    return arr.reshape((1,) * ndim).astype(dtype or arr.dtype)\n                return arr.astype(dtype or arr.dtype)\n            # sum(arr, axis=k)\n            indices = ''.join(chr(ord('a') + i) for i in range(min(ndim, 52)))\n            output = ''.join(chr(ord('a') + i) for i in range(min(ndim, 52)) if i != ax)\n            einsum_str = indices + '->' + output\n            result = einsum(einsum_str, arr, dtype=dtype)\n            if keepdims:\n                result = np.expand_dims(result, axis=ax)\n            return result\n        elif isinstance(axis, tuple) and len(axis) == 1:\n            # Tuple with single axis - convert to int and recurse\n            return _sum(a, axis=axis[0], dtype=dtype, out=out,\n                       keepdims=keepdims, initial=initial, where=where)\n        elif isinstance(axis, tuple):\n            # Multiple axes case\n            ndim = arr.ndim\n            # Normalize axes\n            axes = tuple(mu.normalize_axis_index(ax, ndim) for ax in axis)\n            axes_set = set(axes)\n            if ndim == 0:\n                return arr.astype(dtype or arr.dtype)\n            # Create einsum string\n            indices = ''.join(chr(ord('a') + i) for i in range(min(ndim, 52)))\n            output = ''.join(chr(ord('a') + i) for i in range(min(ndim, 52))\n                           if i not in axes_set)\n            einsum_str = indices + '->' + output\n            result = einsum(einsum_str, arr, dtype=dtype)\n            if keepdims:\n                # Add back dimensions\n                for ax in sorted(axes, reverse=True):\n                    result = np.expand_dims(result, axis=ax)\n            return result\n\n    return umr_sum(a, axis, dtype, out, keepdims, initial, where)",
        "replace_all": false
