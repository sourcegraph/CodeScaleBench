        "file_path": "/workspace/django/template/context.py",
        "old_string": "    def new(self, values=None):\n        \"\"\"\n        Return a new context with the same properties, but with only the\n        values given in 'values' stored.\n        \"\"\"\n        new_context = copy(self)\n        new_context._reset_dicts(values)\n        return new_context",
        "new_string": "    def new(self, values=None):\n        \"\"\"\n        Return a new context with the same properties, but with only the\n        values given in 'values' stored.\n        \"\"\"\n        new_context = copy(self)\n        new_context._reset_dicts(values)\n        # SECURITY FIX: When creating an isolated context, ensure the render_context\n        # is also fresh to prevent variables from parent context leaking through\n        # render_context references. This is crucial for template inclusion with\n        # the 'only' keyword to prevent access to loop variables and other\n        # dynamically injected template variables.\n        if hasattr(new_context, 'render_context'):\n            # Create a fresh RenderContext instead of copying the old one\n            # This ensures complete isolation from parent context state\n            from .context import RenderContext\n            new_context.render_context = RenderContext()\n        return new_context",
        "replace_all": false
