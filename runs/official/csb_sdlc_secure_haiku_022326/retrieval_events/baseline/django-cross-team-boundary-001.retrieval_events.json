        "new_string": "    async def test_cycle_with_no_session_cache_async(self):\n        await self.session.aset(\"a\", \"c\")\n        await self.session.aset(\"b\", \"d\")\n        await self.session.asave()\n        prev_data = await self.session.aitems()\n        self.session = self.backend(self.session.session_key)\n        self.assertIs(hasattr(self.session, \"_session_cache\"), False)\n        await self.session.acycle_key()\n        self.assertCountEqual(await self.session.aitems(), prev_data)\n\n    def test_cycle_with_collision_retry(self):\n        \"\"\"\n        Session data is preserved when key rotation encounters collisions.\n        This tests the fix for the race condition where a newly generated\n        session key collides with an existing one under high concurrency.\n        \"\"\"\n        self.session[\"a\"], self.session[\"b\"] = \"c\", \"d\"\n        self.session.save()\n        prev_key = self.session.session_key\n        prev_data = list(self.session.items())\n\n        # Mock _get_new_session_key to simulate collision by returning\n        # an existing key on first attempt, then a new one on second attempt.\n        original_get_new_session_key = self.session._get_new_session_key\n        call_count = [0]\n\n        def mocked_get_new_session_key():\n            call_count[0] += 1\n            if call_count[0] == 1:\n                # First call returns prev_key (collision)\n                return prev_key\n            else:\n                # Second call returns a new unique key\n                return original_get_new_session_key()\n\n        self.session._get_new_session_key = mocked_get_new_session_key\n\n        try:\n            self.session.cycle_key()\n            # Even with collision, old key should be gone\n            self.assertIs(self.session.exists(prev_key), False)\n            # New key should be different from old key\n            self.assertNotEqual(self.session.session_key, prev_key)\n            # Data should be preserved despite collision\n            self.assertEqual(list(self.session.items()), prev_data)\n        finally:\n            self.session._get_new_session_key = original_get_new_session_key\n\n    def test_save_doesnt_clear_data(self):",
