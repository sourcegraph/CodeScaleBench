        "old_string": "def conditional_escape(text):\n    \"\"\"\n    Similar to escape(), except that it doesn't operate on pre-escaped strings.\n\n    This function relies on the __html__ convention used both by Django's\n    SafeData class and by third-party libraries like markupsafe.\n    \"\"\"\n    if isinstance(text, Promise):\n        text = str(text)\n    if hasattr(text, \"__html__\"):\n        return text.__html__()\n    else:\n        return escape(text)\n\n\ndef format_html(format_string, *args, **kwargs):",
        "new_string": "def conditional_escape(text):\n    \"\"\"\n    Similar to escape(), except that it doesn't operate on pre-escaped strings.\n\n    This function relies on the __html__ convention used both by Django's\n    SafeData class and by third-party libraries like markupsafe.\n    \"\"\"\n    if isinstance(text, Promise):\n        text = str(text)\n    if hasattr(text, \"__html__\"):\n        return text.__html__()\n    else:\n        return escape(text)\n\n\ndef escape_with_encoding(s, encoding=\"utf-8\", strings_only=False, errors=\"strict\"):\n    \"\"\"\n    Convert text from a specified encoding to a string and HTML-escape it.\n\n    Combines encoding conversion and HTML escaping in one atomic operation to\n    prevent bugs where developers forget a step or apply them in the wrong order.\n\n    If strings_only is True and the input is a protected type (int, float,\n    Decimal, datetime, etc.), returns the value as-is without conversion or\n    escaping. Otherwise, converts to a Python string using the specified encoding\n    and then applies Django's standard conditional HTML escaping.\n\n    This function reuses Django's existing encoding conversion utilities\n    (force_str) and HTML escaping utilities (conditional_escape), ensuring\n    consistent behavior with other parts of Django.\n\n    Args:\n        s: The input value to convert and escape.\n        encoding: The character encoding to use (default: \"utf-8\").\n        strings_only: If True, skip conversion for protected types like int,\n            float, Decimal, and datetime objects (default: False).\n        errors: Error handling mode for encoding - 'strict' (default), 'ignore',\n            'replace', or other modes supported by the codec.\n\n    Returns:\n        If strings_only=True and s is a protected type, returns s unchanged.\n        Otherwise returns a SafeString with HTML-escaped content.\n    \"\"\"\n    # If strings_only and it's a protected type, return as-is without escaping\n    if strings_only and is_protected_type(s):\n        return s\n\n    # Convert to string using force_str with specified encoding\n    converted = force_str(s, encoding=encoding, strings_only=strings_only, errors=errors)\n\n    # Apply conditional escaping\n    return conditional_escape(converted)\n\n\ndef format_html(format_string, *args, **kwargs):",
