        "old_string": "logger = logging.getLogger(\"openlibrary.worksearch\")\n\n\nclass SearchScheme:",
        "new_string": "logger = logging.getLogger(\"openlibrary.worksearch\")\n\n\ndef normalize_query_for_lucene(query: str) -> str:\n    \"\"\"\n    Normalize user query by escaping edge-case characters that could be\n    misinterpreted by the Lucene parser.\n\n    Specifically handles:\n    - Trailing dashes at word boundaries (e.g., \"word-\" -> \"word\\\\-\")\n    - But preserves dashes within hyphenated words (e.g., \"test-query\")\n\n    :param query: Raw user query\n    :return: Normalized query with edge cases properly escaped\n    \"\"\"\n    # Escape trailing dashes that appear at the end of words followed by space or end of string\n    # This matches a word character followed by a dash that's followed by whitespace or end of string\n    # e.g., \"Horror- \" or \"test -\" or \"word-$\"\n    query = re.sub(r'(\\w)(-)([ \\t]|$)', r'\\1\\\\\\2\\3', query)\n    return query\n\n\nclass SearchScheme:",
        "replace_all": false
