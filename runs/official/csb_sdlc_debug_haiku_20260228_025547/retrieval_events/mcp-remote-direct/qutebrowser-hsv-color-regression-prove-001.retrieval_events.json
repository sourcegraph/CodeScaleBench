        "file_path": "/tmp/regression_test.py",
        "old_string": "def test_hsv_100_percent_hue():\n    \"\"\"Test that hsv(100%, 100%, 100%) produces hue=359, not hue=255.\n\n    This is the primary regression test. A 100% hue value should map to 359 degrees,\n    not 255 (which would be the case if the bug exists where hue is scaled to 0-255).\n    \"\"\"\n    parser = MockQtColor()\n    result = parser.to_py('hsv(100%,100%,100%)')\n    hue, sat, val, _ = result.getHsv()\n\n    # The hue should be 359 (100% of 359)\n    assert hue == 359, \\\n        f\"Expected hue=359 for hsv(100%,100%,100%), but got hue={hue}. \" \\\n        f\"This indicates hue is being scaled to 255 instead of 359.\"\n\n    # Saturation and value should be 255 (100% of 255)\n    assert sat == 255, \\\n        f\"Expected sat=255 for hsv(100%,100%,100%), but got sat={sat}\"\n    assert val == 255, \\\n        f\"Expected val=255 for hsv(100%,100%,100%), but got val={val}\"",
