        "new_string": "\tprivate watchFileSystemChanges(): vscode.Disposable {\n\t\t// Create file system watchers for TypeScript/JavaScript files to detect changes from git operations\n\t\tconst disposables: vscode.Disposable[] = [];\n\n\t\t// Batch file changes to avoid excessive diagnostics updates\n\t\tlet changedFiles = new Set<string>();\n\t\tlet deletedFiles = new Set<string>();\n\t\tlet changeTimeout: NodeJS.Timeout | undefined;\n\n\t\tconst triggerDiagnosticsForChangedFiles = () => {\n\t\t\tconst hasChanges = changedFiles.size > 0 || deletedFiles.size > 0;\n\t\t\tif (!hasChanges) {\n\t\t\t\treturn;\n\t\t\t}\n\n\t\t\t// For changed/created files, request fresh diagnostics\n\t\t\tconst filesToCheck = Array.from(changedFiles).map(fsPath => vscode.Uri.file(fsPath));\n\t\t\tif (filesToCheck.length > 0) {\n\t\t\t\tthis.client.bufferSyncSupport.getErr(filesToCheck);\n\t\t\t}\n\n\t\t\t// For deleted files, request diagnostics (will be cleared by the language server)\n\t\t\tconst deletedFilesToCheck = Array.from(deletedFiles).map(fsPath => vscode.Uri.file(fsPath));\n\t\t\tif (deletedFilesToCheck.length > 0) {\n\t\t\t\tthis.client.bufferSyncSupport.getErr(deletedFilesToCheck);\n\t\t\t}\n\n\t\t\tchangedFiles.clear();\n\t\t\tdeletedFiles.clear();\n\t\t};\n\n\t\tconst scheduleUpdate = () => {\n\t\t\tif (changeTimeout) {\n\t\t\t\tclearTimeout(changeTimeout);\n\t\t\t}\n\t\t\tchangeTimeout = setTimeout(() => {\n\t\t\t\ttriggerDiagnosticsForChangedFiles();\n\t\t\t\tchangeTimeout = undefined;\n\t\t\t}, 200); // Debounce file changes\n\t\t};\n\n\t\tconst onFileChange = (uri: vscode.Uri) => {\n\t\t\tchangedFiles.add(uri.fsPath);\n\t\t\tscheduleUpdate();\n\t\t};\n\n\t\tconst onFileDelete = (uri: vscode.Uri) => {\n\t\t\tdeletedFiles.add(uri.fsPath);\n\t\t\tchangedFiles.delete(uri.fsPath); // Remove from changed if it was there\n\t\t\tscheduleUpdate();\n\t\t};\n\n\t\t// Watch TypeScript files\n\t\tdisposables.push(vscode.workspace.createFileSystemWatcher('**/*.{ts,tsx,js,jsx,mts,mjs,cts,cjs}', false, false, false));\n\t\tconst tsWatcher = disposables[disposables.length - 1];\n\t\ttsWatcher.onDidChange(onFileChange);\n\t\ttsWatcher.onDidCreate(onFileChange);\n\t\ttsWatcher.onDidDelete(onFileDelete);\n\n\t\treturn new vscode.Disposable(() => {\n\t\t\tif (changeTimeout) {\n\t\t\t\tclearTimeout(changeTimeout);\n\t\t\t}\n\t\t\tfor (const disposable of disposables) {\n\t\t\t\tdisposable.dispose();\n\t\t\t}\n\t\t});\n\t}",
