        "old_string": "\tprivate isStyleCheckDiagnostic(code: number | undefined): boolean {\n\t\treturn typeof code === 'number' && styleCheckDiagnostics.has(code);\n\t}\n}",
        "new_string": "\tprivate watchFileSystemChanges(): vscode.Disposable {\n\t\t// Create a file system watcher for TypeScript/JavaScript files to detect changes from git operations\n\t\tconst patterns = [\n\t\t\t'**/*.ts',\n\t\t\t'**/*.tsx',\n\t\t\t'**/*.js',\n\t\t\t'**/*.jsx',\n\t\t\t'**/*.mts',\n\t\t\t'**/*.mjs',\n\t\t\t'**/*.cts',\n\t\t\t'**/*.cjs',\n\t\t];\n\n\t\tconst watcher = vscode.workspace.createFileSystemWatcher(\n\t\t\tnew vscode.RelativePattern(vscode.workspace.workspaceFolders?.[0] || vscode.Uri.file('/'), `{${patterns.join(',')}}`),\n\t\t\tfalse, // ignoreCreateEvents\n\t\t\tfalse, // ignoreChangeEvents\n\t\t\tfalse  // ignoreDeleteEvents\n\t\t);\n\n\t\t// Batch file changes to avoid excessive diagnostics updates\n\t\tlet changedFiles = new Set<string>();\n\t\tlet changeTimeout: NodeJS.Timeout | undefined;\n\n\t\tconst triggerDiagnosticsForChangedFiles = () => {\n\t\t\tif (changedFiles.size === 0) {\n\t\t\t\treturn;\n\t\t\t}\n\n\t\t\tconst filesToCheck = Array.from(changedFiles).map(fsPath => vscode.Uri.file(fsPath));\n\t\t\tchangedFiles.clear();\n\n\t\t\t// Request diagnostics for the changed files\n\t\t\tthis.client.bufferSyncSupport.getErr(filesToCheck);\n\t\t};\n\n\t\tconst scheduleUpdate = () => {\n\t\t\tif (changeTimeout) {\n\t\t\t\tclearTimeout(changeTimeout);\n\t\t\t}\n\t\t\tchangeTimeout = setTimeout(() => {\n\t\t\t\ttriggerDiagnosticsForChangedFiles();\n\t\t\t\tchangeTimeout = undefined;\n\t\t\t}, 200); // Debounce file changes\n\t\t};\n\n\t\tconst onFileChange = (uri: vscode.Uri) => {\n\t\t\tchangedFiles.add(uri.fsPath);\n\t\t\tscheduleUpdate();\n\t\t};\n\n\t\twatcher.onDidChange(onFileChange);\n\t\twatcher.onDidCreate(onFileChange);\n\t\twatcher.onDidDelete(onFileChange);\n\n\t\treturn new vscode.Disposable(() => {\n\t\t\tif (changeTimeout) {\n\t\t\t\tclearTimeout(changeTimeout);\n\t\t\t}\n\t\t\twatcher.dispose();\n\t\t});\n\t}\n\n\tprivate isStyleCheckDiagnostic(code: number | undefined): boolean {\n\t\treturn typeof code === 'number' && styleCheckDiagnostics.has(code);\n\t}\n}",
