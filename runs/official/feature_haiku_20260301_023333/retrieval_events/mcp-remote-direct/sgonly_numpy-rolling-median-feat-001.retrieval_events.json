        "file_path": "/workspace/numpy/lib/_rolling_median.py",
        "old_string": "def _compute_rolling_median_full(a, window_size):\n    \"\"\"\n    Compute rolling median for 'full' mode (output size: n + window_size - 1).\n    \"\"\"\n    n = len(a)\n    out_size = n + window_size - 1\n    result = np.empty(out_size, dtype=np.float64)\n\n    # Pad the input array with edge values\n    padded = np.pad(a, (window_size - 1, 0), mode='edge')\n\n    # Compute rolling median\n    for i in range(out_size):\n        window = padded[i:i + window_size]\n        result[i] = np.median(window)\n\n    return result",
        "new_string": "def _compute_rolling_median_full(a, window_size):\n    \"\"\"\n    Compute rolling median for 'full' mode (output size: n + window_size - 1).\n    \"\"\"\n    n = len(a)\n    out_size = n + window_size - 1\n    result = np.empty(out_size, dtype=np.float64)\n\n    # Pad the input array with edge values on both sides\n    padded = np.pad(a, (window_size - 1, window_size - 1), mode='edge')\n\n    # Compute rolling median\n    for i in range(out_size):\n        window = padded[i:i + window_size]\n        result[i] = np.median(window)\n\n    return result",
