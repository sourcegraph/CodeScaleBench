        "file_path": "/workspace/numpy/lib/_rolling_median.py",
        "old_string": "def _rolling_median_1d(a, window_size, mode):\n    \"\"\"\n    Compute rolling median for 1-D array.\n    \"\"\"\n    n = len(a)\n\n    # Handle edge case where window is larger than array\n    if window_size > n:\n        if mode == 'valid':\n            return np.array([], dtype=a.dtype)\n        elif mode == 'same':\n            # Return array of NaNs for all elements\n            result = np.empty(n, dtype=np.float64)\n            result[:] = np.nan\n            return result\n        elif mode == 'full':\n            # Pad the array and compute\n            padded = np.pad(a, (window_size - 1, 0), mode='edge')\n            return _compute_rolling_median_valid(padded, window_size)\n\n    if mode == 'valid':\n        return _compute_rolling_median_valid(a, window_size)\n    elif mode == 'same':\n        return _compute_rolling_median_same(a, window_size)\n    elif mode == 'full':\n        return _compute_rolling_median_full(a, window_size)",
