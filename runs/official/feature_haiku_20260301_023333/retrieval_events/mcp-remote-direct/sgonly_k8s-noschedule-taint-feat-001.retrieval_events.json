        "file_path": "/workspace/pkg/apis/core/types.go",
        "old_string": "// These are valid values for TaintEffect\nconst (\n\t// Do not allow new pods to schedule onto the node unless they tolerate the taint,\n\t// but allow all pods submitted to Kubelet without going through the scheduler\n\t// to start, and allow all already-running pods to continue running.\n\t// Enforced by the scheduler.\n\tTaintEffectNoSchedule TaintEffect = \"NoSchedule\"\n\t// Like TaintEffectNoSchedule, but the scheduler tries not to schedule\n\t// new pods onto the node, rather than prohibiting new pods from scheduling\n\t// onto the node entirely. Enforced by the scheduler.\n\tTaintEffectPreferNoSchedule TaintEffect = \"PreferNoSchedule\"\n\t// NOT YET IMPLEMENTED. TODO: Uncomment field once it is implemented.\n\t// Like TaintEffectNoSchedule, but additionally do not allow pods submitted to\n\t// Kubelet without going through the scheduler to start.\n\t// Enforced by Kubelet and the scheduler.\n\t// TaintEffectNoScheduleNoAdmit TaintEffect = \"NoScheduleNoAdmit\"\n\n\t// Evict any already-running pods that do not tolerate the taint.\n\t// Currently enforced by NodeController.\n\tTaintEffectNoExecute TaintEffect = \"NoExecute\"\n)",
        "new_string": "// These are valid values for TaintEffect\nconst (\n\t// Do not allow new pods to schedule onto the node unless they tolerate the taint,\n\t// but allow all pods submitted to Kubelet without going through the scheduler\n\t// to start, and allow all already-running pods to continue running.\n\t// Enforced by the scheduler.\n\tTaintEffectNoSchedule TaintEffect = \"NoSchedule\"\n\t// Like TaintEffectNoSchedule, but the scheduler tries not to schedule\n\t// new pods onto the node, rather than prohibiting new pods from scheduling\n\t// onto the node entirely. Enforced by the scheduler.\n\tTaintEffectPreferNoSchedule TaintEffect = \"PreferNoSchedule\"\n\t// NOT YET IMPLEMENTED. TODO: Uncomment field once it is implemented.\n\t// Like TaintEffectNoSchedule, but additionally do not allow pods submitted to\n\t// Kubelet without going through the scheduler to start.\n\t// Enforced by Kubelet and the scheduler.\n\t// TaintEffectNoScheduleNoAdmit TaintEffect = \"NoScheduleNoAdmit\"\n\n\t// Do not allow new pods to schedule onto the node unless they tolerate the taint.\n\t// Additionally, the node is excluded from service endpoint slices.\n\t// Do not evict running pods.\n\t// Enforced by the scheduler and endpoint slice controller.\n\tTaintEffectNoScheduleNoTraffic TaintEffect = \"NoScheduleNoTraffic\"\n\n\t// Evict any already-running pods that do not tolerate the taint.\n\t// Currently enforced by NodeController.\n\tTaintEffectNoExecute TaintEffect = \"NoExecute\"\n)",
