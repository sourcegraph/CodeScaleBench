        "new_string": "// LogDecision logs a policy decision with the provided identity, policy name,\n// verdict, and reason. This is used for audit purposes to track why specific\n// policy decisions were made.\nfunc (pal *PolicyAuditLogger) LogDecision(identity identity.NumericIdentity, policyName, verdict, reason string) {\n\tpal.Lock()\n\tdefer pal.Unlock()\n\n\tif !pal.enabled || !pal.logger.IsLevelEnabled(pal.logLevel) {\n\t\treturn\n\t}\n\n\tdecision := PolicyDecision{\n\t\tIdentity:   identity,\n\t\tPolicyName: policyName,\n\t\tVerdict:    verdict,\n\t\tReason:     reason,\n\t}\n\n\tscopedLog := pal.logger.WithFields(logrus.Fields{\n\t\tlogfields.Identity:  identity,\n\t\tlogfields.PolicyKey: policyName,\n\t\t\"verdict\":           verdict,\n\t\t\"reason\":            reason,\n\t\t\"audit_decision\":    json.RawMessage(mustMarshalJSON(decision)),\n\t})\n\n\t// Log the decision in structured format\n\tlogAtLevel(scopedLog, pal.logLevel, \"Policy decision\")\n}",
