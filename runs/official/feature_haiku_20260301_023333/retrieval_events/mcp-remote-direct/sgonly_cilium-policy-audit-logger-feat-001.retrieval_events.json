        "new_string": "// mustMarshalJSON marshals a value to JSON, panicking if marshaling fails.\n// This is appropriate for audit logging where data integrity is critical.\nfunc mustMarshalJSON(v interface{}) []byte {\n\tdata, err := json.Marshal(v)\n\tif err != nil {\n\t\t// This should never happen in practice, but we panic to catch\n\t\t// logic errors during development\n\t\tpanic(\"failed to marshal audit log entry: \" + err.Error())\n\t}\n\treturn data\n}\n\n// logAtLevel logs a message at the specified logrus level\nfunc logAtLevel(entry *logrus.Entry, level logrus.Level, msg string) {\n\tswitch level {\n\tcase logrus.DebugLevel:\n\t\tentry.Debug(msg)\n\tcase logrus.InfoLevel:\n\t\tentry.Info(msg)\n\tcase logrus.WarnLevel:\n\t\tentry.Warn(msg)\n\tcase logrus.ErrorLevel:\n\t\tentry.Error(msg)\n\tcase logrus.FatalLevel:\n\t\tentry.Fatal(msg)\n\tcase logrus.PanicLevel:\n\t\tentry.Panic(msg)\n\tdefault:\n\t\tentry.Info(msg)\n\t}\n}",
