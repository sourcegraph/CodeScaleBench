        "new_string": "  rc = nghttp3_conn_submit_request(ctx->h3conn, stream->id,\n                                   nva, nheader, preader, data);\n  if(rc) {\n    switch(rc) {\n    case NGHTTP3_ERR_CONN_CLOSING:\n      CURL_TRC_CF(data, cf, \"h3sid[%\"PRId64\"] failed to send, \"\n                  \"connection is closing\", stream->id);\n      break;\n    default:\n      CURL_TRC_CF(data, cf, \"h3sid[%\"PRId64\"] failed to send -> %d (%s)\",\n                  stream->id, rc, ngtcp2_strerror(rc));\n      break;\n    }\n    *err = CURLE_SEND_ERROR;\n    nwritten = -1;\n    goto out;\n  }\n\n  /* Handle RFC 9218 HTTP/3 stream priority if set */\n#if defined(USE_HTTP3) && defined(HAVE_NGHTTP3_PRIORITY)\n  if(data->set.priority.urgency != 3 || data->set.priority.incremental) {\n    nghttp3_priority priority;\n    priority.urgency = data->set.priority.urgency;\n    priority.incremental = data->set.priority.incremental;\n    rc = nghttp3_conn_prioritize_stream(ctx->h3conn, stream->id, &priority);\n    if(rc) {\n      CURL_TRC_CF(data, cf, \"h3sid[%\"PRId64\"] failed to set priority -> %d\",\n                  stream->id, rc);\n    }\n  }\n#endif\n\n  if(Curl_trc_is_verbose(data)) {\n    infof(data, \"[HTTP/3] [%\" PRId64 \"] OPENED stream for %s\",\n          stream->id, data->state.url);",
