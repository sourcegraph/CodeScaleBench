        "old_string": "#ifdef USE_HTTP3\n  case CURLOPT_H3_STREAM_PRIORITY:\n    /*\n     * Set HTTP/3 stream priority as per RFC 9218.\n     * Format: u=N[,i] where N is urgency (0-7) and i is the incremental flag.\n     */\n    result = Curl_setstropt(&data->set.h3_priority, va_arg(param, char *));\n    break;\n#endif",
        "new_string": "#ifdef USE_HTTP3\n  case CURLOPT_H3_STREAM_PRIORITY:\n  {\n    /*\n     * Set HTTP/3 stream priority as per RFC 9218.\n     * Format: u=N[,i] where N is urgency (0-7) and i is the incremental flag.\n     */\n    char *priority_str = va_arg(param, char *);\n    result = Curl_setstropt(&data->set.h3_priority, priority_str);\n    if(result == CURLE_OK && priority_str) {\n      /* Parse the priority string to extract urgency and incremental */\n      unsigned char urgency = 3;  /* default urgency */\n      bool incremental = FALSE;\n\n      /* Parse format: u=N[,i] */\n      if(strncmp(priority_str, \"u=\", 2) == 0) {\n        char *ptr = priority_str + 2;\n        long val = strtol(ptr, &ptr, 10);\n        if(val >= 0 && val <= 7) {\n          urgency = (unsigned char)val;\n        } else {\n          return CURLE_BAD_FUNCTION_ARGUMENT;\n        }\n        /* Check for incremental flag */\n        if(*ptr == ',' && *(ptr + 1) == 'i') {\n          incremental = TRUE;\n        }\n      } else {\n        return CURLE_BAD_FUNCTION_ARGUMENT;\n      }\n\n      data->set.priority.urgency = urgency;\n      data->set.priority.incremental = incremental ? 1 : 0;\n    }\n    break;\n  }\n#endif",
        "replace_all": false
      },
