        "file_path": "/app/tests/unit/browser/webengine/test_darkmode_qt64_regression.py",
        "old_string": "\"\"\"Regression test for Dark Mode Text Threshold Setting Bug on Qt 6.4\n\nTests that the dark mode text/foreground brightness threshold setting is \ncorrectly configured for Qt 6.4.\n\nBug Description:\n- Qt 6.4 renamed TextBrightnessThreshold to ForegroundBrightnessThreshold\n- The qutebrowser darkmode.py code needs to replace the key when Qt 6.4 is used\n- The copy_replace_setting() method is responsible for this replacement\n- If the bug exists, the old 'TextBrightnessThreshold' key would still be used on Qt 6.4\n\"\"\"\n\nimport logging\nimport pytest\n\nfrom qutebrowser.config import configdata\nfrom qutebrowser.utils import usertypes, version, utils\nfrom qutebrowser.browser.webengine import darkmode\nfrom qutebrowser.misc import objects\n\n\n@pytest.fixture(autouse=True)\ndef patch_backend(monkeypatch):\n    monkeypatch.setattr(objects, 'backend', usertypes.Backend.QtWebEngine)",
