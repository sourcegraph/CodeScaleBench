        "old_string": "class EmptyManager(Manager):\n    def __init__(self, model):\n        super().__init__()\n        self.model = model\n\n    def get_queryset(self):\n        return super().get_queryset().none()",
        "new_string": "class EmptyManager(Manager):\n    def __init__(self, model):\n        super().__init__()\n        self.model = model\n\n    def get_queryset(self):\n        return super().get_queryset().none()\n\n\nclass SoftDeleteManager(Manager):\n    \"\"\"\n    A custom manager that provides bulk soft-delete functionality.\n\n    This manager allows marking multiple records as deleted without actually\n    removing them from the database, which is useful for audit compliance.\n    \"\"\"\n\n    def bulk_soft_delete(\n        self,\n        queryset_or_ids: Union[QuerySet, Iterable[int]],\n        deleted_by: Optional[str] = None,\n    ) -> int:\n        \"\"\"\n        Perform bulk soft-deletion on multiple records.\n\n        Marks matching records with a deleted flag and timestamp using ORM\n        update operations.\n\n        Args:\n            queryset_or_ids: Either a QuerySet or an iterable of primary key IDs\n                to soft-delete.\n            deleted_by: Optional string to record who performed the deletion\n                (e.g., username or user ID). Will be stored in the deleted_by field.\n\n        Returns:\n            The count of records that were soft-deleted.\n\n        Example:\n            # Using a QuerySet\n            count = Model.soft_delete_objects.bulk_soft_delete(\n                Model.objects.filter(is_inactive=True),\n                deleted_by=\"admin_user\"\n            )\n\n            # Using a list of IDs\n            count = Model.soft_delete_objects.bulk_soft_delete(\n                [1, 2, 3],\n                deleted_by=\"admin_user\"\n            )\n        \"\"\"\n        # Convert IDs to QuerySet if necessary\n        if not isinstance(queryset_or_ids, QuerySet):\n            queryset = self.get_queryset().filter(pk__in=queryset_or_ids)\n        else:\n            queryset = queryset_or_ids\n\n        # Prepare the update values\n        update_values = {\n            \"is_deleted\": True,\n            \"deleted_at\": timezone.now(),\n        }\n\n        # Add deleted_by field if provided\n        if deleted_by is not None:\n            update_values[\"deleted_by\"] = deleted_by\n\n        # Execute the bulk update using ORM\n        return queryset.update(**update_values)\n\n    def bulk_restore(\n        self,\n        queryset_or_ids: Union[QuerySet, Iterable[int]],\n    ) -> int:\n        \"\"\"\n        Restore (undo) soft-deleted records.\n\n        Marks the specified records as not deleted by clearing the deleted\n        flag and timestamp using ORM update operations.\n\n        Args:\n            queryset_or_ids: Either a QuerySet or an iterable of primary key IDs\n                to restore.\n\n        Returns:\n            The count of records that were restored.\n\n        Example:\n            # Using a QuerySet\n            count = Model.soft_delete_objects.bulk_restore(\n                Model.soft_delete_objects.filter(user__id=5)\n            )\n\n            # Using a list of IDs\n            count = Model.soft_delete_objects.bulk_restore([1, 2, 3])\n        \"\"\"\n        # Convert IDs to QuerySet if necessary\n        if not isinstance(queryset_or_ids, QuerySet):\n            queryset = self.get_queryset().filter(pk__in=queryset_or_ids)\n        else:\n            queryset = queryset_or_ids\n\n        # Execute the bulk update using ORM\n        return queryset.update(\n            is_deleted=False,\n            deleted_at=None,\n            deleted_by=None,\n        )",
