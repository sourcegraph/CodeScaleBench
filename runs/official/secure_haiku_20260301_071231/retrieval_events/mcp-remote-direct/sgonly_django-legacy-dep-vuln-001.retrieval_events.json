        "old_string": "def conditional_escape(text):\n    \"\"\"\n    Similar to escape(), except that it doesn't operate on pre-escaped strings.\n\n    This function relies on the __html__ convention used both by Django's\n    SafeData class and by third-party libraries like markupsafe.\n    \"\"\"\n    if isinstance(text, Promise):\n        text = str(text)\n    if hasattr(text, \"__html__\"):\n        return text.__html__()\n    else:\n        return escape(text)",
        "new_string": "def conditional_escape(text):\n    \"\"\"\n    Similar to escape(), except that it doesn't operate on pre-escaped strings.\n\n    This function relies on the __html__ convention used both by Django's\n    SafeData class and by third-party libraries like markupsafe.\n    \"\"\"\n    if isinstance(text, Promise):\n        text = str(text)\n    if hasattr(text, \"__html__\"):\n        return text.__html__()\n    else:\n        return escape(text)\n\n\ndef escape_with_encoding(text, encoding=\"utf-8\", strings_only=False, errors=\"strict\"):\n    \"\"\"\n    Convert the given text from a specified encoding to a string and then HTML-escape it.\n\n    Accepts text in any encoding and produces a safe, HTML-escaped string.\n    Supports the same parameters as force_str() for encoding conversion:\n    - encoding: The encoding to use for decoding bytes (default: utf-8)\n    - strings_only: If True, skip conversion for protected types (int, float,\n                    Decimal, datetime, etc.)\n    - errors: How to handle encoding errors (default: strict)\n\n    If strings_only is True and the input is a protected type, returns the value\n    without conversion or escaping. Otherwise, converts to string using the\n    specified encoding and applies conditional HTML escaping (respects __html__\n    method and lazy translation objects).\n    \"\"\"\n    from django.utils.encoding import force_str, is_protected_type\n\n    # Handle lazy translation objects by resolving them first\n    if isinstance(text, Promise):\n        text = str(text)\n\n    # If strings_only is True and the object is a protected type, return as-is\n    if strings_only and is_protected_type(text):\n        return text\n\n    # Convert to string using force_str with the specified encoding\n    # Note: strings_only=False here because we've already handled protected types\n    text = force_str(text, encoding=encoding, strings_only=False, errors=errors)\n\n    # Apply conditional HTML escaping (respects __html__ and lazy objects)\n    return conditional_escape(text)",
        "replace_all": false
