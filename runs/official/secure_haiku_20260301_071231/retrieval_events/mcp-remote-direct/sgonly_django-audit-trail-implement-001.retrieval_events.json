        "old_string": "    def new(self, values=None):\n        \"\"\"\n        Return a new context with the same properties, but with only the\n        values given in 'values' stored.\n        \"\"\"\n        new_context = copy(self)\n        new_context._reset_dicts(values)\n        return new_context",
        "new_string": "    def new(self, values=None):\n        \"\"\"\n        Return a new context with the same properties, but with only the\n        values given in 'values' stored.\n        \"\"\"\n        new_context = copy(self)\n        new_context._reset_dicts(values)\n        # Create a fresh render_context to ensure complete isolation from the\n        # parent context. This prevents loop variables and other parent context\n        # state from leaking into isolated contexts (e.g., {% include ... only %}).\n        new_context.render_context = RenderContext()\n        return new_context",
