        "new_string": "    def prepare_value(self, value):\n        if hasattr(value, \"_meta\"):\n            if self.to_field_name:\n                return value.serializable_value(self.to_field_name)\n            else:\n                return value.pk\n        # Handle the case where value is a pk and to_field_name is set.\n        # When a ForeignKey field uses to_field, the initial value from\n        # model_to_dict() is a pk, but the form choices use to_field values.\n        # We need to convert the pk to the to_field value for consistent display.\n        if self.to_field_name and value not in self.empty_values:\n            try:\n                # Try to fetch the object using the pk value (default ForeignKey behavior)\n                obj = self.queryset.get(pk=value)\n                return obj.serializable_value(self.to_field_name)\n            except (ValueError, TypeError, self.queryset.model.DoesNotExist):\n                # If lookup fails, fall back to the value as-is\n                pass\n        return super().prepare_value(value)",
