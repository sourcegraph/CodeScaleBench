        "old_string": "// OTLPTracingConfig contains fields, which configure\n// OTLP span and tracing output destination.\ntype OTLPTracingConfig struct {\n\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n}",
        "new_string": "// OTLPTracingConfig contains fields, which configure\n// OTLP span and tracing output destination.\ntype OTLPTracingConfig struct {\n\tEndpoint string            `json:\"endpoint,omitempty\" mapstructure:\"endpoint\" yaml:\"endpoint,omitempty\"`\n\tHeaders  map[string]string `json:\"headers,omitempty\" mapstructure:\"headers\" yaml:\"headers,omitempty\"`\n}\n\n// SupportedPropagators is a map of supported propagator names\nvar SupportedPropagators = map[string]bool{\n\t\"tracecontext\": true,\n\t\"baggage\":      true,\n\t\"jaeger\":       true,\n\t\"zipkin\":       true,\n\t\"xray\":         true,\n\t\"b3\":           true,\n\t\"b3multi\":      true,\n}\n\n// Validate validates the TracingConfig fields\nfunc (c *TracingConfig) validate() error {\n\tif c.SamplingRate < 0 || c.SamplingRate > 1 {\n\t\treturn fmt.Errorf(\"sampling_rate must be between 0 and 1 (inclusive), got %v\", c.SamplingRate)\n\t}\n\n\tfor _, prop := range c.Propagators {\n\t\tif !SupportedPropagators[prop] {\n\t\t\tsupported := make([]string, 0, len(SupportedPropagators))\n\t\t\tfor k := range SupportedPropagators {\n\t\t\t\tsupported = append(supported, k)\n\t\t\t}\n\t\t\treturn fmt.Errorf(\"unsupported propagator %q, supported propagators are: %v\", prop, supported)\n\t\t}\n\t}\n\n\treturn nil\n}",
        "replace_all": false
