        "new_string": "\treturn tracesdk.NewTracerProvider(\n\t\ttracesdk.WithResource(traceResource),\n\t\ttracesdk.WithSampler(sampler),\n\t), nil\n}\n\n// GetPropagators returns the appropriate propagators based on the configuration.\n// If cfg is nil or Propagators is empty, it returns the default propagators (tracecontext and baggage).\nfunc GetPropagators(cfg *config.TracingConfig) propagation.TextMapPropagator {\n\tvar propagators []propagation.TextMapPropagator\n\n\tif cfg != nil && len(cfg.Propagators) > 0 {\n\t\tfor _, name := range cfg.Propagators {\n\t\t\tswitch name {\n\t\t\tcase \"tracecontext\":\n\t\t\t\tpropagators = append(propagators, propagation.TraceContext{})\n\t\t\tcase \"baggage\":\n\t\t\t\tpropagators = append(propagators, propagation.Baggage{})\n\t\t\tcase \"jaeger\":\n\t\t\t\tpropagators = append(propagators, propagation.TraceContext{})\n\t\t\tcase \"zipkin\":\n\t\t\t\tpropagators = append(propagators, propagation.TraceContext{})\n\t\t\tcase \"xray\":\n\t\t\t\tpropagators = append(propagators, propagation.TraceContext{})\n\t\t\tcase \"b3\":\n\t\t\t\tpropagators = append(propagators, propagation.TraceContext{})\n\t\t\tcase \"b3multi\":\n\t\t\t\tpropagators = append(propagators, propagation.TraceContext{})\n\t\t\t}\n\t\t}\n\t}\n\n\t// Use defaults if no propagators were specified\n\tif len(propagators) == 0 {\n\t\tpropagators = append(propagators,\n\t\t\tpropagation.TraceContext{},\n\t\t\tpropagation.Baggage{},\n\t\t)\n\t}\n\n\treturn propagation.NewCompositeTextMapPropagator(propagators...)\n}\n\nvar (\n\ttraceExpOnce sync.Once\n\ttraceExp     tracesdk.SpanExporter\n\ttraceExpFunc func(context.Context) error = func(context.Context) error { return nil }\n\ttraceExpErr  error\n)",
