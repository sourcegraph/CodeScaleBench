        "new_string": "class IncludeNodeTests(SimpleTestCase):\n    def test_repr(self):\n        include_node = IncludeNode(\"app/template.html\")\n        self.assertEqual(\n            repr(include_node),\n            \"<IncludeNode: template='app/template.html'>\",\n        )\n\n    def test_context_isolation_from_loop_variables(self):\n        \"\"\"\n        Context isolation (only keyword) should prevent loop variables\n        like forloop from leaking into included templates (SEC-0472).\n        \"\"\"\n        from django.template import Engine\n\n        engine = Engine(\n            debug=True,\n            loaders=[\n                (\n                    \"django.template.loaders.locmem.Loader\",\n                    {\n                        \"parent\": (\n                            \"{% for item in items %}\"\n                            \"{% include 'child' only %}\"\n                            \"{% endfor %}\"\n                        ),\n                        \"child\": \"forloop={{ forloop }}\",\n                    },\n                ),\n            ],\n        )\n\n        parent = engine.get_template(\"parent\")\n        result = parent.render(Context({\"items\": [1, 2, 3]}))\n        # forloop should not be accessible in isolated include\n        # It should be empty string if string_if_invalid is False\n        # or INVALID if string_if_invalid is True\n        self.assertNotIn(\"counter\", result)\n        self.assertNotIn(\"length\", result)",
