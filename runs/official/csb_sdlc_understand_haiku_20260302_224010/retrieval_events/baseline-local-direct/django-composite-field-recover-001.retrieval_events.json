        "old_string": "    def __call__(self, form):\n        \"\"\"\n        Validate the specified fields on the form.\n\n        Args:\n            form: The form instance being validated.\n        \"\"\"\n        # Check that all referenced fields exist on the form\n        for field_name in self.field_names:\n            if field_name not in form.fields:\n                raise ValueError(\n                    f\"Field '{field_name}' does not exist on form \"\n                    f\"'{form.__class__.__name__}'.\"\n                )\n\n        try:\n            # Call the validation function with the form's cleaned_data\n            self.function(form.cleaned_data)\n        except ValidationError as e:\n            # Add the error to the first field in the list of field names\n            # If the ValidationError has a message_dict, use that instead\n            if hasattr(e, 'error_dict'):\n                # If it's a dict-based error, add all errors\n                for field_name, error_list in e.error_dict.items():\n                    form.add_error(field_name, error_list)\n            else:\n                # Otherwise, add the error to the first field\n                field_name = self.field_names[0] if self.field_names else None\n                form.add_error(field_name, e)",
