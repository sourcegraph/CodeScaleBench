        "new_string": "    def has_output(self):\n        \"\"\"\n        Return True if there are meaningful choices available for filtering.\n\n        The filter shows choices like \"All\", any related objects, and \"(None)\" for\n        nullable fields. A filter should only appear if there is at least one\n        meaningful choice beyond \"All\" (i.e., at least one related object or\n        the empty option for nullable fields).\n        \"\"\"\n        if self.include_empty_choice:\n            extra = 1\n        else:\n            extra = 0\n        # Show filter if there's at least one meaningful choice beyond \"All\"\n        return len(self.lookup_choices) + extra >= 1",
        "replace_all": false
      },
