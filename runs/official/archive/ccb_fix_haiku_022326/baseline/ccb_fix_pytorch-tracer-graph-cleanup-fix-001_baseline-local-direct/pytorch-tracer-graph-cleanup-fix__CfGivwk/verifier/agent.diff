diff --git a/torch/_dynamo/output_graph.py b/torch/_dynamo/output_graph.py
index 91c716d..dd6a9a8 100644
--- a/torch/_dynamo/output_graph.py
+++ b/torch/_dynamo/output_graph.py
@@ -2246,6 +2246,40 @@ class OutputGraph(OutputGraphGuardsState):
         self.unspec_variable_map.clear()
         self.backward_state.clear()
 
+    def cleanup_on_exception(self) -> None:
+        """
+        Manually clean up reference cycles that prevent immediate garbage collection
+        of graphs from failed tracer outputs.
+
+        Reference cycles:
+        1. Graph nodes form a doubly-linked list pointing back to the graph
+        2. FakeTensorMode → ShapeEnv → TrackedFake → FakeTensor → FakeTensorMode
+
+        By manually breaking these cycles, we allow Python's reference counting
+        to immediately reclaim memory without waiting for garbage collection.
+        """
+        # Break the doubly-linked list of graph nodes
+        for node in list(self.graph.nodes):
+            # Clear the linked list pointers to break the cycle
+            # where nodes point to each other and back to the graph
+            node._prev = None  # type: ignore[attr-defined]
+            node._next = None  # type: ignore[attr-defined]
+            node.graph = None  # type: ignore[attr-defined]
+
+        # Also clear the root node's graph reference
+        if hasattr(self.graph, "_root"):
+            self.graph._root.graph = None  # type: ignore[attr-defined]
+
+        # Clear the ShapeEnv → TrackedFake reference cycle
+        if hasattr(self, "tracing_context") and hasattr(
+            self.tracing_context, "fake_mode"
+        ):
+            fake_mode = self.tracing_context.fake_mode
+            if hasattr(fake_mode, "shape_env") and fake_mode.shape_env is not None:
+                # Clear the tracked_fakes list to break the cycle
+                # where ShapeEnv holds a reference to all TrackedFake instances
+                fake_mode.shape_env.tracked_fakes = None  # type: ignore[attr-defined]
+
     def add_graph_finalizer(
         self, register_finalizer: Callable[[fx.GraphModule], None]
     ) -> None:
