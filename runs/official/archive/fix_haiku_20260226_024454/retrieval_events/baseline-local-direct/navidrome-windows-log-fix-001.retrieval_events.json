        "old_string": "\tDescribe(\"Redact\", func() {\n\t\tDescribe(\"Subsonic API password\", func() {\n\t\t\tmsg := \"getLyrics.view?v=1.2.0&c=iSub&u=user_name&p=first%20and%20other%20words&title=Title\"\n\t\t\tExpect(Redact(msg)).To(Equal(\"getLyrics.view?v=1.2.0&c=iSub&u=user_name&p=[REDACTED]&title=Title\"))\n\t\t})\n\t})\n})",
        "new_string": "\tDescribe(\"Redact\", func() {\n\t\tDescribe(\"Subsonic API password\", func() {\n\t\t\tmsg := \"getLyrics.view?v=1.2.0&c=iSub&u=user_name&p=first%20and%20other%20words&title=Title\"\n\t\t\tExpect(Redact(msg)).To(Equal(\"getLyrics.view?v=1.2.0&c=iSub&u=user_name&p=[REDACTED]&title=Title\"))\n\t\t})\n\t})\n\n\tDescribe(\"CRLFWriter\", func() {\n\t\tvar buffer *bytes.Buffer\n\t\tvar writer *CRLFWriter\n\n\t\tBeforeEach(func() {\n\t\t\tbuffer = &bytes.Buffer{}\n\t\t\twriter = &CRLFWriter{writer: buffer}\n\t\t})\n\n\t\tDescribe(\"Write\", func() {\n\t\t\tIt(\"converts single LF to CRLF\", func() {\n\t\t\t\tn, err := writer.Write([]byte(\"hello\\n\"))\n\t\t\t\tExpect(err).ToNot(HaveOccurred())\n\t\t\t\tExpect(n).To(Equal(6))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\\r\\n\"))\n\t\t\t})\n\n\t\t\tIt(\"preserves existing CRLF\", func() {\n\t\t\t\tn, err := writer.Write([]byte(\"hello\\r\\n\"))\n\t\t\t\tExpect(err).ToNot(HaveOccurred())\n\t\t\t\tExpect(n).To(Equal(7))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\\r\\n\"))\n\t\t\t})\n\n\t\t\tIt(\"converts multiple LF to CRLF\", func() {\n\t\t\t\tn, err := writer.Write([]byte(\"hello\\nworld\\n\"))\n\t\t\t\tExpect(err).ToNot(HaveOccurred())\n\t\t\t\tExpect(n).To(Equal(12))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\\r\\nworld\\r\\n\"))\n\t\t\t})\n\n\t\t\tIt(\"handles mixed LF and CRLF\", func() {\n\t\t\t\tn, err := writer.Write([]byte(\"hello\\r\\nworld\\n\"))\n\t\t\t\tExpect(err).ToNot(HaveOccurred())\n\t\t\t\tExpect(n).To(Equal(13))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\\r\\nworld\\r\\n\"))\n\t\t\t})\n\n\t\t\tIt(\"handles empty writes\", func() {\n\t\t\t\tn, err := writer.Write([]byte{})\n\t\t\t\tExpect(err).ToNot(HaveOccurred())\n\t\t\t\tExpect(n).To(Equal(0))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"\"))\n\t\t\t})\n\n\t\t\tIt(\"handles standalone CR\", func() {\n\t\t\t\tn, err := writer.Write([]byte(\"hello\\rworld\"))\n\t\t\t\tExpect(err).ToNot(HaveOccurred())\n\t\t\t\tExpect(n).To(Equal(11))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\\rworld\"))\n\t\t\t})\n\n\t\t\tIt(\"handles CRLF split across writes\", func() {\n\t\t\t\t// First write ends with \\r\n\t\t\t\tn1, err1 := writer.Write([]byte(\"hello\\r\"))\n\t\t\t\tExpect(err1).ToNot(HaveOccurred())\n\t\t\t\tExpect(n1).To(Equal(6))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\\r\"))\n\n\t\t\t\t// Second write starts with \\n\n\t\t\t\tn2, err2 := writer.Write([]byte(\"\\nworld\"))\n\t\t\t\tExpect(err2).ToNot(HaveOccurred())\n\t\t\t\tExpect(n2).To(Equal(6))\n\t\t\t\t// The \\n should not be converted to \\r\\n because it's preceded by \\r\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\\r\\nworld\"))\n\t\t\t})\n\n\t\t\tIt(\"handles LF split across writes\", func() {\n\t\t\t\t// First write with content and no trailing newline\n\t\t\t\tn1, err1 := writer.Write([]byte(\"hello\"))\n\t\t\t\tExpect(err1).ToNot(HaveOccurred())\n\t\t\t\tExpect(n1).To(Equal(5))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\"))\n\n\t\t\t\t// Second write with \\n\n\t\t\t\tn2, err2 := writer.Write([]byte(\"\\n\"))\n\t\t\t\tExpect(err2).ToNot(HaveOccurred())\n\t\t\t\tExpect(n2).To(Equal(1))\n\t\t\t\t// The \\n should be converted to \\r\\n\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\\r\\n\"))\n\t\t\t})\n\n\t\t\tIt(\"handles multiple writes with mixed endings\", func() {\n\t\t\t\t// Write 1: content with LF\n\t\t\t\tn1, err1 := writer.Write([]byte(\"line1\\n\"))\n\t\t\t\tExpect(err1).ToNot(HaveOccurred())\n\t\t\t\tExpect(n1).To(Equal(6))\n\n\t\t\t\t// Write 2: content with CRLF\n\t\t\t\tn2, err2 := writer.Write([]byte(\"line2\\r\\n\"))\n\t\t\t\tExpect(err2).ToNot(HaveOccurred())\n\t\t\t\tExpect(n2).To(Equal(7))\n\n\t\t\t\t// Write 3: content with LF\n\t\t\t\tn3, err3 := writer.Write([]byte(\"line3\\n\"))\n\t\t\t\tExpect(err3).ToNot(HaveOccurred())\n\t\t\t\tExpect(n3).To(Equal(6))\n\n\t\t\t\tExpect(buffer.String()).To(Equal(\"line1\\r\\nline2\\r\\nline3\\r\\n\"))\n\t\t\t})\n\n\t\t\tIt(\"handles text with no newlines\", func() {\n\t\t\t\tn, err := writer.Write([]byte(\"hello\"))\n\t\t\t\tExpect(err).ToNot(HaveOccurred())\n\t\t\t\tExpect(n).To(Equal(5))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\"))\n\t\t\t})\n\n\t\t\tIt(\"handles consecutive LFs\", func() {\n\t\t\t\tn, err := writer.Write([]byte(\"hello\\n\\nworld\"))\n\t\t\t\tExpect(err).ToNot(HaveOccurred())\n\t\t\t\tExpect(n).To(Equal(12))\n\t\t\t\tExpect(buffer.String()).To(Equal(\"hello\\r\\n\\r\\nworld\"))\n\t\t\t})\n\t\t})\n\t})\n})",
